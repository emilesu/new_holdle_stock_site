<% set_stock_seo(@stock) %>
<!-- 股票详情页 -->
<div class="min-h-screen bg-bg-soft" id="stock-detail-page">

  <div class="container-hl py-8">


    <!-- 左右两列布局 -->
    <div class="main-container grid grid-cols-1 lg:grid-cols-[4fr_1fr] gap-6">
      <!-- 左列：80% -->
      <div class="space-y-6">

        <!-- 上半部分：股票基础信息 + 雷达图 -->
        <div class="bg-white hl-card overflow-hidden">
          <div class="p-6 top-card flex flex-col lg:flex-row gap-8">
            <!-- 公司信息 -->
            <div class="company-info flex-1 min-w-0">
              <h1 class="text-hl-22 font-bold text-ink">
                <% if @stock.market == 'US' && @stock.name.present? && @stock.name.include?('|') %>
                  <% parts = @stock.name.split('|', 2) %>
                  <%= parts.first %><span class="text-hl-13 font-medium text-muted-2"> - <%= parts.last %></span>
                <% else %>
                  <%= @stock.name.presence || '未命名股票' %>
                <% end %>
              </h1>
              <div class="flex items-center space-x-2 mt-2">
                <span class="text-muted-2 text-hl-13 font-mono"><%= @stock.symbol.presence || 'N/A' %></span>
                <span class="px-2 py-1 text-xs font-semibold rounded <%= @market_badge_bg %>">
                    <%= @stock.market == 'CN' ? 'A股' : @stock.market == 'HK' ? '港股' : '美股' %>
                  </span>
                  <span class="px-2 py-1 text-xs font-semibold rounded <%= @market_badge_bg %>">
                    <%= @stock.exchange.presence || '-' %>
                  </span>
              </div>
              <div class="border-t border-line-soft pt-4 mt-4 space-y-3">
                <div class="flex justify-between py-2">
                  <span class="text-muted-3 text-hl-11">所属板块</span>
                  <span class="px-2 py-1 text-xs font-semibold rounded <%= @market_badge_bg %>">
                    <%= @stock.sector.presence || '-' %>
                  </span>
                </div>
                <div class="flex justify-between py-2">
                  <span class="text-muted-3 text-hl-11">所属行业</span>
                  <span class="px-2 py-1 text-xs font-semibold rounded <%= @market_badge_bg %>">
                    <%= @stock.industry.presence || '-' %>
                  </span>
                </div>
                <div class="flex justify-between py-2">
                  <span class="text-muted-3 text-hl-11">金字塔分</span>
                  <% if user_signed_in? && current_user.is_member? %>
                    <span class="text-ink font-medium"><%= @stock.pyramid_total_score %></span>
                  <% else %>
                    <span class="text-muted-4 text-hl-11">会员可见</span>
                  <% end %>
                </div>
              </div>
              <%= turbo_frame_tag "follow_stock_#{@stock.id}" do %>
                <% if user_signed_in? && @user_favorite.present? %>
                  <%= button_to "已关注", user_favorite_path(@user_favorite, stock_id: @stock.id), method: :delete,
                    class: "w-full hl-btn hl-btn-line mt-4" %>
                <% elsif user_signed_in? %>
                  <%= button_to "收藏股票", user_favorites_path(stock_id: @stock.id), method: :post,
                    class: "w-full hl-btn hl-btn-primary mt-4" %>
                <% else %>
                  <%= link_to "收藏股票", new_user_session_path,
                    class: "w-full hl-btn hl-btn-primary mt-4 text-center block" %>
                <% end %>
              <% end %>
            </div>
            
            <!-- 雷达图数据存储（隐藏） -->
            <div id="radar-data" 
                 data-current='<%= @radar_data.to_json.html_safe if @radar_data %>'
                 class="hidden"></div>

            <!-- 雷达图 -->
            <div class="radar-section flex-1 min-w-0 border-t border-line lg:border-t-0 lg:border-l lg:border-l-line lg:pl-8 pt-4 lg:pt-0">
              <canvas id="radarChart" width="400" height="400" style="display: block; margin: 0 auto; max-width: 100%;"></canvas>
            <!-- 图例区域由 Chart.js 渲染 -->
          </div>
          </div>
        </div>
        
        <!-- 获利能力表 -->
        <div class="bg-white hl-card overflow-hidden">
          <div class="px-6 py-4 border-b border-line">
            <h2 class="text-hl-16 font-semibold text-ink">获利能力 <span class="text-hl-12 text-muted-4 ml-2">Profitability</span> <span class="text-hl-12 text-muted-4 ml-2">(单位：<%= @stock.market == 'US' ? '美元' : @stock.market == 'HK' ? '港币' : '元' %>)</span></h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr>
                  <th class="text-left sticky left-0 bg-bg-soft z-10 min-w-[120px] px-6 py-3">指标</th>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <th class="px-4 py-3 text-right text-hl-11 font-semibold text-ink-soft whitespace-nowrap bg-bg-soft"><%= year %></th>
                    <% end %>
                  <% else %>
                    <th class="px-6 py-3 text-center text-hl-13 text-muted-4">暂无数据</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="divide-y divide-line-soft">
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="roe">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">净资产收益率（ROE）</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:roe].present? ? "%.2f%%" % @financial_data_by_year[year][:roe] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="roa">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">总资产收益率（ROA）</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:roa].present? ? "%.2f%%" % @financial_data_by_year[year][:roa] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="gross_margin">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium">毛利率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:gross_margin].present? ? "%.2f%%" % @financial_data_by_year[year][:gross_margin] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="net_profit_margin">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium">净利率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:net_profit_margin].present? ? "%.2f%%" % @financial_data_by_year[year][:net_profit_margin] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="eps">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">每股收益（EPS）</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:eps].present? ? "%.2f" % @financial_data_by_year[year][:eps] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                </tbody>
            </table>
          </div>
        </div>
        
        <!-- 财务结构表 -->
        <div class="bg-white hl-card overflow-hidden">
          <div class="px-6 py-4 border-b border-line">
            <h2 class="text-hl-16 font-semibold text-ink">财务结构 <span class="text-hl-12 text-muted-4 ml-2">Financial Structure</span></h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr>
                  <th class="text-left sticky left-0 bg-bg-soft z-10 min-w-[120px] px-6 py-3">指标</th>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <th class="px-4 py-3 text-right text-hl-11 font-semibold text-ink-soft whitespace-nowrap bg-bg-soft"><%= year %></th>
                    <% end %>
                  <% else %>
                    <th class="px-6 py-3 text-center text-hl-13 text-muted-4">暂无数据</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="divide-y divide-line-soft">
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="cash_to_assets_ratio">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">现金占总资产比率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:cash_to_assets_ratio].present? ? "%.2f%%" % @financial_data_by_year[year][:cash_to_assets_ratio] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="asset_liab_ratio">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">负债占总资产比率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:asset_liab_ratio].present? ? "%.2f%%" % @financial_data_by_year[year][:asset_liab_ratio] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- 经营能力表 -->
        <div class="bg-white hl-card overflow-hidden">
          <div class="px-6 py-4 border-b border-line">
            <h2 class="text-hl-16 font-semibold text-ink">经营能力 <span class="text-hl-12 text-muted-4 ml-2">Operating Capability</span></h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr>
                  <th class="text-left sticky left-0 bg-bg-soft z-10 min-w-[120px] px-6 py-3">指标</th>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <th class="px-4 py-3 text-right text-hl-11 font-semibold text-ink-soft whitespace-nowrap bg-bg-soft"><%= year %></th>
                    <% end %>
                  <% else %>
                    <th class="px-6 py-3 text-center text-hl-13 text-muted-4">暂无数据</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="divide-y divide-line-soft">
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="receivable_turnover">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">应收账款周转率(次)</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:receivable_turnover].present? ? "%.2f" % @financial_data_by_year[year][:receivable_turnover] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="avg_collection_days">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">平均收现日数</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:avg_collection_days].present? ? "%.0f 天" % @financial_data_by_year[year][:avg_collection_days] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="fixed_asset_turnover">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">固定资产周转率(次)</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:fixed_asset_turnover].present? ? "%.4f" % @financial_data_by_year[year][:fixed_asset_turnover] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="asset_turnover_ratio">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">总资产周转率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:asset_turnover_ratio].present? ? "%.2f%%" % (@financial_data_by_year[year][:asset_turnover_ratio] * 100) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- 现金流量表 -->
        <div class="bg-white hl-card overflow-hidden">
          <div class="px-6 py-4 border-b border-line">
            <h2 class="text-hl-16 font-semibold text-ink">现金流量 <span class="text-hl-12 text-muted-4 ml-2">Cash Flow</span> <span class="text-hl-12 text-muted-4 ml-2">(单位：<%= @stock.market == 'US' ? '亿美元' : @stock.market == 'HK' ? '亿港币' : '亿元' %>)</span></h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr>
                  <th class="text-left sticky left-0 bg-bg-soft z-10 min-w-[120px] px-6 py-3">指标</th>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <th class="px-4 py-3 text-right text-hl-11 font-semibold text-ink-soft whitespace-nowrap bg-bg-soft"><%= year %></th>
                    <% end %>
                  <% else %>
                    <th class="px-6 py-3 text-center text-hl-13 text-muted-4">暂无数据</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="divide-y divide-line-soft">
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="cash_and_cash_equivalents">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">现金及现金等价物</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:cash_and_cash_equivalents].present? ? "%.2f" % (@financial_data_by_year[year][:cash_and_cash_equivalents].to_f / 100_000_000) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="net_income">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">净利润</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:net_income].present? ? "%.2f" % (@financial_data_by_year[year][:net_income].to_f / 100_000_000) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="operating_cash_flow">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">经营活动现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:operating_cash_flow].present? ? "%.2f" % (@financial_data_by_year[year][:operating_cash_flow].to_f / 100_000_000) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="investing_cash_flow">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">投资活动现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:investing_cash_flow].present? ? "%.2f" % (@financial_data_by_year[year][:investing_cash_flow].to_f / 100_000_000) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="financing_cash_flow">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">筹资活动现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:financing_cash_flow].present? ? "%.2f" % (@financial_data_by_year[year][:financing_cash_flow].to_f / 100_000_000) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-bg-mute cursor-pointer indicator-row transition-colors" data-indicator="net_cash_change">
                  <td class="px-6 py-3 text-hl-13 text-muted font-medium whitespace-nowrap">净现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-hl-13 text-muted-2">
                        <%= @financial_data_by_year[year][:net_cash_change].present? ? "%.2f" % (@financial_data_by_year[year][:net_cash_change].to_f / 100_000_000) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-hl-13 text-muted-4">-</td>
                  <% end %>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <!-- 右列：20% -->
      <div class="lg:col-span-1">
        <div class="sticky top-24 bg-white hl-card overflow-hidden">
          <div class="px-4 py-4 border-b border-line bg-bg-mute">
            <span class="text-link font-semibold"><%= @stock.sector.presence || '-' %></span>
            <span class="text-muted-3 items-center justify-right text-hl-11"> - 近五年ROE对比</span>
          </div>
          <div class="p-4">
            
            <div class="border-t border-line-soft">
              <% if @industry_comparison_data.present? %>
                <div class="divide-y divide-line-soft">
                  <% @industry_comparison_data.each_with_index do |item, index| %>
                    <% stock = item[:stock] %>
                    <% radar_data = @comparison_radar_data[stock.symbol] %>
                    <a href="<%= stock_path(stock) %>"
                       class="block py-3 transition-colors comparison-item <%= item[:is_current_stock] ? 'bg-blue-50' : 'hover:bg-bg-mute' %>"
                       data-symbol="<%= stock.symbol %>"
                       data-radar='<%= raw radar_data.to_json if radar_data %>'>
                      <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-2">
                          <span class="w-5 h-5 rounded-full flex items-center justify-center text-hl-11 font-medium 
                            <%= item[:is_current_stock] ? 'bg-blue-500 text-white' : 'bg-bg-mute text-muted-2' %>">
                            <%= index + 1 %>
                          </span>
                          <div class="flex flex-col">
                            <span class="text-hl-13 font-medium text-ink"><%= stock.display_name_for_comparison %></span>
                            <span class="text-hl-11 text-muted-4"><%= stock.symbol %></span>
                          </div>
                        </div>
                        <span class="text-hl-11 font-medium <%= @market_text_color %>">
                          <%= '%.2f' % item[:roe_average] %>%
                        </span>
                      </div>
                    </a>
                  <% end %>
                </div>
              <% else %>
                <div class="text-center py-8">
                  <div class="text-muted-4 mb-2">📊</div>
                  <p class="text-hl-13 text-muted-3">暂无同行业股票数据</p>
                  <p class="text-hl-11 text-muted-4 mt-1">需要至少3年财务数据才能参与对比</p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
        
        <!-- 快速操作 -->
        <!--
        <div class="mt-6 bg-white hl-card p-4">
          <h3 class="text-hl-13 font-semibold text-ink-soft mb-4">快速操作</h3>
          <div class="space-y-2">
            <%= turbo_frame_tag "follow_stock_quick_#{@stock.id}" do %>
              <% if user_signed_in? && @user_favorite.present? %>
                <%= button_to "已收藏", user_favorite_path(@user_favorite, stock_id: @stock.id), method: :delete,
                  class: "w-full py-2 text-left text-hl-13 text-muted-2 hover:text-link hover:bg-bg-mute rounded transition-colors" %>
