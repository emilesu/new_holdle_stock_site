<!-- 股票详情页 -->
<div class="min-h-screen bg-gray-50 pt-10" id="stock-detail-page">
  <style>
    /* 强制布局样式 */
    #stock-detail-page .main-container {
      display: grid !important;
      grid-template-columns: 1fr !important;
      gap: 24px !important;
    }
    
    @media screen and (min-width: 1024px) {
      #stock-detail-page .main-container {
        grid-template-columns: 4fr 1fr !important;
      }
    }
    
    #stock-detail-page .top-card {
      display: flex !important;
      flex-direction: column !important;
      gap: 32px !important;
    }
    
    @media screen and (min-width: 1024px) {
      #stock-detail-page .top-card {
        flex-direction: row !important;
      }
    }
    
    #stock-detail-page .company-info,
    #stock-detail-page .radar-section {
      flex: 1 !important;
      min-width: 0 !important;
    }
    
    #stock-detail-page .radar-section {
      padding-top: 16px !important;
      border-top: 1px solid #e5e7eb !important;
    }
    
    @media screen and (min-width: 1024px) {
      #stock-detail-page .radar-section {
        padding-top: 0 !important;
        padding-left: 32px !important;
        border-top: none !important;
        border-left: 1px solid #e5e7eb !important;
      }
    }
    
    /* 财务表格悬停效果 */
    #stock-detail-page .indicator-row {
      cursor: pointer !important;
      transition: background-color 0.2s ease-in-out !important;
    }
    
    #stock-detail-page .indicator-row:hover {
      background-color: #eff6ff !important;
    }
    
    #stock-detail-page .indicator-row td {
      cursor: pointer !important;
    }
    
    #stock-detail-page .indicator-row:hover td {
      color: #1e40af !important;
    }
    
    /* 对比项悬停效果 */
    #stock-detail-page .comparison-item {
      cursor: pointer !important;
      transition: background-color 0.2s ease-in-out !important;
    }
    
    #stock-detail-page .comparison-item:hover {
      background-color: #f3f4f6 !important;
    }
  </style>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
 

    <!-- 左右两列布局 -->
    <div class="main-container">
      <!-- 左列：80% -->
      <div class="space-y-6">

        <!-- 上半部分：股票基础信息 + 雷达图 -->
        <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
          <div class="p-6 top-card">
            <!-- 公司信息 -->
            <div class="company-info">
              <h1 class="text-2xl font-bold text-gray-900">
                <% if @stock.market == 'US' && @stock.name.present? && @stock.name.include?('|') %>
                  <% parts = @stock.name.split('|', 2) %>
                  <%= parts.first %><span class="text-sm font-medium text-gray-600"> - <%= parts.last %></span>
                <% else %>
                  <%= @stock.name.presence || '未命名股票' %>
                <% end %>
              </h1>
              <div class="flex items-center space-x-2 mt-2">
                <span class="text-gray-600 text-sm font-mono"><%= @stock.symbol.presence || 'N/A' %></span>
                <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= @stock.market == 'CN' ? 'A股' : @stock.market == 'US' ? '美股' : '其他' %>
                </span>
                <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= @stock.exchange.presence || '-' %>
                </span>
              </div>
              <div class="border-t border-gray-100 pt-4 mt-4 space-y-3">
                <div class="flex justify-between py-2">
                  <span class="text-gray-500 text-xs">所属板块</span>
                  <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                    <%= @stock.sector.presence || '-' %>
                  </span>
                </div>
                <div class="flex justify-between py-2">
                  <span class="text-gray-500 text-xs">所属行业</span>
                  <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                    <%= @stock.industry.presence || '-' %>
                  </span>
                </div>
                <div class="flex justify-between py-2">
                  <span class="text-gray-500 text-xs">市值</span>
                  <span class="text-gray-900 font-medium"><%= @stock.respond_to?(:market_cap) && @stock.market_cap.present? ? "#{(@stock.market_cap / 100000000).round(2)} 亿" : '-' %></span>
                </div>
              </div>
              <button id="follow-btn" class="w-full py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors mt-4">
                关注股票
              </button>
            </div>
            
            <!-- 雷达图数据存储（隐藏） -->
            <div id="radar-data" 
                 data-current='<%= @radar_data.to_json.html_safe if @radar_data %>'
                 class="hidden"></div>

            <!-- 雷达图 -->
            <div class="radar-section">
              <canvas id="radarChart" width="400" height="400" style="display: block; margin: 0 auto; max-width: 100%;"></canvas>
            <!-- 图例区域由 Chart.js 渲染 -->
          </div>
          </div>
        </div>
        
        <!-- 获利能力表 -->
        <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-800">获利能力 <span class="text-gray-500 text-xs">(单位：<%= @stock.market == 'US' ? '美元' : '元' %>)</span></h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-sm font-medium text-gray-500 w-32 whitespace-nowrap">指标</th>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <th class="px-4 py-3 text-right text-xs font-semibold text-gray-800 whitespace-nowrap"><%= year %></th>
                    <% end %>
                  <% else %>
                    <th class="px-6 py-3 text-center text-sm text-gray-400">暂无数据</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="roe">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium whitespace-nowrap">净资产收益率（ROE）</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:roe].present? ? "%.2f%%" % @financial_data_by_year[year][:roe] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="roa">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium whitespace-nowrap">总资产收益率（ROA）</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:roa].present? ? "%.2f%%" % @financial_data_by_year[year][:roa] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="gross_margin">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">毛利率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:gross_margin].present? ? "%.2f%%" % @financial_data_by_year[year][:gross_margin] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="net_profit_margin">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">净利率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:net_profit_margin].present? ? "%.2f%%" % @financial_data_by_year[year][:net_profit_margin] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="eps">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium whitespace-nowrap">每股收益（EPS）</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:eps].present? ? "%.2f" % @financial_data_by_year[year][:eps] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="cash_flow_ps">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium whitespace-nowrap">每股现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:cash_flow_ps].present? ? "%.2f" % @financial_data_by_year[year][:cash_flow_ps] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        
        <!-- 财务结构 & 现金流量表 -->
        <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-800">财务结构 & 现金流量 <span class="text-gray-500 text-xs">(单位：<%= @stock.market == 'US' ? '亿美元' : '亿元' %>)</span></h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-sm font-medium text-gray-500 w-36 whitespace-nowrap">指标</th>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <th class="px-4 py-3 text-right text-xs font-semibold text-gray-800 whitespace-nowrap"><%= year %></th>
                    <% end %>
                  <% else %>
                    <th class="px-6 py-3 text-center text-sm text-gray-400">暂无数据</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="asset_liab_ratio">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium whitespace-nowrap">负债占资产比率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:asset_liab_ratio].present? ? "%.2f%%" % @financial_data_by_year[year][:asset_liab_ratio] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="asset_turnover_ratio">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium whitespace-nowrap">总资产周转率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:asset_turnover_ratio].present? ? "%.2f%%" % (@financial_data_by_year[year][:asset_turnover_ratio] * 100) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="net_income">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium whitespace-nowrap">净利润</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:net_income].present? ? "%.2f" % (@financial_data_by_year[year][:net_income] / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="operating_cash_flow">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium whitespace-nowrap">经营活动现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:operating_cash_flow].present? ? "%.2f" % (@financial_data_by_year[year][:operating_cash_flow] / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="investing_cash_flow">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium whitespace-nowrap">投资活动现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:investing_cash_flow].present? ? "%.2f" % (@financial_data_by_year[year][:investing_cash_flow] / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="financing_cash_flow">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium whitespace-nowrap">筹资活动现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:financing_cash_flow].present? ? "%.2f" % (@financial_data_by_year[year][:financing_cash_flow] / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-blue-50 cursor-pointer indicator-row transition-colors" data-indicator="net_cash_change">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium whitespace-nowrap">净现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:net_cash_change].present? ? "%.2f" % (@financial_data_by_year[year][:net_cash_change] / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <!-- 右列：20% -->
      <div class="lg:col-span-1">
        <div class="sticky top-24 bg-white rounded-lg overflow-hidden border border-gray-200">
          <div class="px-4 py-4 border-b border-gray-200 bg-gray-50">
            <span class="text-blue-600 font-semibold"><%= @stock.sector.presence || '-' %></span>
            <span class="text-gray-500 items-center justify-right text-xs"> - 近五年ROE对比</span>
          </div>
          <div class="p-4">
            
            <div class="border-t border-gray-100">
              <% if @industry_comparison_data.present? %>
                <div class="divide-y divide-gray-100">
                  <% @industry_comparison_data.each_with_index do |item, index| %>
                    <% stock = item[:stock] %>
                    <% radar_data = @comparison_radar_data[stock.symbol] %>
                    <a href="<%= stock_path(stock) %>"
                       class="block py-3 transition-colors comparison-item <%= item[:is_current_stock] ? '' : 'hover:bg-gray-50' %>"
                       data-symbol="<%= stock.symbol %>"
                       data-radar='<%= raw radar_data.to_json if radar_data %>'
                       <% if item[:is_current_stock] %>style="background-color: #eff6ff;"<% end %>>
                      <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-2">
                          <span class="w-5 h-5 rounded-full flex items-center justify-center text-xs font-medium 
                            <%= item[:is_current_stock] ? 'bg-blue-500 text-white' : 'bg-gray-100 text-gray-600' %>">
                            <%= index + 1 %>
                          </span>
                          <div class="flex flex-col">
                            <span class="text-sm font-medium text-gray-900"><%= stock.display_name_for_comparison %></span>
                            <span class="text-xs text-gray-400"><%= stock.symbol %></span>
                          </div>
                        </div>
                        <span class="text-xs font-medium <%= item[:roe_average] >= 15 ? 'text-green-600' : 'text-gray-500' %>">
                          <%= '%.2f' % item[:roe_average] %>%
                        </span>
                      </div>
                    </a>
                  <% end %>
                </div>
              <% else %>
                <div class="text-center py-8">
                  <div class="text-gray-400 mb-2">📊</div>
                  <p class="text-sm text-gray-500">暂无同行业股票数据</p>
                  <p class="text-xs text-gray-400 mt-1">需要至少3年财务数据才能参与对比</p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
        
        <!-- 快速操作 -->
        <div class="mt-6 bg-white rounded-lg border border-gray-200 p-4">
          <h3 class="text-sm font-semibold text-gray-800 mb-4">快速操作</h3>
          <div class="space-y-2">
            <button class="w-full py-2 text-left text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">添加到自选</button>
            <button class="w-full py-2 text-left text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">查看历史走势</button>
            <button class="w-full py-2 text-left text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">生成分析报告</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('turbo:load', function() {
  let chartInstance = null;
  let currentStockData = null;
  let hoverTimeout = null;

  const labels = ['ROE', '毛利率', '资产周转率', 'EPS', '负债比率', '净利率'];

  function extractValues(data) {
    if (!data || !data.values) return [0, 0, 0, 0, 0, 0];
    var v = data.values;
    return [
      typeof v.roe === 'number' ? v.roe : 0,
      typeof v.gross_margin === 'number' ? v.gross_margin : 0,
      typeof v.asset_turnover_ratio === 'number' ? v.asset_turnover_ratio : 0,
      typeof v.eps === 'number' ? v.eps : 0,
      typeof v.asset_liab_ratio === 'number' ? v.asset_liab_ratio : 0,
      typeof v.net_profit_margin === 'number' ? v.net_profit_margin : 0
    ];
  }

  function initRadarChart(compareData) {
    if (chartInstance) {
      chartInstance.destroy();
      chartInstance = null;
    }

    var canvas = document.getElementById('radarChart');
    if (!canvas) return;

    var currentValues = extractValues(currentStockData);
    var datasets = [{
      label: currentStockData ? (currentStockData.display_name || currentStockData.name) : '当前股票',
      data: currentValues,
      backgroundColor: 'rgba(239, 68, 68, 0.2)',
      borderColor: 'rgb(239, 68, 68)',
      borderWidth: 2,
      pointRadius: 3,
      pointBackgroundColor: 'rgb(239, 68, 68)',
      pointBorderColor: '#fff',
      pointBorderWidth: 1
    }];

    if (compareData) {
      var compareValues = extractValues(compareData);
      datasets.push({
        label: compareData.display_name || compareData.name || '对比股票',
        data: compareValues,
        backgroundColor: 'rgba(59, 130, 246, 0.2)',
        borderColor: 'rgb(59, 130, 246)',
        borderWidth: 2,
        pointRadius: 3,
        pointBackgroundColor: 'rgb(59, 130, 246)',
        pointBorderColor: '#fff',
        pointBorderWidth: 1
      });
    }

    chartInstance = new Chart(canvas, {
       type: 'radar',
       data: { labels: labels, datasets: datasets },
       options: {
         responsive: true,
         maintainAspectRatio: true,
         animation: false,
         scales: {
           r: {
             min: 0,
             max: 100,
             ticks: { stepSize: 20, backdropColor: 'transparent' },
             pointLabels: { font: { size: 11 }, color: '#374151' },
             grid: { color: 'rgba(0, 0, 0, 0.1)' },
             angleLines: { color: 'rgba(0, 0, 0, 0.1)' }
           }
         },
         plugins: {
           legend: {
             display: true,
             position: 'bottom',
             labels: {
               usePointStyle: true,
               padding: 16,
               font: { size: 11 }
             }
           }
         }
       }
     });
  }

  var radarDataEl = document.getElementById('radar-data');
  if (radarDataEl && radarDataEl.dataset.current) {
    try {
      currentStockData = JSON.parse(radarDataEl.dataset.current);
      setTimeout(function() { initRadarChart(null); }, 100);
    } catch (e) {
      console.error('Parse radar data error:', e);
    }
  }

  document.querySelectorAll('.comparison-item').forEach(function(item) {
    item.addEventListener('mouseenter', function() {
      if (hoverTimeout) clearTimeout(hoverTimeout);
      var radarRaw = this.dataset.radar;
      if (!radarRaw) return;
      try {
        var compareData = JSON.parse(radarRaw);
        initRadarChart(compareData);
      } catch (e) {
        console.error('Parse comparison radar data error:', e);
      }
    });

    item.addEventListener('mouseleave', function() {
      hoverTimeout = setTimeout(function() {
        initRadarChart(null);
      }, 100);
    });
  });
});
</script>

<script>
// 财务指标弹窗功能 - 封装在IIFE中避免全局变量污染
(function() {
  const STOCK_SYMBOL = '<%= @stock.symbol %>';
  const CACHE_TTL = 300000; // 5分钟缓存
  let chartInstance = null;

  // 初始化事件监听（兼容Turbo）
  function initEventListeners() {
    document.querySelectorAll('.indicator-row').forEach(row => {
      row.removeEventListener('click', handleRowClick);
      row.addEventListener('click', handleRowClick);
    });

    const backdrop = document.getElementById('modal-backdrop');
    const closeBtn = document.getElementById('modal-close');
    if (backdrop) {
      backdrop.removeEventListener('click', closeModal);
      backdrop.addEventListener('click', closeModal);
    }
    if (closeBtn) {
      closeBtn.removeEventListener('click', closeModal);
      closeBtn.addEventListener('click', closeModal);
    }
  }

  function handleRowClick() {
    const indicatorKey = this.dataset.indicator;
    openIndicatorModal(indicatorKey);
  }

  function openIndicatorModal(indicatorKey) {
    const modal = document.getElementById('indicator-modal');
    const chartContainer = document.getElementById('chart-container');
    const contentContainer = document.getElementById('content-container');
    const errorContainer = document.getElementById('error-container');

    // 显示加载状态
    chartContainer.innerHTML = '<div class="flex items-center justify-center h-56"><div class="w-8 h-8 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div></div>';
    contentContainer.classList.add('hidden');
    errorContainer.classList.add('hidden');

    // 显示弹窗（带过渡动画）
    modal.classList.remove('hidden');
    modal.classList.add('opacity-100');
    modal.querySelector('.relative').classList.add('scale-100');

    // 从缓存获取或调用API
    const cachedData = getCachedData(indicatorKey);
    if (cachedData) {
      renderIndicatorModal(cachedData);
      return;
    }

    const url = new URL(`/stocks/${encodeURIComponent(STOCK_SYMBOL)}/indicator_detail`, window.location.origin);
    url.searchParams.set('indicator_key', indicatorKey);
    
    fetch(url, {
      method: 'GET',
      headers: {
        'Accept': 'application/json'
      }
    })
      .then(res => {
        if (!res.ok) throw new Error('网络请求失败');
        return res.json();
      })
      .then(data => {
        if (data.success) {
          cacheData(indicatorKey, data.data);
          renderIndicatorModal(data.data);
        } else {
          showError(data.error || '加载失败');
        }
      })
      .catch(err => {
        console.error('Load indicator error:', err);
        showError('加载失败，请稍后重试');
      });
  }

  function showError(message) {
    const errorContainer = document.getElementById('error-container');
    const contentContainer = document.getElementById('content-container');
    errorContainer.innerHTML = `<div class="bg-gray-100 rounded-lg p-4"><p class="text-gray-600 text-center text-xs">${message}</p></div>`;
    errorContainer.classList.remove('hidden');
    contentContainer.classList.add('hidden');
  }

  function getCachedData(indicatorKey) {
    try {
      const cacheKey = `indicator_${STOCK_SYMBOL}_${indicatorKey}`;
      const cached = localStorage.getItem(cacheKey);
      if (cached) {
        const data = JSON.parse(cached);
        if (data.timestamp && Date.now() - data.timestamp < CACHE_TTL) {
          return data.payload;
        }
      }
    } catch (e) {
      console.warn('Cache read error:', e);
    }
    return null;
  }

  function cacheData(indicatorKey, payload) {
    try {
      const cacheKey = `indicator_${STOCK_SYMBOL}_${indicatorKey}`;
      localStorage.setItem(cacheKey, JSON.stringify({
        timestamp: Date.now(),
        payload: payload
      }));
    } catch (e) {
      console.warn('Cache write error:', e);
    }
  }

  function renderIndicatorModal(data) {
    const chartContainer = document.getElementById('chart-container');
    const contentContainer = document.getElementById('content-container');
    const errorContainer = document.getElementById('error-container');

    // 显示内容区域
    chartContainer.innerHTML = '<div style="height: 256px; overflow: hidden;"><canvas id="indicator-chart"></canvas></div>';
    contentContainer.classList.remove('hidden');
    errorContainer.classList.add('hidden');

    // 更新标题
    document.getElementById('modal-title').textContent = data.indicator_name;
    document.getElementById('indicator-description').textContent = data.description || '暂无说明';
    document.getElementById('indicator-formula').textContent = data.formula || '暂无公式';

    // 更新解读标准
    const interpretation = document.getElementById('indicator-interpretation');
    if (data.interpretation) {
      const order = ['excellent', 'good', 'normal', 'poor'];
      const labels = { excellent: '优秀', good: '良好', normal: '一般', poor: '较差' };

      interpretation.innerHTML = order.map(key => {
        if (data.interpretation[key]) {
          return `
            <div class="text-xs text-gray-600 py-1">
              <span class="text-gray-500 font-medium">${labels[key]}：</span>
              ${data.interpretation[key]}
            </div>
          `;
        }
        return '';
      }).join('');
    } else {
      interpretation.innerHTML = '<p class="text-xs text-gray-500">暂无解读标准</p>';
    }

    // 渲染图表
    renderIndicatorChart(data);
  }

  function renderIndicatorChart(data) {
    if (chartInstance) {
      chartInstance.destroy();
      chartInstance = null;
    }

    const ctx = document.getElementById('indicator-chart');
    if (!ctx) return;

    const points = data.data_points || [];
    const labels = points.map(p => p.year);
    
    const isCashFlowIndicator = ['net_income', 'operating_cash_flow', 'investing_cash_flow', 'financing_cash_flow', 'net_cash_change'].includes(data.indicator_key);
    const isAssetTurnover = data.indicator_key === 'asset_turnover_ratio';
    
    const values = points.map(p => {
      if (!p.value) return null;
      let val = parseFloat(p.value);
      if (isCashFlowIndicator && Math.abs(val) >= 100000000) {
        return val / 100000000;
      }
      if (isAssetTurnover) {
        return val * 100;
      }
      return val;
    });
    
    const validValues = values.filter(v => v !== null && !isNaN(v));
    const dataMin = validValues.length > 0 ? Math.min(...validValues) : 0;
    const dataMax = validValues.length > 0 ? Math.max(...validValues) : 100;
    const dataRange = dataMax - dataMin;
    
    let yMin, yMax;
    if (dataRange > 0) {
      const padding = dataRange * 0.15;
      const absMax = Math.max(Math.abs(dataMin), Math.abs(dataMax));
      if (dataRange / absMax < 0.05) {
        yMin = dataMin - padding;
        yMax = dataMax + padding;
      } else {
        yMin = dataMin - padding;
        yMax = dataMax + padding;
      }
    } else {
      yMin = dataMin - 1;
      yMax = dataMax + 1;
    }
    
    const formatted = points.map(p => p.formatted);
    const unit = isCashFlowIndicator ? '亿' : (data.unit || '');

    chartInstance = new Chart(ctx.getContext('2d'), {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: data.indicator_name,
          data: values,
          borderColor: 'rgb(59, 130, 246)',
          backgroundColor: 'rgba(59, 130, 246, 0.08)',
          fill: true,
          tension: 0.3,
          pointRadius: 4,
          pointHoverRadius: 8,
          pointBackgroundColor: 'rgb(59, 130, 246)',
          pointBorderColor: '#fff',
          pointBorderWidth: 2,
          borderWidth: 2,
          pointHoverBorderWidth: 3
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false,
          axis: 'x'
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            enabled: true,
            backgroundColor: 'rgba(30, 30, 30, 0.9)',
            titleFont: { size: 11, weight: '600' },
            bodyFont: { size: 10 },
            padding: 10,
            cornerRadius: 6,
            displayColors: false,
            usePointStyle: false,
            intersect: false,
            titleMarginBottom: 6,
            callbacks: {
              title: ctx => ctx[0].label + '年',
              label: ctx => data.indicator_name + ': ' + (formatted[ctx.dataIndex] || '-')
            }
          }
        },
        scales: {
          y: {
            min: yMin,
            max: yMax,
            beginAtZero: false,
            grid: {
              color: 'rgba(0, 0, 0, 0.06)',
              drawBorder: false,
              lineWidth: 1
            },
            ticks: {
              callback: v => (unit ? v.toFixed(2) + unit : v.toFixed(2)),
              color: '#555555',
              font: { size: 9 },
              padding: 6
            }
          },
          x: {
            grid: { display: false },
            ticks: {
              color: '#555555',
              font: { size: 9, weight: '500' },
              padding: 4
            }
          }
        },
        animation: {
          duration: 400,
          easing: 'linear'
        },
        hover: {
          mode: 'nearest',
          intersect: false
        },
        responsiveAnimationDuration: 0
      }
    });
  }

  function closeModal() {
    const modal = document.getElementById('indicator-modal');
    const modalContent = document.getElementById('modal-content');

    // 直接隐藏
    modal.classList.add('hidden');

    // 销毁图表实例
    if (chartInstance) {
      chartInstance.destroy();
      chartInstance = null;
    }
  }

  // ESC键关闭
  function handleKeydown(e) {
    const modal = document.getElementById('indicator-modal');
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeModal();
    }
  }

  // Turbo兼容：监听turbo:load事件
  document.addEventListener('turbo:load', initEventListeners);
  document.addEventListener('turbo:render', initEventListeners);
  document.addEventListener('keydown', handleKeydown);

  // 初始绑定
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEventListeners);
  } else {
    initEventListeners();
  }
})();
</script>

