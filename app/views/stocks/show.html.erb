<!-- 股票详情页 -->
<div class="min-h-screen bg-gray-50 pt-20">
  <style>
    @media (min-width: 1024px) {
      .stock-main-container {
        grid-template-columns: repeat(5, minmax(0, 1fr)) !important;
      }
      .stock-left-section {
        grid-column: span 4 / span 4 !important;
      }
      .stock-right-section {
        grid-column: span 1 / span 1 !important;
      }
      .top-row {
        display: flex;
        gap: 1rem;
      }
      .company-info {
        flex: 1;
      }
      .radar-wrapper {
        flex: 1;
      }
    }
  </style>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- 返回按钮 -->
    <div class="mb-6">
      <a href="/" class="inline-flex items-center space-x-2 text-gray-600 hover:text-blue-600 transition-colors">

      </a>
    </div>

    <!-- 左右两列布局 -->
    <div class="grid grid-cols-1 stock-main-container gap-6">
      <!-- 左列：80% -->
      <div class="stock-left-section space-y-6">
        
        <!-- 上半部分：股票基础信息 + 雷达图 -->
        <div class="bg-white rounded-lg overflow-hidden">
          <div class="p-6">
            <div class="top-row">
              <!-- 公司信息 -->
              <div class="company-info">
                <h1 class="text-2xl font-bold text-gray-900">
                  <% if @stock.market == 'US' && @stock.name.present? && @stock.name.include?('|') %>
                    <% parts = @stock.name.split('|', 2) %>
                    <%= parts.first %><span class="text-sm font-medium text-gray-600"> - <%= parts.last %></span>
                  <% else %>
                    <%= @stock.name.presence || '未命名股票' %>
                  <% end %>
                </h1>
                <div class="flex items-center space-x-2 mt-2">
                  <span class="text-gray-600 text-sm font-mono"><%= @stock.symbol.presence || 'N/A' %></span>
                  <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                    <%= @stock.market == 'CN' ? 'A股' : @stock.market == 'US' ? '美股' : '其他' %>
                  </span>
                </div>
                <div class="border-t border-gray-100 pt-4 mt-4 space-y-3">
                  <div class="flex justify-between py-2">
                    <span class="text-gray-500 text-sm">所属板块</span>
                    <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                      <%= @stock.sector.presence || '-' %>
                    </span>
                  </div>
                  <div class="flex justify-between py-2">
                    <span class="text-gray-500 text-sm">所属行业</span>
                    <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                      <%= @stock.industry.presence || '-' %>
                    </span>
                  </div>
                  <div class="flex justify-between py-2">
                    <span class="text-gray-500 text-sm">交易所</span>
                    <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                      <%= @stock.exchange.presence || '-' %>
                    </span>
                  </div>
                  <div class="flex justify-between py-2">
                    <span class="text-gray-500 text-sm">市值</span>
                    <span class="text-gray-900 font-medium"><%= @stock.respond_to?(:market_cap) && @stock.market_cap.present? ? "#{(@stock.market_cap / 100000000).round(2)} 亿" : '-' %></span>
                  </div>
                </div>
                <button id="follow-btn" class="w-full py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors mt-4">
                  关注股票
                </button>
              </div>
              
              <!-- 雷达图 -->
              <div class="radar-wrapper bg-white p-6">
                <div class="w-full h-full flex items-center justify-center">
                  <canvas id="radarChart"></canvas>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- 获利能力表 -->
        <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-800">获利能力</h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-sm font-medium text-gray-500 w-32">指标</th>
                  <% years = @financial_indicators.map { |i| i.report_date&.strftime('%Y') }.uniq.compact.sort.first(8) %>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <th class="px-4 py-3 text-right text-xs font-semibold text-gray-800 whitespace-nowrap"><%= year %></th>
                    <% end %>
                  <% else %>
                    <th class="px-6 py-3 text-center text-sm text-gray-400">暂无数据</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">净资产收益率（ROE）</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <% indicator = @financial_indicators.to_a.detect { |i| i.report_date&.strftime('%Y') == year } %>
                        <%= indicator&.roe_avg.present? ? "%.2f%%" % indicator.roe_avg : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">总资产收益率（ROA）</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <% indicator = @financial_indicators.to_a.detect { |i| i.report_date&.strftime('%Y') == year } %>
                        <%= indicator&.net_interest_of_ta.present? ? "%.2f%%" % indicator.net_interest_of_ta : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">毛利率</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <% if @stock.market == 'CN' %>
                          <% indicator = @financial_indicators.to_a.detect { |i| i.report_date&.strftime('%Y') == year } %>
                          <%= indicator&.gross_margin.present? ? "%.2f%%" % indicator.gross_margin : '-' %>
                        <% else %>
                          <% income = @income_statements.to_a.detect { |i| i.report_date&.strftime('%Y') == year } %>
                          <%= income&.operating_income.present? && income&.total_revenue.present? && income.total_revenue != 0 ? "%.2f%%" % (income.operating_income / income.total_revenue * 100) : '-' %>
                        <% end %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">净利率</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <% if @stock.market == 'CN' %>
                          <% income = @income_statements.to_a.detect { |i| i.report_date&.strftime('%Y') == year } %>
                          <%= income&.net_income_to_shareholders.present? && income&.total_revenue.present? && income.total_revenue != 0 ? "%.2f%%" % (income.net_income_to_shareholders / income.total_revenue * 100) : '-' %>
                        <% else %>
                          <% indicator = @financial_indicators.to_a.detect { |i| i.report_date&.strftime('%Y') == year } %>
                          <%= indicator&.net_sales_rate.present? ? "%.2f%%" % indicator.net_sales_rate : '-' %>
                        <% end %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">每股收益（EPS）</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <% indicator = @financial_indicators.to_a.detect { |i| i.report_date&.strftime('%Y') == year } %>
                        <%= indicator&.basic_eps.present? ? "%.2f" % indicator.basic_eps : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">每股现金流量</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <% indicator = @financial_indicators.to_a.detect { |i| i.report_date&.strftime('%Y') == year } %>
                        <%= indicator&.ncf_from_oa_ps.present? ? "%.2f" % indicator.ncf_from_oa_ps : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        
        <!-- 财务结构 & 现金流量表 -->
        <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-800">财务结构 & 现金流量</h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-sm font-medium text-gray-500 w-36">指标</th>
                  <% years = (@income_statements.map { |i| i.report_date&.strftime('%Y') } + @cash_flows.map { |c| c.report_date&.strftime('%Y') }).uniq.compact.sort.first(8) %>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <th class="px-4 py-3 text-right text-xs font-semibold text-gray-800 whitespace-nowrap"><%= year %></th>
                    <% end %>
                  <% else %>
                    <th class="px-6 py-3 text-center text-sm text-gray-400">暂无数据</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">负债占资产比率</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <% balance = @balance_sheets.to_a.detect { |b| b.report_date&.strftime('%Y') == year } %>
                        <% value = balance&.total_liabilities.present? && balance&.total_assets.present? && balance.total_assets != 0 ? (balance.total_liabilities / balance.total_assets * 100) : nil %>
                        <%= value.present? ? "%.2f%%" % value : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">总资产周转率</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <% income = @income_statements.to_a.detect { |i| i.report_date&.strftime('%Y') == year } %>
                        <% balance = @balance_sheets.to_a.detect { |b| b.report_date&.strftime('%Y') == year } %>
                        <% value = income&.total_revenue.present? && balance&.total_assets.present? && balance.total_assets != 0 ? (income.total_revenue / balance.total_assets * 100) : nil %>
                        <%= value.present? ? "%.2f%%" % value : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">净利润</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <% item = @income_statements.to_a.detect { |i| i.report_date&.strftime('%Y') == year } %>
                        <% value = item&.net_income_to_shareholders %>
                        <%= value.present? ? "%.2f" % (value / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">经营活动现金流量</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <% item = @cash_flows.to_a.detect { |c| c.report_date&.strftime('%Y') == year } %>
                        <% value = item&.operating_cash_flow %>
                        <%= value.present? ? "%.2f" % (value / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">投资活动现金流量</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <% item = @cash_flows.to_a.detect { |c| c.report_date&.strftime('%Y') == year } %>
                        <% value = item&.investing_cash_flow %>
                        <%= value.present? ? "%.2f" % (value / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">筹资活动现金流量</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <% item = @cash_flows.to_a.detect { |c| c.report_date&.strftime('%Y') == year } %>
                        <% value = item&.financing_cash_flow %>
                        <%= value.present? ? "%.2f" % (value / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">净现金流量</td>
                  <% if years.any? %>
                    <% years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <% item = @cash_flows.to_a.detect { |c| c.report_date&.strftime('%Y') == year } %>
                        <% value = item&.net_cash_change %>
                        <%= value.present? ? "%.2f" % (value / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <!-- 右列：20% -->
      <div class="stock-right-section">
        <div class="sticky top-24 bg-white rounded-lg overflow-hidden border border-gray-200">
          <div class="px-4 py-4 border-b border-gray-200 bg-gray-50">
            <h3 class="text-base font-semibold text-gray-800">行业对比</h3>
          </div>
          <div class="p-4">
            <div class="flex items-center justify-between text-sm mb-4">
              <span class="text-gray-500">对比标的</span>
              <span class="text-blue-600 font-medium"><%= @stock.sector.presence || '-' %></span>
            </div>
            <div class="border-t border-gray-100">
              <% if @industry_comparison.any? %>
                <div class="divide-y divide-gray-100">
                  <% @industry_comparison.first(10).each_with_index do |stock, index| %>
                    <a href="<%= stock_path(stock) %>" class="block py-3 hover:bg-gray-50 transition-colors">
                      <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-2">
                          <span class="w-5 h-5 rounded-full flex items-center justify-center text-xs font-medium <%= index == 0 ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600' %>">
                            <%= index + 1 %>
                          </span>
                          <span class="text-sm font-medium text-gray-900"><%= stock.name.presence || stock.symbol %></span>
                        </div>
                        <span class="text-xs text-green-600 font-medium">+<%= (rand * 5).round(2) %>%</span>
                      </div>
                    </a>
                  <% end %>
                </div>
              <% else %>
                <div class="text-center py-8">
                  <p class="text-sm text-gray-500">暂无同行业股票</p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
        
        <!-- 快速操作 -->
        <div class="mt-6 bg-white rounded-lg border border-gray-200 p-4">
          <h3 class="text-sm font-semibold text-gray-800 mb-4">快速操作</h3>
          <div class="space-y-2">
            <button class="w-full py-2 text-left text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">添加到自选</button>
            <button class="w-full py-2 text-left text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">查看历史走势</button>
            <button class="w-full py-2 text-left text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">生成分析报告</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('turbo:load', function() {
  const ctx = document.getElementById('radarChart');
  if (ctx) {
    const data = JSON.parse('<%= @radar_data.to_json.html_safe %>');
    new Chart(ctx, {
      type: 'radar',
      data: {
        labels: data.labels,
        datasets: [{
          label: data.datasets[0].label,
          data: data.datasets[0].data,
          backgroundColor: 'rgba(59, 130, 246, 0.1)',
          borderColor: 'rgb(59, 130, 246)',
          borderWidth: 2,
          pointBackgroundColor: 'rgb(59, 130, 246)',
          pointBorderColor: '#fff',
          pointBorderWidth: 2,
          pointRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        scales: {
          r: {
            beginAtZero: true,
            max: 50,
            ticks: { stepSize: 10, font: { size: 10 }, backdropColor: 'transparent', color: '#6B7280' },
            pointLabels: { font: { size: 11 }, color: '#374151' },
            grid: { color: '#E5E7EB' },
            angleLines: { color: '#E5E7EB' }
          }
        },
        plugins: { legend: { display: false } }
      }
    });
  }
  
  const followBtn = document.getElementById('follow-btn');
  if (followBtn) {
    followBtn.addEventListener('click', function() {
      if (followBtn.textContent.trim() === '关注股票') {
        followBtn.textContent = '已关注';
        followBtn.classList.remove('bg-blue-600', 'hover:bg-blue-700');
        followBtn.classList.add('bg-gray-200', 'text-gray-700');
      } else {
        followBtn.textContent = '关注股票';
        followBtn.classList.remove('bg-gray-200', 'text-gray-700');
        followBtn.classList.add('bg-blue-600', 'hover:bg-blue-700');
      }
    });
  }
});
</script>