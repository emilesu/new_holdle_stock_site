    <div class="px-6 border-b border-gray-100 flex justify-between items-center overflow-hidden" style="padding-top: 16px; padding-bottom: 16px; padding-left: 24px; padding-right: 24px;">
      <h3 id="modal-title" class="text-base font-semibold text-gray-800 truncate" style="margin-right: 16px;"></h3>
      <button id="modal-close" class="p-1.5 hover:bg-gray-100 rounded transition-colors" style="margin-left: 16px;">
