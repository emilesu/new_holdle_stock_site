<!-- 股票详情页 -->
<div class="min-h-screen bg-gray-50 pt-20">
  <style>
    @media (min-width: 1024px) {
      .stock-main-container {
        grid-template-columns: repeat(5, minmax(0, 1fr)) !important;
      }
      .stock-left-section {
        grid-column: span 4 / span 4 !important;
      }
      .stock-right-section {
        grid-column: span 1 / span 1 !important;
      }
      .top-row {
        display: flex;
        gap: 1rem;
      }
      .company-info {
        flex: 1;
      }
      .radar-wrapper {
        flex: 1;
      }
    }
  </style>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- 返回按钮 -->
    <div class="mb-6">
      <a href="/" class="inline-flex items-center space-x-2 text-gray-600 hover:text-blue-600 transition-colors">

      </a>
    </div>

    <!-- 左右两列布局 -->
    <div class="grid grid-cols-1 stock-main-container gap-6">
      <!-- 左列：80% -->
      <div class="stock-left-section space-y-6">
        
        <!-- 上半部分：股票基础信息 + 雷达图 -->
        <div class="bg-white rounded-lg overflow-hidden">
          <div class="p-6">
            <div class="top-row">
              <!-- 公司信息 -->
              <div class="company-info">
                <h1 class="text-2xl font-bold text-gray-900">
                  <% if @stock.market == 'US' && @stock.name.present? && @stock.name.include?('|') %>
                    <% parts = @stock.name.split('|', 2) %>
                    <%= parts.first %><span class="text-sm font-medium text-gray-600"> - <%= parts.last %></span>
                  <% else %>
                    <%= @stock.name.presence || '未命名股票' %>
                  <% end %>
                </h1>
                <div class="flex items-center space-x-2 mt-2">
                  <span class="text-gray-600 text-sm font-mono"><%= @stock.symbol.presence || 'N/A' %></span>
                  <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                    <%= @stock.market == 'CN' ? 'A股' : @stock.market == 'US' ? '美股' : '其他' %>
                  </span>
                </div>
                <div class="border-t border-gray-100 pt-4 mt-4 space-y-3">
                  <div class="flex justify-between py-2">
                    <span class="text-gray-500 text-sm">所属板块</span>
                    <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                      <%= @stock.sector.presence || '-' %>
                    </span>
                  </div>
                  <div class="flex justify-between py-2">
                    <span class="text-gray-500 text-sm">所属行业</span>
                    <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                      <%= @stock.industry.presence || '-' %>
                    </span>
                  </div>
                  <div class="flex justify-between py-2">
                    <span class="text-gray-500 text-sm">交易所</span>
                    <span class="px-2 py-1 text-xs font-semibold rounded <%= @stock.market == 'CN' ? 'bg-green-100 text-green-800' : @stock.market == 'US' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' %>">
                      <%= @stock.exchange.presence || '-' %>
                    </span>
                  </div>
                  <div class="flex justify-between py-2">
                    <span class="text-gray-500 text-sm">市值</span>
                    <span class="text-gray-900 font-medium"><%= @stock.respond_to?(:market_cap) && @stock.market_cap.present? ? "#{(@stock.market_cap / 100000000).round(2)} 亿" : '-' %></span>
                  </div>
                </div>
                <button id="follow-btn" class="w-full py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors mt-4">
                  关注股票
                </button>
              </div>
              
              <!-- 雷达图数据存储（隐藏） -->
              <div id="radar-data" 
                   data-current='<%= raw @radar_data.to_json if @radar_data %>'
                   style="display: none;"></div>

              <!-- 雷达图 -->
              <div class="radar-wrapper p-6" >
                <canvas id="radarChart" width="400" height="400" style="display: block; margin: 0 auto;"></canvas>
                <!-- 图例 -->
                <div class="flex justify-center items-center space-x-6 mt-4 text-sm">
                  <div class="flex items-center space-x-2">
                    <span class="w-4 h-1 bg-blue-500 rounded"></span>
                  </div>
                  <div class="flex items-center space-x-2">
                    <span class="w-4 h-1 bg-red-500 rounded"></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- 获利能力表 -->
        <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-800">获利能力</h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-sm font-medium text-gray-500 w-32">指标</th>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <th class="px-4 py-3 text-right text-xs font-semibold text-gray-800 whitespace-nowrap"><%= year %></th>
                    <% end %>
                  <% else %>
                    <th class="px-6 py-3 text-center text-sm text-gray-400">暂无数据</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">净资产收益率（ROE）</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:roe].present? ? "%.2f%%" % @financial_data_by_year[year][:roe] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">总资产收益率（ROA）</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:roa].present? ? "%.2f%%" % @financial_data_by_year[year][:roa] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">毛利率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:gross_margin].present? ? "%.2f%%" % @financial_data_by_year[year][:gross_margin] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">净利率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:net_profit_margin].present? ? "%.2f%%" % @financial_data_by_year[year][:net_profit_margin] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">每股收益（EPS）</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:eps].present? ? "%.2f" % @financial_data_by_year[year][:eps] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">每股现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm text-gray-600">
                        <%= @financial_data_by_year[year][:cash_flow_ps].present? ? "%.2f" % @financial_data_by_year[year][:cash_flow_ps] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        
        <!-- 财务结构 & 现金流量表 -->
        <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-800">财务结构 & 现金流量</h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-sm font-medium text-gray-500 w-36">指标</th>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <th class="px-4 py-3 text-right text-xs font-semibold text-gray-800 whitespace-nowrap"><%= year %></th>
                    <% end %>
                  <% else %>
                    <th class="px-6 py-3 text-center text-sm text-gray-400">暂无数据</th>
                  <% end %>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">负债占资产比率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:asset_liab_ratio].present? ? "%.2f%%" % @financial_data_by_year[year][:asset_liab_ratio] : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">总资产周转率</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:asset_turnover_ratio].present? ? "%.2f%%" % (@financial_data_by_year[year][:asset_turnover_ratio] * 100) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">净利润</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:net_income].present? ? "%.2f" % (@financial_data_by_year[year][:net_income] / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">经营活动现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:operating_cash_flow].present? ? "%.2f" % (@financial_data_by_year[year][:operating_cash_flow] / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">投资活动现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:investing_cash_flow].present? ? "%.2f" % (@financial_data_by_year[year][:investing_cash_flow] / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">筹资活动现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:financing_cash_flow].present? ? "%.2f" % (@financial_data_by_year[year][:financing_cash_flow] / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3 text-sm text-gray-700 font-medium">净现金流量</td>
                  <% if @financial_years.any? %>
                    <% @financial_years.each do |year| %>
                      <td class="px-4 py-3 text-right text-sm">
                        <%= @financial_data_by_year[year][:net_cash_change].present? ? "%.2f" % (@financial_data_by_year[year][:net_cash_change] / 100000000.0) : '-' %>
                      </td>
                    <% end %>
                  <% else %>
                    <td class="px-6 py-3 text-center text-sm text-gray-400">-</td>
                  <% end %>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <!-- 右列：20% -->
      <div class="stock-right-section">
        <div class="sticky top-24 bg-white rounded-lg overflow-hidden border border-gray-200">
          <div class="px-4 py-4 border-b border-gray-200 bg-gray-50">
            <span class="text-blue-600 font-semibold"><%= @stock.sector.presence || '-' %></span>
            <span class="text-gray-500 items-center justify-right text-xs"> - 近五年ROE对比</span>
          </div>
          <div class="p-4">
            
            <div class="border-t border-gray-100">
              <% if @industry_comparison_data.present? %>
                <div class="divide-y divide-gray-100">
                  <% @industry_comparison_data.each_with_index do |item, index| %>
                    <% stock = item[:stock] %>
                    <% radar_data = @comparison_radar_data[stock.symbol] %>
                    <a href="<%= stock_path(stock) %>"
                       class="block py-3 transition-colors comparison-item <%= item[:is_current_stock] ? '' : 'hover:bg-gray-50' %>"
                       data-symbol="<%= stock.symbol %>"
                       data-radar='<%= raw radar_data.to_json if radar_data %>'
                       <% if item[:is_current_stock] %>style="background-color: #eff6ff;"<% end %>>
                      <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-2">
                          <span class="w-5 h-5 rounded-full flex items-center justify-center text-xs font-medium 
                            <%= item[:is_current_stock] ? 'bg-blue-500 text-white' : 'bg-gray-100 text-gray-600' %>">
                            <%= index + 1 %>
                          </span>
                          <div class="flex flex-col">
                            <span class="text-sm font-medium text-gray-900"><%= stock.display_name_for_comparison %></span>
                            <span class="text-xs text-gray-400"><%= stock.symbol %></span>
                          </div>
                        </div>
                        <span class="text-xs font-medium <%= item[:roe_average] >= 15 ? 'text-green-600' : 'text-gray-500' %>">
                          <%= '%.2f' % item[:roe_average] %>%
                        </span>
                      </div>
                    </a>
                  <% end %>
                </div>
              <% else %>
                <div class="text-center py-8">
                  <div class="text-gray-400 mb-2">📊</div>
                  <p class="text-sm text-gray-500">暂无同行业股票数据</p>
                  <p class="text-xs text-gray-400 mt-1">需要至少3年财务数据才能参与对比</p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
        
        <!-- 快速操作 -->
        <div class="mt-6 bg-white rounded-lg border border-gray-200 p-4">
          <h3 class="text-sm font-semibold text-gray-800 mb-4">快速操作</h3>
          <div class="space-y-2">
            <button class="w-full py-2 text-left text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">添加到自选</button>
            <button class="w-full py-2 text-left text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">查看历史走势</button>
            <button class="w-full py-2 text-left text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">生成分析报告</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function parseRadarData(encodedData) {
  if (!encodedData) return null;
  try {
    return JSON.parse(encodedData);
  } catch (e) {
    console.error('Failed to parse radar data:', e);
    return null;
  }
}

function getChartData(stockData) {
  var defaultData = [50, 60, 70, 80, 65, 55];
  if (!stockData || !stockData.normalized_values) return defaultData;
  
  var vals = stockData.normalized_values;
  return [
    typeof vals.roe === 'number' ? vals.roe : 0,
    typeof vals.gross_margin === 'number' ? vals.gross_margin : 0,
    typeof vals.net_profit_margin === 'number' ? vals.net_profit_margin : 0,
    typeof vals.eps === 'number' ? vals.eps : 0,
    typeof vals.asset_liab_ratio === 'number' ? vals.asset_liab_ratio : 0,
    typeof vals.asset_turnover_ratio === 'number' ? vals.asset_turnover_ratio : 0
  ];
}

function initChart() {
  var canvas = document.getElementById('radarChart');
  if (!canvas) return;
  
  var labels = ['ROE', '毛利率', '净利率', 'EPS', '负债占资产比率', '总资产周转率'];
  
  var radarDataElement = document.getElementById('radar-data');
  var currentStockData = radarDataElement ? parseRadarData(radarDataElement.dataset.current) : null;
  var currentData = getChartData(currentStockData);
  
  window.currentStockData = currentStockData;
  
  window.radarChartInstance = new Chart(canvas, {
    type: 'radar',
    data: {
      labels: labels,
      datasets: [
        {
          label: currentStockData ? (currentStockData.display_name || currentStockData.name) : '当前股票',
          data: currentData,
          backgroundColor: 'rgba(239, 68, 68, 0.2)',
          borderColor: 'rgb(239, 68, 68)',
          borderWidth: 2,
          pointRadius: 3
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      scales: {
        r: {
          min: 0,
          max: 100,
          ticks: { stepSize: 20 },
          pointLabels: { font: { size: 11 } }
        }
      },
      plugins: { 
        legend: { 
          display: true,
          position: 'bottom',
          labels: {
            usePointStyle: true,
            padding: 20,
            font: { size: 12 }
          }
        } 
      }
    }
  });
}

document.addEventListener('turbo:load', function() {
  function tryInitChart() {
    if (typeof Chart !== 'undefined') {
      initChart();
    } else {
      setTimeout(tryInitChart, 50);
    }
  }
  tryInitChart();
  
  var followBtn = document.getElementById('follow-btn');
  if (followBtn) {
    followBtn.addEventListener('click', function() {
      if (followBtn.textContent.trim() === '关注股票') {
        followBtn.textContent = '已关注';
        followBtn.classList.remove('bg-blue-600', 'hover:bg-blue-700');
        followBtn.classList.add('bg-gray-200', 'text-gray-700');
      } else {
        followBtn.textContent = '关注股票';
        followBtn.classList.remove('bg-gray-200', 'text-gray-700');
        followBtn.classList.add('bg-blue-600', 'hover:bg-blue-700');
      }
    });
  }
  
  var originalRadarData = null;
  var radarDataElement = document.getElementById('radar-data');
  if (radarDataElement && radarDataElement.dataset.current) {
    originalRadarData = parseRadarData(radarDataElement.dataset.current);
  }
  
  var comparisonItems = document.querySelectorAll('.comparison-item');
  comparisonItems.forEach(function(item) {
    item.addEventListener('mouseenter', function(e) {
      var comparisonData = parseRadarData(this.dataset.radar);
      if (comparisonData) {
        updateRadarChart(comparisonData);
      }
    });
    
    item.addEventListener('mouseleave', function(e) {
      clearComparisonChart();
    });
  });
});

function updateRadarChart(comparisonData) {
  var chart = window.radarChartInstance;
  if (!chart) return;
  
  var currentStockData = window.currentStockData;
  var currentData = getChartData(currentStockData);
  var comparisonDataValues = getChartData(comparisonData);
  
  if (comparisonData && chart.data.datasets.length === 1) {
    chart.data.datasets.push({
      label: comparisonData.display_name || comparisonData.name || '对比股票',
      data: comparisonDataValues,
      backgroundColor: 'rgba(59, 130, 246, 0.2)',
      borderColor: 'rgb(59, 130, 246)',
      borderWidth: 2,
      pointRadius: 3
    });
  } else if (comparisonData && chart.data.datasets.length === 2) {
    chart.data.datasets[1].label = comparisonData.name || '对比股票';
    chart.data.datasets[1].data = comparisonDataValues;
  }
  
  chart.update();
}

function clearComparisonChart() {
  var chart = window.radarChartInstance;
  if (!chart) return;
  
  if (chart.data.datasets.length === 2) {
    chart.data.datasets.pop();
    chart.update();
  }
}


</script>