      <div id="error-container" class="hidden"></div>
      
      <div id="chart-container" class="mb-6 overflow-hidden" style="overflow: hidden;">
        <div style="height: 256px; overflow: hidden;">
          <canvas id="indicator-chart"></canvas>
        </div>
      </div>
      
      <div id="content-container" class="overflow-hidden" style="overflow: hidden;">
        <div class="mb-6">
          <h4 class="font-semibold text-gray-700 text-sm mb-3 truncate">指标定义</h4>
          <p id="indicator-description" class="text-gray-600 text-xs leading-relaxed break-words" style="word-break: break-word; hyphens: auto;"></p>
        </div>
        
        <div class="h-px bg-gray-100 mb-6"></div>
        
        <div class="mb-6">
          <h4 class="font-semibold text-gray-700 text-sm mb-3 truncate">计算公式</h4>
          <div id="indicator-formula" class="text-gray-600 text-xs font-mono p-3 rounded overflow-x-auto" style="word-break: break-all; overflow-x: auto; overflow-y: hidden;"></div>
        </div>
        
        <div class="h-px bg-gray-100 mb-6"></div>
        
        <div>
          <h4 class="font-semibold text-gray-700 text-sm mb-3 truncate">解读标准</h4>
          <div id="indicator-interpretation" class="space-y-3 overflow-hidden" style="overflow: hidden;"></div>
        </div>
      </div>
    </div>
  </div>
</div>