<nav class="hl-nav sticky top-0 z-50 bg-white border-b border-line" data-controller="mobile-menu">
  <div class="container-hl h-15 flex items-center gap-6">

    <%# ----- Logo ----- %>
    <%= link_to root_path, class: "hl-nav-logo flex items-center gap-2 shrink-0" do %>
      <span class="text-hl-15 font-bold text-ink tracking-wide">HOLD LE</span>
    <% end %>

    <%# ----- 搜索框 ----- %>
    <div class="hl-nav-search relative flex-1 max-w-[280px]" id="search-container">
      <span class="hl-nav-search-icon">⌕</span>
      <input
        type="text"
        id="stock-search-input"
        placeholder="搜索股票代码或名称..."
        autocomplete="off"
        class="hl-nav-search-input flex-1 bg-transparent border-none outline-none text-hl-13 text-muted placeholder:text-muted-4"
      >
      <div id="search-suggestions" class="absolute top-full left-0 right-0 mt-2 bg-white rounded-xl shadow-lg border border-line overflow-hidden hidden z-50">
        <div id="suggestions-list"></div>
        <div id="no-results" class="px-4 py-6 text-center text-muted-4 hidden">
          <p class="text-hl-13">未找到匹配的股票</p>
        </div>
      </div>
    </div>

    <%# ----- 导航链接 ----- %>
    <div class="hl-nav-links hidden md:flex">
      <%= link_to pyramid_path, class: "hl-nav-link #{'hl-nav-link-active' if controller_name == 'pyramids'}" do %>
        金字塔
        <%= tag.span class: "hl-nav-link-active-dot", aria: { hidden: "true" } if controller_name == 'pyramids' %>
      <% end %>
      <%= link_to courses_path, class: "hl-nav-link #{'hl-nav-link-active' if controller_name == 'courses'}" do %>
        交易课
        <%= tag.span class: "hl-nav-link-active-dot", aria: { hidden: "true" } if controller_name == 'courses' %>
      <% end %>
      <%= link_to join_path, class: "hl-nav-link #{'hl-nav-link-active' if controller_name == 'pages'}" do %>
        加入我们
        <%= tag.span class: "hl-nav-link-active-dot", aria: { hidden: "true" } if controller_name == 'pages' %>
      <% end %>
      <%= link_to "#", class: "hl-nav-link" do %>
        关于
      <% end %>
      <%= link_to video_path, class: "hl-nav-link hl-nav-link-new flex items-center #{'hl-nav-link-active' if controller_name == 'pages' && action_name == 'video'}" do %>
        <span>视频</span>
        <%= tag.span class: "hl-nav-link-active-dot", aria: { hidden: "true" } if controller_name == 'pages' && action_name == 'video' %>
      <% end %>
    </div>

    <%# ----- 用户区域 / 登录入口（右侧） ----- %>
    <div class="ml-auto flex items-center gap-3">
      <% if user_signed_in? %>
        <div data-controller="user-dropdown" class="relative hidden md:block">
          <button data-action="click->user-dropdown#toggle"
                  class="hl-nav-admin flex items-center gap-2 cursor-pointer select-none"
                  aria-haspopup="true"
                  aria-expanded="false">
            <%= user_avatar_tag(current_user, size: "w-6 h-6") %>
            <span class="text-hl-13 text-muted"><%= current_user.nickname || current_user.email %></span>
            <svg class="w-3 h-3 text-muted-4 transition-transform duration-150" data-user-dropdown-target="arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <div data-user-dropdown-target="menu"
               class="hidden absolute right-0 top-full mt-2 w-56 bg-white border border-line rounded
                      opacity-0 translate-y-[-4px] transition-all duration-150 ease-out z-50
                      hl-dropdown-open:opacity-100 hl-dropdown-open:translate-y-0
                      hl-dropdown-closing:opacity-0 hl-dropdown-closing:translate-y-[-4px]">
            <div class="px-4 py-3 border-b border-line-soft">
              <div class="flex items-center gap-3">
                <%= user_avatar_tag(current_user, size: "w-9 h-9") %>
                <div class="min-w-0 flex-1">
                  <p class="text-hl-13 font-medium text-ink truncate"><%= current_user.nickname || current_user.email %></p>
                  <% role_name = human_role(current_user.role) %>
                  <% role_color = case current_user.role
                       when 'super_admin' then 'text-amber-600'
                       when 'admin' then 'text-link'
                       when 'member' then 'text-profit'
                       else 'text-muted-3'
                     end %>
                  <p class="text-hl-12 <%= role_color %> truncate"><%= role_name %></p>
                </div>
              </div>
            </div>
            <div class="py-1">
              <%= link_to users_profile_path, class: "flex items-center gap-3 px-4 py-2 text-hl-13 text-muted hover:text-ink hover:bg-bg-mute transition-colors" do %>
                  <svg class="w-4 h-4 text-muted-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                  个人中心
                <% end %>
                <%= link_to "#", class: "flex items-center gap-3 px-4 py-2 text-hl-13 text-muted hover:text-ink hover:bg-bg-mute transition-colors",
                            data: { action: "click->message#open:prevent" } do %>
                  <svg class="w-4 h-4 text-muted-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                  我的留言
                <% end %>
              <% if current_user.admin? %>
                <%= link_to admin_root_path, class: "flex items-center gap-3 px-4 py-2 text-hl-13 text-muted hover:text-ink hover:bg-bg-mute transition-colors" do %>
                  <svg class="w-4 h-4 text-muted-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                  后台管理
                <% end %>
              <% end %>
            </div>
            <div class="border-t border-line-soft py-1">
              <%= button_to destroy_user_session_path, method: :delete,
                    class: "flex items-center gap-3 w-full px-4 py-2 text-hl-13 text-muted hover:text-profit hover:bg-bg-mute transition-colors text-left",
                    data: { turbo: false } do %>
                <svg class="w-4 h-4 text-muted-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                退出登录
              <% end %>
            </div>
          </div>
        </div>
      <% else %>
        <%= link_to '登录', new_user_session_path, class: "hl-nav-link text-hl-13 hidden md:inline-flex" %>
        <%= link_to '注册', new_user_registration_path, class: "hl-btn hl-btn-primary text-hl-13 !py-[6px] !px-[14px] hidden md:inline-flex" %>
      <% end %>

      <%# ----- 移动端菜单按钮 ----- %>
      <button id="mobile-menu-btn" data-action="click->mobile-menu#toggle"
              class="md:hidden p-2 hover:bg-bg-mute rounded" aria-label="切换菜单">
        <svg data-mobile-menu-target="buttonIcon" class="w-[18px] h-[18px] text-muted transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <%# ----- 移动端菜单 ----- %>
  <div id="mobile-menu" data-mobile-menu-target="menu"
       class="md:hidden hidden bg-white border-t border-line overflow-hidden transition-[max-height] duration-200 ease-out">
    <div class="px-4 py-4 space-y-3">
      <div class="space-y-1">
        <%= link_to "金字塔", pyramid_path, class: "block px-4 py-2 text-hl-14 rounded #{controller_name == 'pyramids' ? 'bg-bg-mute text-ink font-medium border-l-2 border-profit' : 'text-muted hover:text-ink hover:bg-bg-mute'}" %>
        <%= link_to "交易课", courses_path, class: "block px-4 py-2 text-hl-14 rounded #{controller_name == 'courses' ? 'bg-bg-mute text-ink font-medium border-l-2 border-profit' : 'text-muted hover:text-ink hover:bg-bg-mute'}" %>
        <%= link_to "加入我们", join_path, class: "block px-4 py-2 text-hl-14 rounded #{controller_name == 'pages' ? 'bg-bg-mute text-ink font-medium border-l-2 border-profit' : 'text-muted hover:text-ink hover:bg-bg-mute'}" %>
        <%= link_to "关于", "#", class: "block px-4 py-2 text-hl-14 text-muted hover:text-ink hover:bg-bg-mute rounded" %>
        <%= link_to "视频", video_path, class: "block px-4 py-2 text-hl-14 rounded #{controller_name == 'pages' && action_name == 'video' ? 'bg-bg-mute text-ink font-medium border-l-2 border-profit' : 'text-muted hover:text-ink hover:bg-bg-mute'} flex items-center" do %>
          视频分享
          <span class="ml-2 w-2 h-2 bg-profit rounded-full"></span>
        <% end %>
      </div>
      <div class="pt-4 border-t border-line-soft">
        <% if user_signed_in? %>
          <div class="flex items-center gap-3 pb-3">
            <%= user_avatar_tag(current_user, size: "w-10 h-10") %>
            <div>
              <p class="font-medium text-ink"><%= current_user.nickname || current_user.email %></p>
              <% mob_role_name = human_role(current_user.role) %>
              <% mob_role_color = case current_user.role
                   when 'super_admin' then 'text-amber-600'
                   when 'admin' then 'text-link'
                   when 'member' then 'text-profit'
                   else 'text-muted-3'
                 end %>
              <p class="text-hl-13 <%= mob_role_color %>"><%= mob_role_name %></p>
            </div>
          </div>
          <div class="space-y-1">
            <%= link_to '个人中心', users_profile_path, class: "block px-4 py-2 text-hl-13 text-muted hover:text-ink hover:bg-bg-mute rounded" %>
            <%= link_to "#", class: "block px-4 py-2 text-hl-13 text-muted hover:text-ink hover:bg-bg-mute rounded",
                        data: { action: "click->message#open:prevent" } do %>
              我的留言
            <% end %>
            <% if current_user.admin? %>
              <%= link_to '后台管理', admin_root_path, class: "block px-4 py-2 text-hl-13 text-muted hover:text-ink hover:bg-bg-mute rounded" %>
            <% end %>
            <%= button_to '退出登录', destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-hl-13 text-muted hover:text-ink hover:bg-bg-mute rounded", form_class: "block" %>
          </div>
        <% else %>
          <div class="flex gap-3">
            <%= link_to '登录', new_user_session_path, class: "flex-1 px-4 py-2 text-center text-hl-13 text-muted border border-line rounded hover:bg-bg-mute" %>
            <%= link_to '注册', new_user_registration_path, class: "flex-1 px-4 py-2 text-center text-hl-13 bg-ink text-white rounded hover:opacity-90" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</nav>