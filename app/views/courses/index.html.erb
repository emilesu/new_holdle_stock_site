<% set_page_title "投资交易课程 - Holdle" %>
<% set_page_description "学习使用 Holdle 的工具和方法，掌握金字塔评分系统、财务分析技巧，构建你的交易规则系统。" %>
<% set_page_keywords "投资课程,交易系统,股票分析,金字塔评分,财务分析" %>
<div class="py-16">
  <div class="container-narrow">
    <div class="label-en">COURSES - V2.0</div>
    <h1 class="text-hl-22 font-semibold text-ink mb-2">HOLDLE - 投资交易课</h1>
    <p class="text-hl-13 text-muted-3 mb-7">学习如何使用 HOLDLE 的工具和方法，构建你的交易规则系统</p>

    <div class="grid grid-cols-1 gap-4">
      <% @courses.each do |course| %>
        <%= link_to course_path(course), class: 'hl-card hl-card-hover block transition-colors' do %>
          <div class="p-6 sm:p-7">
            <div class="flex flex-col sm:flex-row gap-5">
              <% if course.cover_url %>
                <div class="shrink-0">
                  <%= image_tag course.cover_url,
                        alt: "#{course.title} 封面",
                        class: 'w-full sm:w-44 h-28 object-cover rounded border border-line',
                        loading: 'lazy' %>
                </div>
              <% end %>
              <div class="flex-1 min-w-0">
                <h2 class="text-hl-16 font-semibold text-ink"><%= course.title %></h2>
                <% if course.description.present? %>
                  <p class="mt-1.5 text-hl-13 text-muted line-clamp-2"><%= course.description %></p>
                <% end %>
                <div class="mt-3 flex items-center gap-4 text-hl-12 text-muted-4">
                  <span><%= course.chapters.size %> 个章节</span>
                  <span><%= course.lessons.size %> 个小节</span>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
      <% if @courses.empty? %>
        <div class="hl-card py-16 text-center">
          <p class="text-hl-14 text-muted-4">暂无课程</p>
        </div>
      <% end %>
    </div>
  </div>
</div>