<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <h1 class="text-lg font-semibold text-gray-800">交易课</h1>
      <p class="mt-1 text-sm text-gray-500">精选投资课程，系统学习股票分析</p>
    </div>
    <div class="divide-y divide-gray-100">
      <% @courses.each do |course| %>
        <%= link_to course_path(course), class: 'block px-6 py-4 hover:bg-blue-50 transition-colors' do %>
          <div class="flex items-start space-x-4">
            <% if course.cover_url %>
              <%= image_tag course.cover_url,
                    alt: "#{course.title} 封面",
                    class: 'w-24 h-16 object-cover rounded border border-gray-100 flex-shrink-0',
                    loading: 'lazy' %>
            <% end %>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between">
                <h2 class="text-sm font-semibold text-gray-900"><%= course.title %></h2>
                <div class="ml-4 flex-shrink-0">
                  <% if course.member_only? %>
                    <span class="inline-flex px-2 py-1 text-xs font-medium bg-blue-50 text-blue-600 border border-blue-200 rounded">会员</span>
                  <% else %>
                    <span class="inline-flex px-2 py-1 text-xs font-medium bg-gray-50 text-gray-500 border border-gray-200 rounded">公开</span>
                  <% end %>
                </div>
              </div>
              <% if course.description.present? %>
                <p class="mt-1 text-xs text-gray-500 line-clamp-2"><%= course.description %></p>
              <% end %>
              <div class="mt-2 flex items-center space-x-4 text-xs text-gray-400">
                <span><%= course.chapters.size %> 个章节</span>
                <span><%= course.lessons.size %> 个小节</span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
      <% if @courses.empty? %>
        <div class="py-16 text-center">
          <p class="text-gray-400">暂无课程</p>
        </div>
      <% end %>
    </div>
  </div>
</div>