<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white rounded-lg overflow-hidden border border-gray-200">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-lg font-semibold text-gray-800"><%= @course.title %></h1>
          <% if @course.description.present? %>
            <p class="mt-1 text-sm text-gray-500"><%= @course.description %></p>
          <% end %>
        </div>
        <div class="ml-4 flex-shrink-0">
          <% if @course.member_only? %>
            <span class="inline-flex px-2 py-1 text-xs font-medium bg-blue-50 text-blue-600 border border-blue-200 rounded">会员课程</span>
          <% else %>
            <span class="inline-flex px-2 py-1 text-xs font-medium bg-gray-50 text-gray-500 border border-gray-200 rounded">公开课程</span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="p-6 space-y-8">
      <% @chapters.each_with_index do |chapter, index| %>
        <div>
          <div class="flex items-center space-x-3 mb-4">
            <span class="flex items-center justify-center w-6 h-6 bg-gray-100 text-xs font-bold text-gray-500"><%= index + 1 %></span>
            <h2 class="text-sm font-semibold text-gray-900"><%= chapter.title %></h2>
            <% if chapter.summary.present? %>
              <span class="text-xs text-gray-400">· <%= chapter.summary %></span>
            <% end %>
          </div>
          <div class="space-y-1">
            <% chapter.lessons.published.sorted.each do |lesson| %>
              <%= link_to lesson_path(lesson), class: 'flex items-center space-x-3 px-4 py-2.5 border-b border-gray-50 last:border-b-0 hover:bg-blue-50 transition-colors rounded' do %>
                <span class="w-4 text-xs text-gray-400 font-mono text-right flex-shrink-0"><%= lesson.sort_num %></span>
                <span class="text-sm text-gray-700 hover:text-blue-600"><%= lesson.title %></span>
              <% end %>
            <% end %>
            <% if chapter.lessons.published.empty? %>
              <p class="px-4 py-2 text-sm text-gray-400">暂无小节</p>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @chapters.empty? %>
        <div class="py-16 text-center">
          <p class="text-gray-400">暂无章节内容</p>
        </div>
      <% end %>
    </div>
  </div>
</div>