<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- 课程标题区 -->
  <div class="border-b border-gray-200 pb-6 mb-8">
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900"><%= @course.title %></h1>
        <% if @course.description.present? %>
          <p class="mt-2 text-gray-500"><%= @course.description %></p>
        <% end %>
      </div>
      <div class="ml-4 flex-shrink-0">
        <% if @course.member_only? %>
          <span class="inline-flex px-3 py-1 text-sm font-medium bg-blue-50 text-blue-600 border border-blue-200 rounded">会员课程</span>
        <% else %>
          <span class="inline-flex px-3 py-1 text-sm font-medium bg-gray-50 text-gray-500 border border-gray-200 rounded">公开课程</span>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 章节列表 -->
  <div class="space-y-6">
    <% @chapters.each_with_index do |chapter, index| %>
      <div>
        <div class="flex items-center space-x-3 mb-3">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-gray-100 text-xs font-bold text-gray-500"><%= index + 1 %></span>
          <h2 class="text-lg font-semibold text-gray-900"><%= chapter.title %></h2>
          <% if chapter.summary.present? %>
            <span class="text-sm text-gray-400">· <%= chapter.summary %></span>
          <% end %>
        </div>
        <div class="ml-10 space-y-0 border-l-2 border-gray-100 pl-4">
          <% chapter.lessons.published.sorted.each do |lesson| %>
            <%= link_to lesson_path(lesson), class: 'block py-2.5 border-b border-gray-50 last:border-b-0 hover:text-blue-600 transition-colors' do %>
              <div class="flex items-center space-x-2 text-sm">
                <span class="w-1.5 h-1.5 rounded-full bg-gray-300 flex-shrink-0"></span>
                <span class="text-gray-700 hover:text-blue-600"><%= lesson.title %></span>
              </div>
            <% end %>
          <% end %>
          <% if chapter.lessons.published.empty? %>
            <p class="py-2 text-sm text-gray-400">暂无小节</p>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @chapters.empty? %>
      <div class="py-16 text-center">
        <p class="text-gray-400">暂无章节内容</p>
      </div>
    <% end %>
  </div>
</div>