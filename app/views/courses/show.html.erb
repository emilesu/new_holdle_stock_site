<div class="py-16">
  <div class="container-narrow">
    <%# 面包屑导航 %>
    <div class="text-hl-12 text-muted-4 mb-6">
      <%= link_to '交易课', courses_path, class: 'hover:text-link transition-colors' %>
      <span class="mx-1.5 text-muted-5">/</span>
      <span class="text-ink font-medium"><%= @course.title %></span>
    </div>

    <%# 课程头部 %>
    <div class="hl-card p-6 sm:p-8 mb-6">
      <div class="flex flex-col sm:flex-row gap-6">
        <% if @course.cover_url %>
          <div class="shrink-0">
            <%= image_tag @course.cover_url,
                  alt: "#{@course.title} 封面",
                  class: 'w-full sm:w-56 h-32 sm:h-40 object-cover rounded border border-line',
                  loading: 'lazy' %>
          </div>
        <% end %>
        <div class="flex-1 min-w-0">
          <h1 class="text-hl-22 font-semibold text-ink mb-2"><%= @course.title %></h1>
          <% if @course.description.present? %>
            <p class="text-hl-14 text-muted leading-relaxed"><%= @course.description %></p>
          <% end %>
          <div class="mt-4 flex flex-wrap items-center gap-4 text-hl-12 text-muted-4">
            <span><%= @course.chapters.size %> 个章节</span>
            <span><%= @course.lessons.size %> 个小节</span>
          </div>
        </div>
      </div>
    </div>

    <%# 章节列表 %>
    <div class="space-y-6">
      <% @chapters.each_with_index do |chapter, index| %>
        <div class="hl-card">
          <%# 章节头部 %>
          <div class="flex items-center gap-3 px-6 sm:px-8 py-4 border-b border-line-soft">
            <span class="flex items-center justify-center w-7 h-7 bg-bg-mute text-hl-12 font-bold text-muted-2 rounded"><%= index + 1 %></span>
            <h2 class="text-hl-15 font-semibold text-ink"><%= chapter.title %></h2>
            <% if chapter.summary.present? %>
              <span class="text-hl-12 text-muted-4 hidden sm:inline">· <%= chapter.summary %></span>
            <% end %>
          </div>

          <%# 小节列表 %>
          <div class="divide-y divide-line-soft">
            <% chapter.lessons.published.sorted.each do |lesson| %>
              <%= link_to lesson_path(lesson), class: 'flex items-center gap-3 px-6 sm:px-8 py-3 hover:bg-bg-soft transition-colors' do %>
                <span class="w-5 text-hl-12 text-muted-4 font-mono text-right shrink-0"><%= lesson.sort_num %></span>
                <span class="flex-1 text-hl-13 text-muted hover:text-ink transition-colors min-w-0"><%= lesson.title %></span>
                <% if lesson.member_only? %>
                  <span class="shrink-0 inline-flex px-2 py-0.5 text-hl-11 font-medium bg-bg-mute text-muted-3 border border-line-soft rounded">会员</span>
                <% else %>
                  <span class="shrink-0 inline-flex px-2 py-0.5 text-hl-11 font-medium bg-bg-soft text-muted-4 border border-line-soft rounded">公开</span>
                <% end %>
              <% end %>
            <% end %>
            <% if chapter.lessons.published.empty? %>
              <div class="px-6 sm:px-8 py-5 text-center">
                <p class="text-hl-13 text-muted-4">暂无小节</p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @chapters.empty? %>
        <div class="hl-card py-16 text-center">
          <p class="text-hl-14 text-muted-4">暂无章节内容</p>
        </div>
      <% end %>
    </div>
  </div>
</div>