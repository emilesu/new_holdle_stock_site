  </div>
</section>

<%# ========== 5. 历史战绩 ========== %>
<section class="py-16">
  <div class="container-hl">
    <div class="label-en">CASE CLOSED · 已结案案例</div>
    <h2 class="text-hl-22 font-semibold text-ink mb-2">历史战绩</h2>
    <p class="text-hl-13 text-muted-3 mb-7">按 HOLD LE 策略完整执行，每笔都有明确的入场规则和出场规则</p>

    <div class="hl-card overflow-hidden">
      <div class="px-6 py-4 border-b border-line-soft flex justify-between items-center text-hl-12 text-muted-3">
        <span>已结案案例 · 8 笔</span>
        <span class="bg-bg-mute text-muted-2 px-2 py-0.5 rounded text-hl-11">已结案</span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse hl-table">
          <thead>
            <tr>
              <th class="w-1/3">股票</th>
              <th class="w-1/4">区间</th>
              <th class="w-1/6">收益</th>
              <th>一句话备注</th>
            </tr>
          </thead>
          <tbody>
            <%# 数据硬编码，不依赖 controller 变量 %>
            <% cases = [
              { name: "贵州茅台", code: "600519.SH", range: "2016.05 → 2018.08", ret: "+168.2%", note: '一笔最经典的"等状态A再买"' },
              { name: "海康威视", code: "002415.SZ", range: "2017.03 → 2018.02", ret: "+88.8%",  note: "得概率优势，守株待兔" },
              { name: "伟星新材", code: "002372.SZ", range: "2016.07 → 2018.09", ret: "+69.5%",  note: "建材行业隐藏的优等生" },
              { name: "爱尔眼科", code: "300015.SZ", range: "2017.11 → 已结案",   ret: "+52.3%",  note: '医疗器械的"长潜"样本' },
              { name: "海天味业", code: "603288.SH", range: "2017.05 → 已结案",   ret: "+44.6%",  note: "食品消费类龙头" },
              { name: "上海机场", code: "600009.SH", range: "2017.05 → 已结案",   ret: "+38.1%",  note: "现金流稳定的公用事业股" },
              { name: "Apple 苹果", code: "AAPL",    range: "2017.03 → 2018.12", ret: "+15.0%",  note: "稳住不输 + 止损位控制" },
              { name: "Apple 苹果", code: "AAPL",    range: "2014.05 → 2015.08", ret: "+23.4%",  note: "美股样本，按规则完整执行" }
            ] %>
            <% cases.each do |c| %>
              <tr>
                <td>
                  <span class="font-semibold text-ink"><%= c[:name] %></span>
                  <span class="text-muted-4 text-hl-12 ml-1.5"><%= c[:code] %></span>
                </td>
                <td><%= c[:range] %></td>
                <td><span class="profit-up profit-up-before"><%= c[:ret] %></span></td>
                <td><%= c[:note] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="px-6 py-4 bg-bg-soft border-t border-line-soft text-hl-12 text-muted-3 leading-relaxed">
        ※ 过去的战绩不代表未来，但方法论的有效性是长期可复现的。<br>
        ※ 我希望这套方法能成为你长期使用的工具，而不是短期暴富的承诺。
      </div>
    </div>
  </div>
</section>

