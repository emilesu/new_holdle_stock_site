<%- if controller_name != 'sessions' %>
  <%- unless local_assigns[:hide_login] %>
    <p class="text-hl-13 text-muted-3">
      <%= link_to "已有账号？立即登录", new_session_path(resource_name), class: "text-link hover:text-link-hover font-medium transition-colors" %>
    </p>
  <% end %>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p class="text-hl-13 text-muted-3">
    <%= link_to "还没有账号？立即注册", new_registration_path(resource_name), class: "text-link hover:text-link-hover font-medium transition-colors" %>
  </p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p class="text-hl-13 text-muted-3">
    <%= link_to "忘记密码？", new_password_path(resource_name), class: "text-link hover:text-link-hover font-medium transition-colors" %>
  </p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p class="text-hl-13 text-muted-3">
    <%= link_to "没有收到确认邮件？", new_confirmation_path(resource_name), class: "text-link hover:text-link-hover font-medium transition-colors" %>
  </p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p class="text-hl-13 text-muted-3">
    <%= link_to "没有收到解锁邮件？", new_unlock_path(resource_name), class: "text-link hover:text-link-hover font-medium transition-colors" %>
  </p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <%= button_to "使用 #{OmniAuth::Utils.camelize(provider)} 登录",
      omniauth_authorize_path(resource_name, provider),
      data: { turbo: false },
      class: "hl-btn hl-btn-line w-full text-center mt-2" %>
  <% end %>
<% end %>