<% if resource.errors.any? %>
  <div id="error_explanation" data-turbo-temporary
       class="mb-5 p-4 border border-line-soft rounded bg-bg-soft">
    <p class="text-hl-13 font-medium text-profit mb-2">
      <%= I18n.t("errors.messages.not_saved",
                 count: resource.errors.count,
                 resource: resource.class.model_name.human.downcase) %>
    </p>
    <ul class="list-disc pl-5 text-hl-12 text-profit space-y-1">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>