<div class="py-16 bg-bg-soft min-h-screen">
  <div class="container-narrow">
    <div class="hl-card p-8 sm:p-10">

      <div class="text-center mb-7">
        <span class="text-hl-11 text-muted-5 tracking-wide-2 font-medium block mb-3">HOLD LE</span>
        <h1 class="text-hl-22 font-semibold text-ink">重新发送确认邮件</h1>
        <p class="mt-2 text-hl-13 text-muted-3">输入您的邮箱地址，我们将重新发送确认邮件</p>
      </div>

      <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "block text-hl-13 font-medium text-muted mb-1.5" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "your@email.com",
              value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
              class: "w-full px-4 py-2.5 border border-line rounded text-hl-14 text-ink placeholder:text-muted-4 bg-white focus:outline-none focus:border-muted-3 transition-colors" %>
          </div>

          <div class="pt-2">
            <%= f.submit "重新发送确认邮件", class: "hl-btn hl-btn-primary w-full text-center" %>
          </div>
        </div>
      <% end %>

      <div class="mt-7 pt-5 border-t border-line-soft text-center">
        <p class="text-hl-13 text-muted-3">
          <%= link_to "返回登录", new_session_path(resource_name), class: "text-link hover:text-link-hover font-medium transition-colors" %>
        </p>
      </div>

    </div>
  </div>
</div>