<div class="py-16 bg-bg-soft min-h-screen">
  <div class="container-narrow">
    <div class="hl-card p-8 sm:p-10">

      <div class="text-center mb-7">
        <span class="text-hl-11 text-muted-5 tracking-wide-2 font-medium block mb-3">HOLD LE</span>
        <h1 class="text-hl-22 font-semibold text-ink">设置新密码</h1>
        <p class="mt-2 text-hl-13 text-muted-3">请输入您的新密码</p>
      </div>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div class="space-y-4">
          <div>
            <%= f.label :password, class: "block text-hl-13 font-medium text-muted mb-1.5" do %>
              新密码
              <% if @minimum_password_length %>
                <span class="text-muted-4 font-normal">(至少 <%= @minimum_password_length %> 位)</span>
              <% end %>
            <% end %>
            <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: "输入新密码",
              class: "w-full px-4 py-2.5 border border-line rounded text-hl-14 text-ink placeholder:text-muted-4 bg-white focus:outline-none focus:border-muted-3 transition-colors" %>
          </div>

          <div>
            <%= f.label :password_confirmation, class: "block text-hl-13 font-medium text-muted mb-1.5" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "再次输入新密码",
              class: "w-full px-4 py-2.5 border border-line rounded text-hl-14 text-ink placeholder:text-muted-4 bg-white focus:outline-none focus:border-muted-3 transition-colors" %>
          </div>

          <div class="pt-2">
            <%= f.submit "设置新密码", class: "hl-btn hl-btn-primary w-full text-center" %>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>