<div class="py-16 bg-bg-soft min-h-screen">
  <div class="container-narrow">
    <div class="hl-card p-8 sm:p-10">

      <div class="text-center mb-7">
        <span class="text-hl-11 text-muted-5 tracking-wide-2 font-medium block mb-3">HOLD LE</span>
        <h1 class="text-hl-22 font-semibold text-ink">创建账号</h1>
        <p class="mt-2 text-hl-13 text-muted-3">开启您的股票分析之旅</p>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <% if resource.errors.any? %>
          <div class="mb-5 p-4 border border-line-soft rounded bg-bg-soft">
            <p class="text-hl-13 font-medium text-profit mb-2"><%= pluralize(resource.errors.count, "个") %> 错误：</p>
            <ul class="list-disc pl-5 text-hl-12 text-profit space-y-1">
              <% resource.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "block text-hl-13 font-medium text-muted mb-1.5" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "your@email.com",
              class: "w-full px-4 py-2.5 border border-line rounded text-hl-14 text-ink placeholder:text-muted-4 bg-white focus:outline-none focus:border-muted-3 transition-colors" %>
          </div>

          <div>
            <%= f.label :nickname, class: "block text-hl-13 font-medium text-muted mb-1.5" %>
            <%= f.text_field :nickname, autocomplete: "nickname", placeholder: "设置一个昵称",
              class: "w-full px-4 py-2.5 border border-line rounded text-hl-14 text-ink placeholder:text-muted-4 bg-white focus:outline-none focus:border-muted-3 transition-colors" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-hl-13 font-medium text-muted mb-1.5" do %>
              密码
              <% if @minimum_password_length %>
                <span class="text-muted-4 font-normal">(至少 <%= @minimum_password_length %> 位)</span>
              <% end %>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", placeholder: "设置密码",
              class: "w-full px-4 py-2.5 border border-line rounded text-hl-14 text-ink placeholder:text-muted-4 bg-white focus:outline-none focus:border-muted-3 transition-colors" %>
          </div>

          <div>
            <%= f.label :password_confirmation, class: "block text-hl-13 font-medium text-muted mb-1.5" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "再次输入密码",
              class: "w-full px-4 py-2.5 border border-line rounded text-hl-14 text-ink placeholder:text-muted-4 bg-white focus:outline-none focus:border-muted-3 transition-colors" %>
          </div>

          <div class="pt-2">
            <%= f.submit "注册", class: "hl-btn hl-btn-primary w-full text-center" %>
          </div>
        </div>
      <% end %>

      <div class="mt-7 pt-5 border-t border-line-soft text-center">
        <p class="text-hl-13 text-muted-3">
          已有账号？
          <%= link_to "立即登录", new_session_path(resource_name), class: "text-link hover:text-link-hover font-medium transition-colors" %>
        </p>
      </div>

    </div>
  </div>
</div>