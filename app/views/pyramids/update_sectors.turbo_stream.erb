<%= turbo_stream.replace 'pyramid-sector' do %>
<select name="sector" id="pyramid-sector" class="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent w-40 bg-white">
  <option value="">全部</option>
  <% @sectors.each do |sector| %>
    <option value="<%= sector %>"><%= sector %></option>
  <% end %>
</select>
<% end %>