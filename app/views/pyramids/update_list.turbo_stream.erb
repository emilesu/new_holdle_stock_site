<%= turbo_stream.replace 'pyramid-list-container' do %>
  <div id="pyramid-list-container">
    <div id="pyramid-stock-list" class="divide-y divide-line-soft">
      <% @stocks.each_slice(2) do |pair| %>
        <div class="grid grid-cols-1 md:grid-cols-2">
          <% pair.each do |stock| %>
            <% rank = @stocks.index(stock) + 1 %>
            <div class="stock-row flex items-center justify-between px-6 py-3 border-r border-line-soft last:border-r-0 cursor-pointer transition-colors duration-150 hover:bg-bg-mute"
                 data-stock-id="<%= stock.id %>"
                 data-stock-symbol="<%= stock.symbol %>"
                 data-stock-url="<%= stock_path(stock) %>"
                 data-stock-name="<%= stock.market == 'US' && stock.name&.include?('|') ? stock.name.split('|').first.strip : stock.name %>">
              <div class="flex items-center space-x-3 min-w-0">
                <span class="text-hl-11 font-mono text-muted-4 w-5 text-right shrink-0"><%= rank %></span>
                <div class="min-w-0">
                  <div class="stock-name text-hl-13 font-medium text-ink truncate hover:text-link">
                    <%= stock.market == 'US' && stock.name&.include?('|') ? stock.name.split('|').first.strip : stock.name %>
                  </div>
                  <div class="text-hl-11 text-muted-3 truncate"><%= stock.symbol %></div>
                </div>
              </div>
              <span class="stock-score font-semibold text-link text-hl-13 shrink-0 ml-2"><%= stock.pyramid_total_score %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div id="pyramid-scroll-sentinel"
         class="flex justify-center py-4 text-hl-13 text-muted-4 opacity-100 transition-opacity duration-300"
         data-next-page="2"
         data-total-pages="<%= @total_pages %>"
         data-market="<%= @market %>"
         data-sector="<%= @sector || '' %>">
      <% if @total_pages > 1 %>
        <span class="flex items-center space-x-2"><span>滚动加载更多...</span></span>
      <% else %>
        <span>— 已全部加载 —</span>
      <% end %>
    </div>
  </div>
<% end %>

<%= turbo_stream.replace 'base-label' do %>
  <span class="text-muted-2 text-hl-11" id="base-label"><%= @compare_data ? @compare_data[:base][:display_name] : '行业第一' %></span>
<% end %>

<% if @compare_data %>
  <%= turbo_stream.replace 'radar-chart' do %>
    <canvas id="radar-chart"></canvas>
  <% end %>

  <%= turbo_stream.append 'pyramid-page' do %>
    <script>
      (function() {
        var data = <%= raw(@compare_data[:base].to_json) %>;
        if (window.initChart && data) {
          window.initChart(data);
        }
      })();
    </script>
  <% end %>
<% end %>
