<%= turbo_stream.replace 'pyramid-list-container' do %>
  <div id="pyramid-list-container">
    <div id="pyramid-stock-list" class="divide-y divide-gray-100">
      <% @stocks.each_slice(2) do |pair| %>
        <div class="grid grid-cols-1 md:grid-cols-2">
          <% pair.each do |stock| %>
            <% rank = @stocks.index(stock) + 1 %>
            <div class="stock-row flex items-center justify-between px-6 py-3 border-r border-gray-100 last:border-r-0"
                 data-stock-id="<%= stock.id %>"
                 data-stock-symbol="<%= stock.symbol %>"
                 data-stock-url="<%= stock_path(stock) %>"
                 data-stock-name="<%= stock.market == 'US' && stock.name&.include?('|') ? stock.name.split('|').first.strip : stock.name %>">
              <div class="flex items-center space-x-3 min-w-0">
                <span class="text-xs font-mono text-gray-400 w-5 text-right shrink-0"><%= rank %></span>
                <div class="min-w-0">
                  <div class="stock-name text-sm font-medium text-gray-900 truncate">
                    <%= stock.market == 'US' && stock.name&.include?('|') ? stock.name.split('|').first.strip : stock.name %>
                  </div>
                  <div class="text-xs text-gray-500 truncate"><%= stock.symbol %></div>
                </div>
              </div>
              <span class="stock-score font-semibold text-indigo-600 text-sm shrink-0 ml-2"><%= stock.pyramid_total_score %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div id="pyramid-scroll-sentinel"
         class="flex justify-center py-4 text-sm text-gray-400 opacity-100 transition-opacity duration-300"
         data-next-page="2"
         data-total-pages="<%= @total_pages %>"
         data-market="<%= @market %>"
         data-sector="<%= @sector || '' %>">
      <% if @total_pages > 1 %>
        <span class="flex items-center space-x-2"><span>滚动加载更多...</span></span>
      <% else %>
        <span>— 已全部加载 —</span>
      <% end %>
    </div>
  </div>
<% end %>

<%= turbo_stream.replace 'base-label' do %>
  <span class="text-gray-600 text-xs" id="base-label"><%= @compare_data ? @compare_data[:base][:display_name] : '行业第一' %></span>
<% end %>
