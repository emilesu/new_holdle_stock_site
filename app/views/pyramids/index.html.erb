<div class="min-h-screen bg-gray-50 pt-10" id="pyramid-page">
  <header class="bg-white border-b border-gray-200 px-4 py-3 sticky top-0 z-10">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <h1 class="text-lg font-semibold text-gray-900">金字塔股票排行</h1>
      <span class="text-sm text-gray-500">已登录用户可完整查看</span>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">雷达对比图</h2>
        <div class="relative" style="height: 320px;">
          <canvas id="radar-chart"></canvas>
        </div>
        <div class="flex justify-center items-center space-x-6 mt-4 text-sm">
          <div class="flex items-center space-x-2">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <span class="text-gray-600" id="base-label"><%= @compare_data ? @compare_data[:base][:display_name] : '行业第一' %></span>
          </div>
          <div class="flex items-center space-x-2" id="compare-legend" style="display: none;">
            <div class="w-3 h-3 rounded-full bg-blue-500"></div>
            <span class="text-gray-600" id="compare-label"></span>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-gray-200">
        <div class="bg-white rounded-lg overflow-hidden border-b border-gray-200 p-4">
          <div class="flex flex-wrap gap-4 items-center">
            <div class="flex items-center gap-2">
              <label class="text-sm font-medium text-gray-600 w-12 shrink-0">市场</label>
              <select name="market" id="pyramid-market" class="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent w-28 bg-white">
                <option value="CN" <%= 'selected' if @market == 'CN' %>>A股</option>
                <option value="US" <%= 'selected' if @market == 'US' %>>美股</option>
              </select>
            </div>

            <div class="flex items-center gap-2">
              <label class="text-sm font-medium text-gray-600 w-12 shrink-0">行业</label>
              <div id="sector-container">
                <select name="sector" id="pyramid-sector" class="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent w-40 bg-white">
                  <option value="">全部</option>
                  <% @sectors.each do |sector| %>
                    <option value="<%= sector %>" <%= 'selected' if @sector == sector %>><%= sector %></option>
                  <% end %>
                </select>
              </div>
            </div>
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">排名</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">股票</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">行业</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">金字塔总分</th>
              </tr>
            </thead>
            <tbody id="pyramid-stock-list" class="bg-white divide-y divide-gray-200">
              <% @stocks.each_with_index do |stock, index| %>
                <tr class="cursor-pointer hover:bg-blue-50 transition-colors stock-row"
                    data-stock-id="<%= stock.id %>"
                    data-stock-symbol="<%= stock.symbol %>"
                    data-stock-name="<%= stock.market == 'US' && stock.name&.include?('|') ? stock.name.split('|').first.strip : stock.name %>">
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-medium">
                    <%= index + 1 %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900">
                      <%= stock.market == 'US' && stock.name&.include?('|') ? stock.name.split('|').first.strip : stock.name %>
                    </div>
                    <div class="text-xs text-gray-500"><%= stock.symbol %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= stock.sector %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm">
                    <span class="font-medium text-indigo-600"><%= stock.pyramid_total_score %></span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div id="pyramid-pagination" class="px-6 py-4 border-t border-gray-200">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">显示 <%= [(@page - 1) * 20 + 1, @total_count].min %> - <%= [@page * 20, @total_count].min %> 条，共 <%= @total_count %> 只股票</span>
            
            <nav class="flex items-center space-x-1">
              <a href="<%= pyramid_path(page: [@page - 1, 1].max, market: @market, sector: @sector) %>" 
                 class="px-3 py-2 text-sm bg-white border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-700 transition-colors"
                 <%= @page <= 1 ? 'disabled class="text-gray-300 cursor-not-allowed"' : '' %>>
                ← 上一页
              </a>
              
              <%= (1..@total_pages).to_a.each do |page_num| %>
                <% if page_num == @page %>
                  <span class="px-3 py-2 text-sm bg-blue-600 text-white rounded-lg font-medium"><%= page_num %></span>
                <% elsif page_num >= @page - 2 && page_num <= @page + 2 %>
                  <a href="<%= pyramid_path(page: page_num, market: @market, sector: @sector) %>" 
                     class="px-3 py-2 text-sm bg-white border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-700 transition-colors">
                    <%= page_num %>
                  </a>
                <% end %>
              <% end %>
              
              <a href="<%= pyramid_path(page: [@page + 1, @total_pages].min, market: @market, sector: @sector) %>" 
                 class="px-3 py-2 text-sm bg-white border border-gray-300 rounded-lg hover:bg-gray-50 text-gray-700 transition-colors"
                 <%= @page >= @total_pages ? 'disabled class="text-gray-300 cursor-not-allowed"' : '' %>>
                下一页 →
              </a>
            </nav>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  let chartInstance = null;
  let currentBaseStockId = '<%= @top_stock&.id || 0 %>';
  let initialBaseData = <%= @compare_data ? raw(@compare_data.to_json) : 'null' %>;

  const initChart = (baseData, compareData = null) => {
    if (chartInstance) {
      chartInstance.destroy();
      chartInstance = null;
    }

    const ctx = document.getElementById('radar-chart');
    if (!ctx) return;

    const labels = ['ROE', '毛利率', '净利率', 'EPS', '负债比率', '资产周转率'];
    const baseValues = baseData ? [
      baseData.values.roe || 0,
      baseData.values.gross_margin || 0,
      baseData.values.net_profit_margin || 0,
      baseData.values.eps || 0,
      baseData.values.asset_liab_ratio || 0,
      baseData.values.asset_turnover_ratio || 0
    ] : [0, 0, 0, 0, 0, 0];

    const datasets = [{
      label: baseData ? (baseData.display_name || baseData.name) : '行业第一',
      data: baseValues,
      backgroundColor: 'rgba(239, 68, 68, 0.2)',
      borderColor: 'rgb(239, 68, 68)',
      borderWidth: 2,
      pointRadius: 3
    }];

    if (compareData) {
      const compareValues = [
        compareData.values.roe || 0,
        compareData.values.gross_margin || 0,
        compareData.values.net_profit_margin || 0,
        compareData.values.eps || 0,
        compareData.values.asset_liab_ratio || 0,
        compareData.values.asset_turnover_ratio || 0
      ];
      datasets.push({
        label: compareData.display_name || compareData.name,
        data: compareValues,
        backgroundColor: 'rgba(59, 130, 246, 0.2)',
        borderColor: 'rgb(59, 130, 246)',
        borderWidth: 2,
        pointRadius: 3
      });
      document.getElementById('compare-legend').style.display = 'flex';
      document.getElementById('compare-label').textContent = compareData.display_name || compareData.name;
    } else {
      document.getElementById('compare-legend').style.display = 'none';
    }

    chartInstance = new Chart(ctx, {
      type: 'radar',
      data: { labels, datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          r: {
            min: 0,
            max: 100,
            ticks: { stepSize: 20 },
            pointLabels: { font: { size: 11 } }
          }
        },
        plugins: {
          legend: { display: false }
        }
      }
    });
  };

  const loadCompareData = async (compareId) => {
    if (!currentBaseStockId) return;

    try {
      let url = `/pyramid/compare?base_id=${currentBaseStockId}`;
      if (compareId) {
        url += `&compare_id=${compareId}`;
      }
      
      const response = await fetch(url);
      const result = await response.json();

      if (result.success && result.data) {
        initChart(result.data.base, result.data.compare);
      }
    } catch (e) {
      console.error('加载对比数据失败:', e);
    }
  };

  const addRowEventListeners = () => {
    document.querySelectorAll('.stock-row').forEach(row => {
      row.addEventListener('mouseenter', function() {
        const stockId = this.dataset.stockId;
        loadCompareData(stockId);
      });
      row.addEventListener('mouseleave', function() {
        loadCompareData(null);
      });
    });
  };

  const updateSectors = async (market) => {
    console.log('Updating sectors for market:', market);
    try {
      const url = `/pyramid/update_sectors?market=${encodeURIComponent(market)}`;
      const response = await fetch(url, {
        method: 'GET',
        headers: {
          'Accept': 'text/vnd.turbo-stream.html',
          'X-Requested-With': 'XMLHttpRequest'
        }
      });
      
      if (!response.ok) {
        console.error('Sectors request failed:', response.status);
        return;
      }
      
      const html = await response.text();
      console.log('Received sectors HTML:', html);
      window.Turbo.renderStreamMessage(html);
      
      setTimeout(() => {
        setupSectorListener();
      }, 50);
    } catch (e) {
      console.error('Failed to update sectors:', e);
    }
  };

  const updateList = async (market, sector) => {
    console.log('Updating list for market:', market, 'sector:', sector);
    try {
      let url = `/pyramid/update_list?market=${encodeURIComponent(market)}`;
      if (sector && sector !== '') {
        url += `&sector=${encodeURIComponent(sector)}`;
      }
      
      const response = await fetch(url, {
        method: 'GET',
        headers: {
          'Accept': 'text/vnd.turbo-stream.html',
          'X-Requested-With': 'XMLHttpRequest'
        }
      });
      
      if (!response.ok) {
        console.error('List request failed:', response.status);
        return;
      }
      
      const html = await response.text();
      console.log('Received list HTML:', html);
      window.Turbo.renderStreamMessage(html);
      
      setTimeout(() => {
        const newTopStock = document.querySelector('.stock-row');
        if (newTopStock) {
          currentBaseStockId = newTopStock.dataset.stockId;
          console.log('Updated base stock ID:', currentBaseStockId);
        }
        addRowEventListeners();
        loadCompareData(null);
      }, 150);
    } catch (e) {
      console.error('Failed to update list:', e);
    }
  };

  const setupSectorListener = () => {
    const sectorSelect = document.getElementById('pyramid-sector');
    if (sectorSelect) {
      sectorSelect.removeEventListener('change', handleSectorChange);
      sectorSelect.addEventListener('change', handleSectorChange);
      console.log('Sector listener set up');
    }
  };

  const handleSectorChange = function() {
    const market = document.getElementById('pyramid-market').value;
    const sector = this.value;
    console.log('Sector changed:', sector);
    updateList(market, sector);
  };

  document.getElementById('pyramid-market').addEventListener('change', function() {
    const market = this.value;
    document.getElementById('pyramid-sector').value = '';
    updateSectors(market);
    updateList(market, '');
  });

  setupSectorListener();
  addRowEventListeners();

  if (initialBaseData && initialBaseData.base) {
    initChart(initialBaseData.base);
  }
});
</script>
