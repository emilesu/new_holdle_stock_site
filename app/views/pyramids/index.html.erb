<% set_page_title "金字塔评分 - 股票智能排行 - Holdle" %>
<% set_page_description "查看全市场股票的金字塔评分排名，从财务健康度、盈利能力、成长性等多维度筛选优质股票。" %>
<% set_page_keywords "金字塔评分,股票排行,智能选股,财务健康,多维度评分" %>
<div class="min-h-screen bg-bg-soft" id="pyramid-page">
  <style>
    #pyramid-page.radar-fixed .radar-card {
      position: fixed;
      z-index: 40;
    }
    #pyramid-page.radar-fixed .radar-column {
      min-height: var(--radar-card-height, 0px);
    }
    @media (max-width: 1023px) {
      #pyramid-page.radar-fixed .radar-card {
        position: static;
        z-index: auto;
      }
      #pyramid-page.radar-fixed .radar-column {
        min-height: auto;
      }
    }
  </style>

  <main class="container-hl py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="radar-column">
        <div class="hl-card radar-card">
          <div class="px-6 py-4 border-b border-line bg-bg-mute">
            <h2 class="text-hl-16 font-semibold text-ink-soft">雷达对比图</h2>
          </div>
          <div class="p-6">
            <div class="relative h-80">
              <canvas id="radar-chart"></canvas>
            </div>
            <div id="chart-legend-pyramid" class="flex justify-center items-center space-x-6 mt-4 text-hl-13">
              <div class="flex items-center space-x-2">
                <span class="w-3 h-3 bg-red-500 rounded-full inline-block"></span>
                <span class="text-muted-2 text-hl-11" id="base-label"><%= @compare_data ? @compare_data[:base][:display_name] : '行业第一' %></span>
              </div>
              <div class="flex items-center space-x-2 hidden" id="compare-legend">
                <span class="w-3 h-3 bg-blue-500 rounded-full inline-block"></span>
                <span class="text-muted-2 text-hl-11" id="compare-label"></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="pyramid-column">
        <div class="hl-card">
          <div class="px-6 py-4 border-b border-line bg-bg-mute">
            <h2 class="text-hl-16 font-semibold text-ink-soft">金字塔排行榜</h2>
          </div>
          <div class="px-6 py-4 border-b border-line">
          <div class="flex flex-wrap gap-4 items-center">
            <div class="flex items-center gap-2">
              <label class="text-hl-13 font-medium text-muted-2 w-12 shrink-0">市场</label>
              <select name="market" id="pyramid-market" class="px-3 py-2 text-hl-13 border border-line rounded focus:border-link w-28 bg-white">
                <option value="CN" <%= 'selected' if @market == 'CN' %>>A股</option>
                <option value="HK" <%= 'selected' if @market == 'HK' %>>港股</option>
                <option value="US" <%= 'selected' if @market == 'US' %>>美股</option>
              </select>
            </div>

            <div class="flex items-center gap-2">
              <label class="text-hl-13 font-medium text-muted-2 w-12 shrink-0">行业</label>
              <div id="sector-container">
                <select name="sector" id="pyramid-sector" class="px-3 py-2 text-hl-13 border border-line rounded focus:border-link w-40 bg-white">
                  <option value="">全部</option>
                  <% @sectors.each do |sector| %>
                    <option value="<%= sector %>" <%= 'selected' if @sector == sector %>><%= sector %></option>
                  <% end %>
                </select>
              </div>
            </div>
          </div>
        </div>

        <div id="pyramid-list-container">
          <div id="pyramid-stock-list" class="divide-y divide-line-soft">
            <% @stocks.each_slice(2) do |pair| %>
              <div class="grid grid-cols-1 md:grid-cols-2">
                <% pair.each do |stock| %>
                  <% global_index = @stocks.index(stock) + 1 %>
                  <% rank = (@page - 1) * 20 + global_index %>
                  <div class="stock-row flex items-center justify-between px-6 py-3 border-r border-line-soft last:border-r-0 cursor-pointer transition-colors duration-150 hover:bg-bg-mute"
                       data-stock-id="<%= stock.id %>"
                       data-stock-symbol="<%= stock.symbol %>"
                       data-stock-url="<%= stock_path(stock) %>"
                       data-stock-name="<%= stock.market == 'US' && stock.name&.include?('|') ? stock.name.split('|').first.strip : stock.name %>">
                    <div class="flex items-center space-x-3 min-w-0">
                      <span class="text-hl-11 font-mono text-muted-4 w-5 text-right shrink-0"><%= rank %></span>
                      <div class="min-w-0">
                        <div class="stock-name text-hl-13 font-medium text-ink truncate hover:text-link">
                          <%= stock.market == 'US' && stock.name&.include?('|') ? stock.name.split('|').first.strip : stock.name %>
                        </div>
                        <div class="text-hl-11 text-muted-3 truncate"><%= stock.symbol %></div>
                      </div>
                    </div>
                    <span class="stock-score font-semibold text-link text-hl-13 shrink-0 ml-2 hover:text-link"><%= stock.pyramid_total_score %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>

          <div id="pyramid-scroll-sentinel"
               class="flex justify-center py-4 text-hl-13 text-muted-4 opacity-100 transition-opacity duration-300"
               data-scroll-has-more="<%= @total_pages > 1 %>"
               data-next-page="2"
               data-total-pages="<%= @total_pages %>"
               data-market="<%= @market %>"
               data-sector="<%= @sector || '' %>">
            <% if @total_pages > 1 %>
              <span class="flex items-center space-x-2"><span>滚动加载更多...</span></span>
            <% else %>
              <span>— 已全部加载 —</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
document.addEventListener('turbo:load', function initPyramidPage() {
  const pyramidPage = document.getElementById('pyramid-page');
  if (!pyramidPage) return;
  if (pyramidPage.dataset._initialized) return;
  pyramidPage.dataset._initialized = 'true';

  let chartInstance = null;
  let currentBaseStockId = '<%= @top_stock&.id || 0 %>';
  let initialBaseData = <%= @compare_data ? raw(@compare_data.to_json) : 'null' %>;
  let lastHoveredStockId = null;
  let pendingRequestId = 0;
  let hoverDebounceTimer = null;

  const initChart = (baseData, compareData = null) => {
    if (chartInstance) {
      chartInstance.destroy();
      chartInstance = null;
    }

    const ctx = document.getElementById('radar-chart');
    if (!ctx) return;

    const labels = ['ROE', '毛利率', '资产周转率', 'EPS', '现金比率', '净利率'];
    const baseValues = baseData ? [
      baseData.values.roe || 0,
      baseData.values.gross_margin || 0,
      baseData.values.asset_turnover_ratio || 0,
      baseData.values.eps || 0,
      baseData.values.cash_to_assets_ratio || 0,
      baseData.values.net_profit_margin || 0
    ] : [0, 0, 0, 0, 0, 0];

    const datasets = [{
      label: baseData ? (baseData.display_name || baseData.name) : '行业第一',
      data: baseValues,
      backgroundColor: 'rgba(239, 68, 68, 0.2)',
      borderColor: 'rgb(239, 68, 68)',
      borderWidth: 2,
      pointRadius: 3
    }];

    if (compareData) {
      const compareValues = [
        compareData.values.roe || 0,
        compareData.values.gross_margin || 0,
        compareData.values.asset_turnover_ratio || 0,
        compareData.values.eps || 0,
        compareData.values.cash_to_assets_ratio || 0,
        compareData.values.net_profit_margin || 0
      ];
      datasets.push({
        label: compareData.display_name || compareData.name,
        data: compareValues,
        backgroundColor: 'rgba(59, 130, 246, 0.2)',
        borderColor: 'rgb(59, 130, 246)',
        borderWidth: 2,
        pointRadius: 3
      });
      document.getElementById('compare-legend').style.display = 'flex';
      document.getElementById('compare-label').textContent = compareData.display_name || compareData.name;
    } else {
      document.getElementById('compare-legend').style.display = 'none';
    }

    chartInstance = new Chart(ctx, {
      type: 'radar',
      data: { labels, datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: false,
        scales: {
          r: {
            min: 0,
            max: 100,
            ticks: { stepSize: 20 },
            pointLabels: { font: { size: 11 } }
          }
        },
        plugins: {
          legend: { display: false }
        }
      }
    });
  };

  window.initChart = initChart;

  // 仅更新对比数据集，避免销毁重建图表
  const updateChartCompareData = (compareData) => {
    if (!chartInstance) return;

    if (compareData) {
      const compareValues = [
        compareData.values.roe || 0,
        compareData.values.gross_margin || 0,
        compareData.values.asset_turnover_ratio || 0,
        compareData.values.eps || 0,
        compareData.values.cash_to_assets_ratio || 0,
        compareData.values.net_profit_margin || 0
      ];

      if (chartInstance.data.datasets.length === 1) {
        chartInstance.data.datasets.push({
          label: compareData.display_name || compareData.name,
          data: compareValues,
          backgroundColor: 'rgba(59, 130, 246, 0.2)',
          borderColor: 'rgb(59, 130, 246)',
          borderWidth: 2,
          pointRadius: 3
        });
      } else if (chartInstance.data.datasets.length >= 2) {
        chartInstance.data.datasets[1].data = compareValues;
        chartInstance.data.datasets[1].label = compareData.display_name || compareData.name;
      }

      chartInstance.update('none');
      document.getElementById('compare-legend').style.display = 'flex';
      document.getElementById('compare-label').textContent = compareData.display_name || compareData.name;
    } else {
      if (chartInstance.data.datasets.length >= 2) {
        chartInstance.data.datasets.pop();
        chartInstance.update('none');
      }
      document.getElementById('compare-legend').style.display = 'none';
    }
  };

  // 雷达数据前端缓存 - 避免重复请求
  const radarDataCache = new Map();

  const loadCompareData = (compareId) => {
    if (hoverDebounceTimer) {
      clearTimeout(hoverDebounceTimer);
      hoverDebounceTimer = null;
    }

    if (compareId === lastHoveredStockId) return;
    lastHoveredStockId = compareId;

    if (!compareId) {
      updateChartCompareData(null);
      return;
    }

    if (compareId === currentBaseStockId) return;

    const cached = radarDataCache.get(compareId);
    if (cached) {
      updateChartCompareData(cached);
      return;
    }

    if (!currentBaseStockId) return;

    pendingRequestId++;
    const thisRequestId = pendingRequestId;

    fetch(`/pyramid/compare?base_id=${currentBaseStockId}&compare_id=${compareId}`)
      .then(response => response.json())
      .then(result => {
        if (thisRequestId !== pendingRequestId) return;
        if (result.success && result.data && result.data.compare) {
          radarDataCache.set(compareId, result.data.compare);
          updateChartCompareData(result.data.compare);
        }
      })
      .catch(e => console.error('加载对比数据失败:', e));
  };

  // 空函数保留向后兼容（已有调用点），hover 事件已改用委托方式
  const addRowEventListeners = () => {};

  // 使用事件委托绑定 hover 和点击事件到永不替换的祖先元素
  const pyramidPageEl = document.getElementById('pyramid-page');
  pyramidPageEl.addEventListener('mouseover', function(e) {
    const row = e.target.closest('.stock-row');
    if (!row) return;
    loadCompareData(row.dataset.stockId);
  });

  pyramidPageEl.addEventListener('mouseout', function(e) {
    const row = e.target.closest('.stock-row');
    if (!row) return;
    const to = e.relatedTarget;
    if (!to || row.contains(to)) return;
    pendingRequestId++;
    lastHoveredStockId = null;
    loadCompareData(null);
  });

  pyramidPageEl.addEventListener('click', function(e) {
    const row = e.target.closest('.stock-row');
    if (!row) return;
    const url = row.dataset.stockUrl;
    if (url) {
      window.open(url, '_blank');
    }
  });

  const updateSectors = async (market) => {
    try {
      const url = `/pyramid/update_sectors?market=${encodeURIComponent(market)}`;
      const response = await fetch(url, {
        method: 'GET',
        headers: {
          'Accept': 'text/vnd.turbo-stream.html',
          'X-Requested-With': 'XMLHttpRequest'
        }
      });

      if (!response.ok) {
        console.error('Sectors request failed:', response.status);
        return;
      }

      const html = await response.text();
      window.Turbo.renderStreamMessage(html);

      setTimeout(() => {
        setupSectorListener();
      }, 50);
    } catch (e) {
      console.error('Failed to update sectors:', e);
    }
  };

  const updateList = async (market, sector) => {
    try {
      let url = `/pyramid/update_list?market=${encodeURIComponent(market)}`;
      if (sector && sector !== '') {
        url += `&sector=${encodeURIComponent(sector)}`;
      }

      const response = await fetch(url, {
        method: 'GET',
        headers: {
          'Accept': 'text/vnd.turbo-stream.html',
          'X-Requested-With': 'XMLHttpRequest'
        }
      });

      if (!response.ok) {
        console.error('List request failed:', response.status);
        return;
      }

      const html = await response.text();
      window.Turbo.renderStreamMessage(html);

      // 重置滚动加载页码
      scrollCurrentPage = 1;
      scrollIsLoading = false;
      
      setTimeout(() => {
        radarDataCache.clear();
        const newTopStock = document.querySelector('.stock-row');
        if (newTopStock) {
          currentBaseStockId = newTopStock.dataset.stockId;
        }
        addRowEventListeners();
        setupScrollObserver();
        loadCompareData(null);
      }, 150);
    } catch (e) {
      console.error('Failed to update list:', e);
    }
  };

  const setupSectorListener = () => {
    const sectorSelect = document.getElementById('pyramid-sector');
    if (sectorSelect) {
      sectorSelect.removeEventListener('change', handleSectorChange);
      sectorSelect.addEventListener('change', handleSectorChange);
    }
  };

  const handleSectorChange = function() {
    const market = document.getElementById('pyramid-market').value;
    const sector = this.value;
    updateList(market, sector);
  };

  document.getElementById('pyramid-market').addEventListener('change', function() {
    const market = this.value;
    document.getElementById('pyramid-sector').value = '';
    pendingRequestId++;
    updateSectors(market);
    updateList(market, '');
  });

  // 无限滚动加载（v3 - 使用 JS 变量维护页码，避开 Turbo replace 不生效的 Bug）
  console.log('[Scroll] 金字塔页面加载，使用 v3 滚动加载机制（JS 变量维护页码）');
  let scrollObserver = null;
  let scrollIsLoading = false;
  let scrollCurrentPage = 1;  // 用 JS 变量取代 DOM data 属性维护当前页码

  const setupScrollObserver = () => {
    if (scrollObserver) {
      scrollObserver.disconnect();
      scrollObserver = null;
    }

    const sentinel = document.getElementById('pyramid-scroll-sentinel');
    if (!sentinel) {
      console.log('[Scroll] sentinel 元素未找到');
      return;
    }

    const totalPages = parseInt(sentinel.dataset.totalPages || 1);
    const hasMore = scrollCurrentPage < totalPages;
    console.log('[Scroll] setupScrollObserver: hasMore=' + hasMore + ', currentPage=' + scrollCurrentPage + ', totalPages=' + totalPages);
    if (!hasMore) return;

    scrollObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        console.log('[Scroll] Observer回调: isIntersecting=' + entry.isIntersecting + ', isLoading=' + scrollIsLoading);
        if (!entry.isIntersecting || scrollIsLoading) return;
        console.log('[Scroll] sentinel 进入视口，触发加载下一页');
        loadNextPage();
      });
    }, { rootMargin: '300px' });

    scrollObserver.observe(sentinel);
    console.log('[Scroll] IntersectionObserver 已绑定到 sentinel');
  };

  const loadNextPage = async () => {
    const sentinel = document.getElementById('pyramid-scroll-sentinel');
    if (!sentinel || scrollIsLoading) {
      console.log('[Scroll] loadNextPage 跳过: sentinel=' + !!sentinel + ', isLoading=' + scrollIsLoading);
      return;
    }

    const totalPages = parseInt(sentinel.dataset.totalPages || 1);
    const nextPage = scrollCurrentPage + 1;
    
    if (nextPage > totalPages) {
      console.log('[Scroll] loadNextPage 跳过: nextPage=' + nextPage + ' > totalPages=' + totalPages);
      sentinel.dataset.scrollHasMore = 'false';
      sentinel.innerHTML = '<span>— 已全部加载 —</span>';
      return;
    }

    const market = sentinel.dataset.market || 'CN';
    const sector = sentinel.dataset.sector || '';
    console.log('[Scroll] loadNextPage: 开始加载 page=' + nextPage + ', market=' + market + ', sector=' + sector);

    scrollIsLoading = true;
    sentinel.innerHTML = '<span class="flex items-center space-x-2"><svg class="animate-spin h-4 w-4 text-gray-400" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg><span>加载中...</span></span>';

    try {
      let url = `/pyramid/load_more?page=${nextPage}&market=${encodeURIComponent(market)}`;
      if (sector) {
        url += `&sector=${encodeURIComponent(sector)}`;
      }

      const response = await fetch(url, {
        headers: {
          'Accept': 'text/vnd.turbo-stream.html',
          'X-Requested-With': 'XMLHttpRequest'
        }
      });

      if (!response.ok) throw new Error('请求失败');

      const html = await response.text();
      console.log('[Scroll] 收到响应，长度=' + html.length + ' chars');
      
      window.Turbo.renderStreamMessage(html);
      
      // 用 JS 变量更新页码，不依赖 Turbo replace 是否生效
      scrollCurrentPage = nextPage;
      scrollIsLoading = false;
      
      // 手动更新 sentinel 的 data 属性和文本
      const updatedSentinel = document.getElementById('pyramid-scroll-sentinel');
      if (updatedSentinel) {
        const hasMore = scrollCurrentPage < parseInt(updatedSentinel.dataset.totalPages || 1);
        updatedSentinel.dataset.scrollHasMore = hasMore ? 'true' : 'false';
        updatedSentinel.dataset.nextPage = String(scrollCurrentPage + 1);
        
        if (hasMore) {
          updatedSentinel.innerHTML = '<span>滚动加载更多...</span>';
        } else {
          updatedSentinel.innerHTML = '<span>— 已全部加载 —</span>';
        }
        
        console.log('[Scroll] 手动更新 sentinel: currentPage=' + scrollCurrentPage + 
          ', hasMore=' + hasMore + ', nextPage=' + updatedSentinel.dataset.nextPage);
      }

      console.log('[Scroll] Turbo渲染完成，重新配置观察器');
      setupScrollObserver();

      // 主动检查：Turbo 异步 append 后，sentinel 可能已被推出视口
      // IntersectionObserver 不会对已在视口外的元素触发，需手动检测
      setTimeout(() => {
        const checkSentinel = document.getElementById('pyramid-scroll-sentinel');
        if (checkSentinel && !scrollIsLoading && scrollCurrentPage < parseInt(checkSentinel.dataset.totalPages || 1)) {
          const rect = checkSentinel.getBoundingClientRect();
          const windowHeight = window.innerHeight || document.documentElement.clientHeight;
          const isVisible = rect.top < windowHeight + 300 && rect.bottom > 0;
          console.log('[Scroll] 主动检查: rect.top=' + rect.top + ', windowHeight=' + windowHeight + ', isVisible=' + isVisible);
          if (isVisible) {
            console.log('[Scroll] sentinel 仍在视口内，自动触发下一页');
            loadNextPage();
            return;
          }
        }
        addRowEventListeners();
      }, 200);
    } catch (e) {
      scrollIsLoading = false;
      const currentSentinel = document.getElementById('pyramid-scroll-sentinel');
      if (currentSentinel) {
        currentSentinel.innerHTML = '<div class="flex flex-col items-center space-y-2 py-4"><span class="text-red-500">加载失败</span></div>';
        setTimeout(() => {
          const retrySentinel = document.getElementById('pyramid-scroll-sentinel');
          if (retrySentinel && scrollCurrentPage < parseInt(retrySentinel.dataset.totalPages || 1)) {
            setupScrollObserver();
            loadNextPage();
          }
        }, 3000);
      } else {
        setTimeout(setupScrollObserver, 1000);
      }
    }
  };

  setupScrollObserver();

  // 雷达图固定定位滚动处理
  let radarScrollHandler = null;
  let radarResizeHandler = null;

  const initRadarFixed = () => {
    const radarCard = document.querySelector('.radar-card');
    const radarColumn = document.querySelector('.radar-column');
    const pageContainer = document.getElementById('pyramid-page');
    const navbar = document.querySelector('nav');
    if (!radarCard || !radarColumn || !pageContainer) return;

    const getFixedTop = () => {
      if (navbar) return navbar.offsetHeight;
      return 0;
    };

    const updateRadarPosition = () => {
      if (window.innerWidth < 1024) {
        pageContainer.classList.remove('radar-fixed');
        radarCard.style.width = '';
        radarCard.style.left = '';
        radarCard.style.top = '';
        radarColumn.style.setProperty('--radar-card-height', '0px');
        return;
      }

      const radarCardRect = radarCard.getBoundingClientRect();
      const fixedTop = getFixedTop();
      // 触发阈值：导航栏下方32px
      const stickyThreshold = fixedTop + 32;

      if (radarCardRect.top <= stickyThreshold) {
        pageContainer.classList.add('radar-fixed');
        const columnRect = radarColumn.getBoundingClientRect();
        radarCard.style.width = columnRect.width + 'px';
        radarCard.style.left = columnRect.left + 'px';
        radarCard.style.top = stickyThreshold + 'px';   // ← 固定值，始终对齐
        radarColumn.style.setProperty('--radar-card-height', radarCard.offsetHeight + 'px');
      } else {
        pageContainer.classList.remove('radar-fixed');
        radarCard.style.width = '';
        radarCard.style.left = '';
        radarCard.style.top = '';
        radarColumn.style.setProperty('--radar-card-height', '0px');
      }
    };

    let ticking = false;
    radarScrollHandler = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateRadarPosition();
          ticking = false;
        });
        ticking = true;
      }
    };

    document.addEventListener('scroll', radarScrollHandler, { passive: true });
    updateRadarPosition();

    radarResizeHandler = () => {
      updateRadarPosition();
    };
    window.addEventListener('resize', radarResizeHandler);
  };

  initRadarFixed();

  function cleanupBeforeCache() {
    // 移除初始化标记，确保 Turbo 恢复缓存页面时能重新初始化
    pyramidPage.removeAttribute('data-_initialized');
    if (scrollObserver) {
      scrollObserver.disconnect();
      scrollObserver = null;
    }
    if (radarScrollHandler) {
      document.removeEventListener('scroll', radarScrollHandler);
    }
    if (radarResizeHandler) {
      window.removeEventListener('resize', radarResizeHandler);
    }
  }
  document.addEventListener('turbo:before-cache', cleanupBeforeCache);

  setupSectorListener();
  addRowEventListeners();

  if (initialBaseData && initialBaseData.base) {
    initChart(initialBaseData.base);
  }
});
</script>
