<div class="min-h-screen bg-gray-50" id="pyramid-page">
  <style>
    #pyramid-page .stock-row {
      cursor: pointer;
      transition: background-color 0.2s ease-in-out;
    }
    #pyramid-page .stock-row:hover {
      background-color: #eff6ff;
    }
    #pyramid-page .stock-row:hover .stock-name {
      color: #1e40af;
    }
    #pyramid-page .stock-row:hover .stock-score {
      color: #1e40af;
    }
    #pyramid-page .comparison-item {
      cursor: pointer;
      transition: background-color 0.2s ease-in-out;
    }
    #pyramid-page .comparison-item:hover {
      background-color: #f3f4f6;
    }
    #pyramid-page.radar-fixed .radar-card {
      position: fixed;
      z-index: 40;
    }
    #pyramid-page.radar-fixed .radar-column {
      min-height: var(--radar-card-height, 0px);
    }
    @media (max-width: 1023px) {
      #pyramid-page.radar-fixed .radar-card {
        position: static;
        z-index: auto;
      }
      #pyramid-page.radar-fixed .radar-column {
        min-height: auto;
      }
    }
  </style>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="radar-column">
        <div class="bg-white rounded-lg border border-gray-200 radar-card">
          <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-800">雷达对比图</h2>
          </div>
          <div class="p-6">
            <div class="relative h-80">
              <canvas id="radar-chart"></canvas>
            </div>
            <div id="chart-legend-pyramid" class="flex justify-center items-center space-x-6 mt-4 text-sm">
              <div class="flex items-center space-x-2">
                <span class="w-3 h-3 bg-red-500 rounded-full inline-block"></span>
                <span class="text-gray-600 text-xs" id="base-label"><%= @compare_data ? @compare_data[:base][:display_name] : '行业第一' %></span>
              </div>
              <div class="flex items-center space-x-2 hidden" id="compare-legend">
                <span class="w-3 h-3 bg-blue-500 rounded-full inline-block"></span>
                <span class="text-gray-600 text-xs" id="compare-label"></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="pyramid-column">
        <div class="bg-white rounded-lg border border-gray-200">
          <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-800">金字塔排行榜</h2>
          </div>
          <div class="px-6 py-4 border-b border-gray-200">
          <div class="flex flex-wrap gap-4 items-center">
            <div class="flex items-center gap-2">
              <label class="text-sm font-medium text-gray-600 w-12 shrink-0">市场</label>
              <select name="market" id="pyramid-market" class="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent w-28 bg-white">
                <option value="CN" <%= 'selected' if @market == 'CN' %>>A股</option>
                <option value="US" <%= 'selected' if @market == 'US' %>>美股</option>
              </select>
            </div>

            <div class="flex items-center gap-2">
              <label class="text-sm font-medium text-gray-600 w-12 shrink-0">行业</label>
              <div id="sector-container">
                <select name="sector" id="pyramid-sector" class="px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent w-40 bg-white">
                  <option value="">全部</option>
                  <% @sectors.each do |sector| %>
                    <option value="<%= sector %>" <%= 'selected' if @sector == sector %>><%= sector %></option>
                  <% end %>
                </select>
              </div>
            </div>
          </div>
        </div>

        <div id="pyramid-list-container">
          <div id="pyramid-stock-list" class="divide-y divide-gray-100">
            <% @stocks.each_slice(2) do |pair| %>
              <div class="grid grid-cols-1 md:grid-cols-2">
                <% pair.each do |stock| %>
                  <% global_index = @stocks.index(stock) + 1 %>
                  <% rank = (@page - 1) * 20 + global_index %>
                  <div class="stock-row flex items-center justify-between px-6 py-3 border-r border-gray-100 last:border-r-0"
                       data-stock-id="<%= stock.id %>"
                       data-stock-symbol="<%= stock.symbol %>"
                       data-stock-url="<%= stock_path(stock) %>"
                       data-stock-name="<%= stock.market == 'US' && stock.name&.include?('|') ? stock.name.split('|').first.strip : stock.name %>">
                    <div class="flex items-center space-x-3 min-w-0">
                      <span class="text-xs font-mono text-gray-400 w-5 text-right shrink-0"><%= rank %></span>
                      <div class="min-w-0">
                        <div class="stock-name text-sm font-medium text-gray-900 truncate">
                          <%= stock.market == 'US' && stock.name&.include?('|') ? stock.name.split('|').first.strip : stock.name %>
                        </div>
                        <div class="text-xs text-gray-500 truncate"><%= stock.symbol %></div>
                      </div>
                    </div>
                    <span class="stock-score font-semibold text-indigo-600 text-sm shrink-0 ml-2"><%= stock.pyramid_total_score %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>

          <div id="pyramid-scroll-sentinel"
               class="flex justify-center py-4 text-sm text-gray-400 opacity-100 transition-opacity duration-300"
               data-next-page="2"
               data-total-pages="<%= @total_pages %>"
               data-market="<%= @market %>"
               data-sector="<%= @sector || '' %>">
            <% if @total_pages > 1 %>
              <span class="flex items-center space-x-2"><span>滚动加载更多...</span></span>
            <% else %>
              <span>— 已全部加载 —</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
document.addEventListener('turbo:load', function initPyramidPage() {
  const pyramidPage = document.getElementById('pyramid-page');
  if (!pyramidPage) return;
  if (pyramidPage.dataset._initialized) return;
  pyramidPage.dataset._initialized = 'true';

  let chartInstance = null;
  let currentBaseStockId = '<%= @top_stock&.id || 0 %>';
  let initialBaseData = <%= @compare_data ? raw(@compare_data.to_json) : 'null' %>;
  let lastHoveredStockId = null;
  let pendingRequestId = 0;
  let hoverDebounceTimer = null;

  const initChart = (baseData, compareData = null) => {
    if (chartInstance) {
      chartInstance.destroy();
      chartInstance = null;
    }

    const ctx = document.getElementById('radar-chart');
    if (!ctx) return;

    const labels = ['ROE', '毛利率', '资产周转率', 'EPS', '负债比率', '净利率'];
    const baseValues = baseData ? [
      baseData.values.roe || 0,
      baseData.values.gross_margin || 0,
      baseData.values.asset_turnover_ratio || 0,
      baseData.values.eps || 0,
      baseData.values.asset_liab_ratio || 0,
      baseData.values.net_profit_margin || 0
    ] : [0, 0, 0, 0, 0, 0];

    const datasets = [{
      label: baseData ? (baseData.display_name || baseData.name) : '行业第一',
      data: baseValues,
      backgroundColor: 'rgba(239, 68, 68, 0.2)',
      borderColor: 'rgb(239, 68, 68)',
      borderWidth: 2,
      pointRadius: 3
    }];

    if (compareData) {
      const compareValues = [
        compareData.values.roe || 0,
        compareData.values.gross_margin || 0,
        compareData.values.asset_turnover_ratio || 0,
        compareData.values.eps || 0,
        compareData.values.asset_liab_ratio || 0,
        compareData.values.net_profit_margin || 0
      ];
      datasets.push({
        label: compareData.display_name || compareData.name,
        data: compareValues,
        backgroundColor: 'rgba(59, 130, 246, 0.2)',
        borderColor: 'rgb(59, 130, 246)',
        borderWidth: 2,
        pointRadius: 3
      });
      document.getElementById('compare-legend').style.display = 'flex';
      document.getElementById('compare-label').textContent = compareData.display_name || compareData.name;
    } else {
      document.getElementById('compare-legend').style.display = 'none';
    }

    chartInstance = new Chart(ctx, {
      type: 'radar',
      data: { labels, datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: false,
        scales: {
          r: {
            min: 0,
            max: 100,
            ticks: { stepSize: 20 },
            pointLabels: { font: { size: 11 } }
          }
        },
        plugins: {
          legend: { display: false }
        }
      }
    });
  };

  window.initChart = initChart;

  // 仅更新对比数据集，避免销毁重建图表
  const updateChartCompareData = (compareData) => {
    if (!chartInstance) return;

    if (compareData) {
      const compareValues = [
        compareData.values.roe || 0,
        compareData.values.gross_margin || 0,
        compareData.values.asset_turnover_ratio || 0,
        compareData.values.eps || 0,
        compareData.values.asset_liab_ratio || 0,
        compareData.values.net_profit_margin || 0
      ];

      if (chartInstance.data.datasets.length === 1) {
        chartInstance.data.datasets.push({
          label: compareData.display_name || compareData.name,
          data: compareValues,
          backgroundColor: 'rgba(59, 130, 246, 0.2)',
          borderColor: 'rgb(59, 130, 246)',
          borderWidth: 2,
          pointRadius: 3
        });
      } else if (chartInstance.data.datasets.length >= 2) {
        chartInstance.data.datasets[1].data = compareValues;
        chartInstance.data.datasets[1].label = compareData.display_name || compareData.name;
      }

      chartInstance.update('none');
      document.getElementById('compare-legend').style.display = 'flex';
      document.getElementById('compare-label').textContent = compareData.display_name || compareData.name;
    } else {
      if (chartInstance.data.datasets.length >= 2) {
        chartInstance.data.datasets.pop();
        chartInstance.update('none');
      }
      document.getElementById('compare-legend').style.display = 'none';
    }
  };

  // 雷达数据前端缓存 - 避免重复请求
  const radarDataCache = new Map();

  const loadCompareData = (compareId) => {
    if (hoverDebounceTimer) {
      clearTimeout(hoverDebounceTimer);
      hoverDebounceTimer = null;
    }

    if (compareId === lastHoveredStockId) return;
    lastHoveredStockId = compareId;

    if (!compareId) {
      updateChartCompareData(null);
      return;
    }

    if (compareId === currentBaseStockId) return;

    const cached = radarDataCache.get(compareId);
    if (cached) {
      updateChartCompareData(cached);
      return;
    }

    if (!currentBaseStockId) return;

    pendingRequestId++;
    const thisRequestId = pendingRequestId;

    fetch(`/pyramid/compare?base_id=${currentBaseStockId}&compare_id=${compareId}`)
      .then(response => response.json())
      .then(result => {
        if (thisRequestId !== pendingRequestId) return;
        if (result.success && result.data && result.data.compare) {
          radarDataCache.set(compareId, result.data.compare);
          updateChartCompareData(result.data.compare);
        }
      })
      .catch(e => console.error('加载对比数据失败:', e));
  };

  const addRowEventListeners = () => {
    document.querySelectorAll('.stock-row').forEach(row => {
      row.removeEventListener('mouseenter', row._hoverEnterHandler);
      row.removeEventListener('mouseleave', row._hoverLeaveHandler);

      row._hoverEnterHandler = function() {
        const stockId = this.dataset.stockId;
        loadCompareData(stockId);
      };
      row._hoverLeaveHandler = function() {
        pendingRequestId++;
        lastHoveredStockId = null;
        loadCompareData(null);
      };

      row.addEventListener('mouseenter', row._hoverEnterHandler);
      row.addEventListener('mouseleave', row._hoverLeaveHandler);
    });
  };

  // 排行榜股票项点击跳转 - 委托到永不替换的祖先元素
  document.getElementById('pyramid-page').addEventListener('click', function(e) {
    const row = e.target.closest('.stock-row');
    if (!row) return;
    const url = row.dataset.stockUrl;
    if (url) {
      window.open(url, '_blank');
    }
  });

  const updateSectors = async (market) => {
    try {
      const url = `/pyramid/update_sectors?market=${encodeURIComponent(market)}`;
      const response = await fetch(url, {
        method: 'GET',
        headers: {
          'Accept': 'text/vnd.turbo-stream.html',
          'X-Requested-With': 'XMLHttpRequest'
        }
      });

      if (!response.ok) {
        console.error('Sectors request failed:', response.status);
        return;
      }

      const html = await response.text();
      window.Turbo.renderStreamMessage(html);

      setTimeout(() => {
        setupSectorListener();
      }, 50);
    } catch (e) {
      console.error('Failed to update sectors:', e);
    }
  };

  const updateList = async (market, sector) => {
    try {
      let url = `/pyramid/update_list?market=${encodeURIComponent(market)}`;
      if (sector && sector !== '') {
        url += `&sector=${encodeURIComponent(sector)}`;
      }

      const response = await fetch(url, {
        method: 'GET',
        headers: {
          'Accept': 'text/vnd.turbo-stream.html',
          'X-Requested-With': 'XMLHttpRequest'
        }
      });

      if (!response.ok) {
        console.error('List request failed:', response.status);
        return;
      }

      const html = await response.text();
      window.Turbo.renderStreamMessage(html);

      setTimeout(() => {
        radarDataCache.clear();
        const newTopStock = document.querySelector('.stock-row');
        if (newTopStock) {
          currentBaseStockId = newTopStock.dataset.stockId;
        }
        addRowEventListeners();
        setupScrollObserver();
        loadCompareData(null);
      }, 150);
    } catch (e) {
      console.error('Failed to update list:', e);
    }
  };

  const setupSectorListener = () => {
    const sectorSelect = document.getElementById('pyramid-sector');
    if (sectorSelect) {
      sectorSelect.removeEventListener('change', handleSectorChange);
      sectorSelect.addEventListener('change', handleSectorChange);
    }
  };

  const handleSectorChange = function() {
    const market = document.getElementById('pyramid-market').value;
    const sector = this.value;
    updateList(market, sector);
  };

  document.getElementById('pyramid-market').addEventListener('change', function() {
    const market = this.value;
    document.getElementById('pyramid-sector').value = '';
    pendingRequestId++;
    updateSectors(market);
    updateList(market, '');
  });

  // 无限滚动加载
  let scrollObserver = null;
  let scrollCurrentPage = 1;
  let scrollIsLoading = false;
  let scrollHasMore = <%= @total_pages > 1 ? 'true' : 'false' %>;

  const setupScrollObserver = () => {
    if (scrollObserver) {
      scrollObserver.disconnect();
      scrollObserver = null;
    }

    const sentinel = document.getElementById('pyramid-scroll-sentinel');
    if (!sentinel) return;

    scrollCurrentPage = 1;
    scrollHasMore = parseInt(sentinel.dataset.totalPages || 1) > 1;

    scrollObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting || scrollIsLoading || !scrollHasMore) return;
        loadNextPage();
      });
    }, { rootMargin: '200px' });

    scrollObserver.observe(sentinel);
  };

  const loadNextPage = async () => {
    const sentinel = document.getElementById('pyramid-scroll-sentinel');
    if (!sentinel || scrollIsLoading) return;
    if (!scrollHasMore) return;

    const nextPage = parseInt(sentinel.dataset.nextPage || 2);
    const market = sentinel.dataset.market || 'CN';
    const sector = sentinel.dataset.sector || '';

    scrollIsLoading = true;
    sentinel.style.opacity = '0.5';
    sentinel.innerHTML = '<span class="flex items-center space-x-2 transition-opacity duration-300"><svg class="animate-spin h-4 w-4 text-gray-400" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg><span>加载中...</span></span>';
    setTimeout(() => { sentinel.style.opacity = '1'; }, 50);

    try {
      let url = `/pyramid/load_more?page=${nextPage}&market=${encodeURIComponent(market)}`;
      if (sector) {
        url += `&sector=${encodeURIComponent(sector)}`;
      }

      const response = await fetch(url, {
        headers: {
          'Accept': 'text/vnd.turbo-stream.html',
          'X-Requested-With': 'XMLHttpRequest'
        }
      });

      if (!response.ok) throw new Error('请求失败');

      const html = await response.text();
      window.Turbo.renderStreamMessage(html);
      scrollIsLoading = false;

      const newSentinel = document.getElementById('pyramid-scroll-sentinel');
      if (newSentinel) {
        const totalPages = parseInt(newSentinel.dataset.totalPages || 1);
        const nextPg = parseInt(newSentinel.dataset.nextPage || 1);
        scrollHasMore = nextPg <= totalPages;

        if (scrollObserver && scrollHasMore) {
          scrollObserver.unobserve(sentinel);
          scrollObserver.observe(newSentinel);
        }

        scrollCurrentPage = nextPg - 1;

        setTimeout(() => {
          addRowEventListeners();
        }, 50);
      }
    } catch (e) {
      scrollIsLoading = false;
      sentinel.innerHTML = '<div class="flex flex-col items-center space-y-2"><span class="text-red-500">加载失败</span><button onclick="retryLoadMore()" class="px-3 py-1 text-sm bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">点击重试</button></div>';
    }
  };

  window.retryLoadMore = function() {
    scrollIsLoading = false;
    loadNextPage();
  };

  setupScrollObserver();

  // 雷达图固定定位滚动处理
  let radarScrollHandler = null;
  let radarResizeHandler = null;

  const initRadarFixed = () => {
    const radarCard = document.querySelector('.radar-card');
    const radarColumn = document.querySelector('.radar-column');
    const pageContainer = document.getElementById('pyramid-page');
    const navbar = document.querySelector('nav');
    if (!radarCard || !radarColumn || !pageContainer) return;

    const getFixedTop = () => {
      if (navbar) return navbar.offsetHeight;
      return 0;
    };

    const updateRadarPosition = () => {
      if (window.innerWidth < 1024) {
        pageContainer.classList.remove('radar-fixed');
        radarCard.style.width = '';
        radarCard.style.left = '';
        radarCard.style.top = '';
        radarColumn.style.setProperty('--radar-card-height', '0px');
        return;
      }

      const radarCardRect = radarCard.getBoundingClientRect();
      const fixedTop = getFixedTop();
      // 触发阈值：导航栏下方32px
      const stickyThreshold = fixedTop + 32;

      if (radarCardRect.top <= stickyThreshold) {
        pageContainer.classList.add('radar-fixed');
        const columnRect = radarColumn.getBoundingClientRect();
        radarCard.style.width = columnRect.width + 'px';
        radarCard.style.left = columnRect.left + 'px';
        radarCard.style.top = stickyThreshold + 'px';   // ← 固定值，始终对齐
        radarColumn.style.setProperty('--radar-card-height', radarCard.offsetHeight + 'px');
      } else {
        pageContainer.classList.remove('radar-fixed');
        radarCard.style.width = '';
        radarCard.style.left = '';
        radarCard.style.top = '';
        radarColumn.style.setProperty('--radar-card-height', '0px');
      }
    };

    let ticking = false;
    radarScrollHandler = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateRadarPosition();
          ticking = false;
        });
        ticking = true;
      }
    };

    document.addEventListener('scroll', radarScrollHandler, { passive: true });
    updateRadarPosition();

    radarResizeHandler = () => {
      updateRadarPosition();
    };
    window.addEventListener('resize', radarResizeHandler);
  };

  initRadarFixed();

  document.addEventListener('turbo:before-render', function cleanup() {
    if (radarScrollHandler) {
      document.removeEventListener('scroll', radarScrollHandler);
    }
    if (radarResizeHandler) {
      window.removeEventListener('resize', radarResizeHandler);
    }
    document.removeEventListener('turbo:before-render', cleanup);
  }, { once: true });

  setupSectorListener();
  addRowEventListeners();

  if (initialBaseData && initialBaseData.base) {
    initChart(initialBaseData.base);
  }
});
</script>
