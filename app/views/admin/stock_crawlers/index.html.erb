<div class="mb-6">
  <h1 class="text-hl-22 font-bold text-ink">爬虫管理</h1>
  <p class="mt-1 text-hl-13 text-muted">股票数据爬虫任务管理中心</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <div class="hl-card">
    <div class="px-5 py-4 bg-gradient-to-r from-green-50 to-green-100 border-b border-line">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="w-3 h-8 bg-gradient-to-b from-green-500 to-green-600 rounded-md"></div>
          <h2 class="text-hl-16 font-semibold text-ink">🇺🇸 美股爬虫区</h2>
        </div>
        <span class="text-hl-12 text-muted-4 font-medium bg-white px-3 py-1 rounded">3个任务</span>
      </div>
    </div>
    <div class="p-5 space-y-3">
      <a href="<%= admin_stock_crawlers_us_stock_list_path %>" 
         class="hl-btn hl-btn-primary flex items-center justify-center space-x-3">
        <span class="text-xl">📋</span>
        <span class="font-medium">爬取美股列表</span>
      </a>
      <a href="<%= admin_stock_crawlers_us_stock_basic_path %>" 
         class="hl-btn hl-btn-primary flex items-center justify-center space-x-3">
        <span class="text-xl">🏢</span>
        <span class="font-medium">爬取美股名称&行业</span>
      </a>
      <a href="<%= admin_stock_crawlers_us_finance_path %>" 
         class="hl-btn hl-btn-primary flex items-center justify-center space-x-3">
        <span class="text-xl">💰</span>
        <span class="font-medium">爬取美股全套财务</span>
      </a>
    </div>
  </div>

  <div class="hl-card">
    <div class="px-5 py-4 bg-gradient-to-r from-blue-50 to-blue-100 border-b border-line">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="w-3 h-8 bg-gradient-to-b from-blue-500 to-blue-600 rounded-md"></div>
          <h2 class="text-hl-16 font-semibold text-ink">🇭🇰 港股爬虫区</h2>
        </div>
        <span class="text-hl-12 text-muted-4 font-medium bg-white px-3 py-1 rounded">4个任务</span>
      </div>
    </div>
    <div class="p-5 space-y-3">
      <a href="<%= admin_stock_crawlers_hk_stock_list_path %>" 
         class="hl-btn hl-btn-primary flex items-center justify-center space-x-3">
        <span class="text-xl">📋</span>
        <span class="font-medium">爬取港股列表、名称&行业</span>
      </a>
      <a href="<%= admin_stock_crawlers_hk_finance_path %>" 
         class="hl-btn hl-btn-primary flex items-center justify-center space-x-3">
        <span class="text-xl">💰</span>
        <span class="font-medium">爬取港股全套财务</span>
      </a>
      <div class="border-t border-line pt-3 space-y-3">
        <div class="text-hl-12 text-muted-4 font-medium mb-1">— 东方财富数据源(测试) —</div>
        <a href="<%= admin_stock_crawlers_hk_finance_em_path %>" 
           class="hl-btn hl-btn-line flex items-center justify-center space-x-3">
          <span class="text-xl">🆕</span>
          <span class="font-medium">港股全套财务(东方财富)</span>
        </a>
        <a href="<%= admin_stock_crawlers_hk_finance_em_single_path(limit: 5) %>" 
           class="hl-btn hl-btn-line flex items-center justify-center space-x-3">
          <span class="text-xl">🔬</span>
          <span class="font-medium">测试5只港股(东方财富)</span>
        </a>
      </div>
    </div>
  </div>

  <div class="hl-card">
    <div class="px-5 py-4 bg-gradient-to-r from-red-50 to-red-100 border-b border-line">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="w-3 h-8 bg-gradient-to-b from-red-500 to-red-600 rounded-md"></div>
          <h2 class="text-hl-16 font-semibold text-ink">🇨🇳 A股爬虫区</h2>
        </div>
        <span class="text-hl-12 text-muted-4 font-medium bg-white px-3 py-1 rounded">2个任务</span>
      </div>
    </div>
    <div class="p-5 space-y-3">
      <a href="<%= admin_stock_crawlers_a_stock_list_path %>" 
         class="hl-btn hl-btn-primary flex items-center justify-center space-x-3">
        <span class="text-xl">📋</span>
        <span class="font-medium">爬取A股列表、名称&行业</span>
      </a>
      <a href="<%= admin_stock_crawlers_a_finance_path %>" 
         class="hl-btn hl-btn-primary flex items-center justify-center space-x-3">
        <span class="text-xl">💰</span>
        <span class="font-medium">爬取A股全套财务</span>
      </a>
    </div>
  </div>

  <div class="hl-card">
    <div class="px-5 py-4 bg-gradient-to-r from-indigo-50 to-indigo-100 border-b border-line">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="w-3 h-8 bg-gradient-to-b from-indigo-500 to-indigo-600 rounded-md"></div>
          <h2 class="text-hl-16 font-semibold text-ink">📊 数据计算</h2>
        </div>
        <span class="text-hl-12 text-muted-4 font-medium bg-white px-3 py-1 rounded">2个任务</span>
      </div>
    </div>
    <div class="p-5 space-y-3">
      <a href="<%= admin_stock_crawlers_update_all_pyramid_path %>" 
         class="hl-btn hl-btn-primary flex items-center justify-center space-x-3">
        <span class="text-xl">🏆</span>
        <span class="font-medium">全局更新金字塔分数</span>
      </a>
      <a href="<%= admin_stock_crawlers_refresh_all_radar_path %>" 
         class="hl-btn hl-btn-primary flex items-center justify-center space-x-3">
        <span class="text-xl">📈</span>
        <span class="font-medium">全局刷新雷达维度缓存</span>
      </a>
    </div>
  </div>
</div>

<div class="hl-card">
  <div class="px-5 py-4 border-b border-line flex items-center justify-between">
    <div class="flex items-center space-x-3">
      <span class="text-xl">📝</span>
      <h2 class="text-hl-16 font-semibold text-ink">执行结果</h2>
    </div>
    <span class="text-hl-12 text-muted-4">共 <%= @results.count %> 条记录</span>
  </div>
  <div class="divide-y divide-line max-h-[400px] overflow-y-auto">
    <% if @results.present? %>
      <% @results.each do |result| %>
        <div class="px-5 py-4 flex items-center space-x-4 hover:bg-bg-mute transition-colors">
          <div class="w-3 h-3 rounded-full flex-shrink-0 
            <%= result.status == 'success' ? 'bg-green-500' : 'bg-red-500' %>">
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-hl-13 font-medium text-ink truncate"><%= result.task_name %></div>
            <div class="text-hl-12 text-muted-4 truncate"><%= result.message %></div>
          </div>
          <div class="text-right text-hl-12 text-muted-5 flex-shrink-0">
            <div class="font-medium text-muted-3"><%= result.executed_at.strftime('%m-%d %H:%M') %></div>
            <div>耗时 <%= result.duration %>s</div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="px-5 py-12 text-center">
        <div class="w-16 h-16 bg-bg-mute rounded-full flex items-center justify-center mx-auto mb-4">
          <span class="text-3xl">🔄</span>
        </div>
        <p class="text-hl-13 text-muted-4">暂无执行记录</p>
        <p class="text-hl-12 text-muted-5 mt-1">请点击上方按钮开始爬取任务</p>
      </div>
    <% end %>
  </div>
</div>

<div class="mt-6 bg-yellow-50 border border-yellow-200 rounded-md p-4">
  <div class="flex items-start space-x-3">
    <span class="text-xl flex-shrink-0">⚠️</span>
    <div>
      <p class="text-hl-13 font-medium text-yellow-800">注意事项</p>
      <p class="text-hl-12 text-yellow-700 mt-1">任务执行期间请耐心等待，请勿重复点击。大型爬取任务可能需要较长时间，请在后台执行。</p>
    </div>
  </div>
</div>