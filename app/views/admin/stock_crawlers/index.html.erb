<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">爬虫管理</h1>
      <p class="mt-2 text-gray-600">股票数据爬虫任务管理中心</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 bg-gradient-to-r from-green-50 to-green-100 border-b border-gray-100">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
              <div class="w-3 h-8 bg-gradient-to-b from-green-500 to-green-600 rounded-lg"></div>
              <h2 class="text-lg font-semibold text-gray-800">🇺🇸 美股爬虫区</h2>
            </div>
            <span class="text-sm text-gray-500 font-medium bg-white px-3 py-1 rounded-full">3个任务</span>
          </div>
        </div>
        <div class="p-6 space-y-3">
          <a href="<%= admin_stock_crawlers_us_stock_list_path %>" 
             class="flex items-center justify-center space-x-3 px-4 py-3 bg-gradient-to-r from-green-500 to-green-600 text-white rounded-xl hover:from-green-600 hover:to-green-700 transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
            <span class="text-xl">📋</span>
            <span class="font-medium">爬取美股列表</span>
          </a>
          <a href="<%= admin_stock_crawlers_us_stock_basic_path %>" 
             class="flex items-center justify-center space-x-3 px-4 py-3 bg-gradient-to-r from-green-500 to-green-600 text-white rounded-xl hover:from-green-600 hover:to-green-700 transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
            <span class="text-xl">🏢</span>
            <span class="font-medium">爬取美股名称&行业</span>
          </a>
          <a href="<%= admin_stock_crawlers_us_finance_path %>" 
             class="flex items-center justify-center space-x-3 px-4 py-3 bg-gradient-to-r from-green-500 to-green-600 text-white rounded-xl hover:from-green-600 hover:to-green-700 transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
            <span class="text-xl">💰</span>
            <span class="font-medium">爬取美股全套财务</span>
          </a>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 bg-gradient-to-r from-red-50 to-red-100 border-b border-gray-100">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
              <div class="w-3 h-8 bg-gradient-to-b from-red-500 to-red-600 rounded-lg"></div>
              <h2 class="text-lg font-semibold text-gray-800">🇨🇳 A股爬虫区</h2>
            </div>
            <span class="text-sm text-gray-500 font-medium bg-white px-3 py-1 rounded-full">2个任务</span>
          </div>
        </div>
        <div class="p-6 space-y-3">
          <a href="<%= admin_stock_crawlers_a_stock_list_path %>" 
             class="flex items-center justify-center space-x-3 px-4 py-3 bg-gradient-to-r from-red-500 to-red-600 text-white rounded-xl hover:from-red-600 hover:to-red-700 transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
            <span class="text-xl">📋</span>
            <span class="font-medium">爬取A股列表、名称&行业</span>
          </a>
          <a href="<%= admin_stock_crawlers_a_finance_path %>" 
             class="flex items-center justify-center space-x-3 px-4 py-3 bg-gradient-to-r from-red-500 to-red-600 text-white rounded-xl hover:from-red-600 hover:to-red-700 transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
            <span class="text-xl">💰</span>
            <span class="font-medium">爬取A股全套财务</span>
          </a>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 bg-gradient-to-r from-indigo-50 to-indigo-100 border-b border-gray-100">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
              <div class="w-3 h-8 bg-gradient-to-b from-indigo-500 to-indigo-600 rounded-lg"></div>
              <h2 class="text-lg font-semibold text-gray-800">📊 数据计算</h2>
            </div>
            <span class="text-sm text-gray-500 font-medium bg-white px-3 py-1 rounded-full">2个任务</span>
          </div>
        </div>
        <div class="p-6 space-y-3">
          <a href="<%= admin_stock_crawlers_update_all_pyramid_path %>" 
             class="flex items-center justify-center space-x-3 px-4 py-3 bg-gradient-to-r from-indigo-500 to-indigo-600 text-white rounded-xl hover:from-indigo-600 hover:to-indigo-700 transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
            <span class="text-xl">🏆</span>
            <span class="font-medium">全局更新金字塔分数</span>
          </a>
          <a href="<%= admin_stock_crawlers_refresh_all_radar_path %>" 
             class="flex items-center justify-center space-x-3 px-4 py-3 bg-gradient-to-r from-indigo-500 to-indigo-600 text-white rounded-xl hover:from-indigo-600 hover:to-indigo-700 transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
            <span class="text-xl">📈</span>
            <span class="font-medium">全局刷新雷达维度缓存</span>
          </a>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <span class="text-xl">📝</span>
          <h2 class="text-lg font-semibold text-gray-800">执行结果</h2>
        </div>
        <span class="text-sm text-gray-500">共 <%= @results.count %> 条记录</span>
      </div>
      <div class="divide-y divide-gray-100 max-h-[400px] overflow-y-auto">
        <% if @results.present? %>
          <% @results.each do |result| %>
            <div class="px-6 py-4 flex items-center space-x-4 hover:bg-gray-50 transition-colors">
              <div class="w-3 h-3 rounded-full flex-shrink-0 
                <%= result.status == 'success' ? 'bg-green-500 shadow-lg shadow-green-500/50' : 'bg-red-500 shadow-lg shadow-red-500/50' %>">
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-medium text-gray-900 truncate"><%= result.task_name %></div>
                <div class="text-sm text-gray-500 truncate"><%= result.message %></div>
              </div>
              <div class="text-right text-sm text-gray-400 flex-shrink-0">
                <div class="font-medium text-gray-600"><%= result.executed_at.strftime('%m-%d %H:%M') %></div>
                <div>耗时 <%= result.duration %>s</div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="px-6 py-12 text-center">
            <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl">🔄</span>
            </div>
            <p class="text-gray-500">暂无执行记录</p>
            <p class="text-sm text-gray-400 mt-1">请点击上方按钮开始爬取任务</p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mt-6 bg-yellow-50 border border-yellow-200 rounded-xl p-4">
      <div class="flex items-start space-x-3">
        <span class="text-xl flex-shrink-0">⚠️</span>
        <div>
          <p class="font-medium text-yellow-800">注意事项</p>
          <p class="text-sm text-yellow-700 mt-1">任务执行期间请耐心等待，请勿重复点击。大型爬取任务可能需要较长时间，请在后台执行。</p>
        </div>
      </div>
    </div>
  </div>
</div>
