<%= form_with(model: [:admin, course, chapter, lesson], class: 'space-y-6') do |f| %>
  <div>
    <%= f.label :title, '小节标题', class: 'block text-sm font-medium text-gray-700 mb-1' %>
    <%= f.text_field :title, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500' %>
    <% if lesson.errors[:title].any? %>
      <p class="mt-1 text-sm text-red-600"><%= lesson.errors[:title].join(', ') %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :content, 'MD 内容（支持 Markdown 语法）', class: 'block text-sm font-medium text-gray-700 mb-1' %>
    <%= f.text_area :content, rows: 20, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500 font-mono text-sm' %>
  </div>

  <div class="flex flex-wrap items-center gap-6">
    <div class="flex items-center space-x-2">
      <%= f.check_box :is_published, class: 'rounded border-gray-300 text-blue-600 focus:ring-blue-500' %>
      <%= f.label :is_published, '发布', class: 'text-sm text-gray-700' %>
    </div>

    <div>
      <%= f.label :access_level, '访问级别', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.select :access_level, options_for_select([['继承章节', nil], ['公开', 0], ['会员', 1]], lesson.access_level), {}, class: 'px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500' %>
    </div>

    <div>
      <%= f.label :sort_num, '排序', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.number_field :sort_num, class: 'w-20 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500' %>
    </div>
  </div>

  <div class="flex items-center space-x-3">
    <%= f.submit '保存', class: 'bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700' %>
    <%= link_to '取消', admin_course_chapter_lessons_path(course, chapter), class: 'text-sm text-gray-600 hover:text-gray-800' %>
  </div>
<% end %>