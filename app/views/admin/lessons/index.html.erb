<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">
    小节管理 - <%= link_to @chapter.title, admin_course_chapters_path(@course) %> / <%= @course.title %>
  </h1>
  <div class="flex items-center space-x-2">
    <%= link_to '新建小节', new_admin_course_chapter_lesson_path(@course, @chapter), class: 'bg-blue-600 text-white px-4 py-2 rounded-md text-sm hover:bg-blue-700' %>
    <%= link_to '返回章节', admin_course_chapters_path(@course), class: 'text-sm text-gray-600 hover:text-gray-800' %>
  </div>
</div>

<div class="bg-white rounded-md border border-gray-200">
  <table class="min-w-full">
    <thead>
      <tr class="border-b border-gray-200 bg-gray-50">
        <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">排序</th>
        <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">标题</th>
        <th class="px-6 py-3 text-center text-sm font-medium text-gray-500">发布状态</th>
        <th class="px-6 py-3 text-center text-sm font-medium text-gray-500">内容长度</th>
        <th class="px-6 py-3 text-right text-sm font-medium text-gray-500">操作</th>
      </tr>
    </thead>
    <tbody>
      <% @lessons.each do |lesson| %>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="px-6 py-4 text-sm text-gray-600"><%= lesson.sort_num %></td>
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= lesson.title %></td>
          <td class="px-6 py-4 text-center">
            <% if lesson.is_published %>
              <span class="inline-flex px-2 py-1 text-xs font-medium bg-green-100 text-green-700 rounded-full">已发布</span>
            <% else %>
              <span class="inline-flex px-2 py-1 text-xs font-medium bg-gray-100 text-gray-600 rounded-full">草稿</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-center text-sm text-gray-600"><%= lesson.content.to_s.length %> 字</td>
          <td class="px-6 py-4 text-right">
            <div class="flex items-center justify-end space-x-2">
              <%= link_to '编辑', edit_admin_course_chapter_lesson_path(@course, @chapter, lesson), class: 'text-sm text-blue-600 hover:text-blue-800' %>
              <%= button_to '删除', admin_course_chapter_lesson_path(@course, @chapter, lesson), method: :delete, class: 'text-sm text-red-600 hover:text-red-800', data: { turbo_confirm: '确定删除？' } %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @lessons.empty? %>
        <tr>
          <td colspan="5" class="px-6 py-8 text-center text-gray-400">暂无小节</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>