<div class="flex items-center justify-between mb-6">
  <h1 class="text-lg font-semibold text-gray-800">
    <%= link_to '课程管理', admin_courses_path, class: 'text-blue-600 hover:text-blue-800' %> /
    <%= link_to @course.title, admin_course_path(@course), class: 'text-blue-600 hover:text-blue-800' %> /
    <%= link_to '章节管理', admin_course_chapters_path(@course), class: 'text-blue-600 hover:text-blue-800' %> /
    <%= @chapter.title %> / 小节管理
  </h1>
  <%= link_to '新增小节', new_admin_course_chapter_lesson_path(@course, @chapter), class: 'bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 text-sm' %>
</div>

<div class="bg-white rounded-md border border-gray-200 overflow-hidden">
  <table class="w-full">
    <thead>
      <tr class="border-b border-gray-200 bg-gray-50">
        <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">排序</th>
        <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">标题</th>
        <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">有效访问级别</th>
        <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">状态</th>
        <th class="px-6 py-3 text-right text-sm font-medium text-gray-500">操作</th>
      </tr>
    </thead>
    <tbody>
      <% @lessons.each do |lesson| %>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="px-6 py-4 text-sm text-gray-600"><%= lesson.sort_num %></td>
          <td class="px-6 py-4 text-sm">
            <%= link_to lesson.title, admin_course_chapter_lesson_path(@course, @chapter, lesson), class: 'text-blue-600 hover:text-blue-800' %>
          </td>
          <td class="px-6 py-4 text-sm">
            <% level = lesson.effective_access_level %>
            <span class="inline-flex px-2 py-1 text-xs font-medium <%= level == 1 ? 'bg-blue-50 text-blue-600 border border-blue-200' : 'bg-green-50 text-green-600 border border-green-200' %> rounded">
              <%= level == 1 ? '会员' : '公开' %>
              <% if lesson.access_level.nil? %>
                <span class="ml-1 text-gray-400">(继承)</span>
              <% end %>
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600">
            <%= lesson.published? ? '已发布' : '草稿' %>
          </td>
          <td class="px-6 py-4 text-sm text-right">
            <div class="flex items-center justify-end space-x-3">
              <%= link_to '查看', admin_course_chapter_lesson_path(@course, @chapter, lesson), class: 'text-blue-600 hover:text-blue-800' %>
              <%= link_to '编辑', edit_admin_course_chapter_lesson_path(@course, @chapter, lesson), class: 'text-gray-600 hover:text-gray-800' %>
              <%= button_to '删除', admin_course_chapter_lesson_path(@course, @chapter, lesson), method: :delete, class: 'text-red-600 hover:text-red-800', data: { turbo_confirm: '确认删除？' } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>