<div class="flex items-center justify-between mb-6">
  <h1 class="text-hl-16 font-semibold text-ink">
    <%= link_to '课程管理', admin_courses_path, class: 'text-link hover:text-link-hover' %> /
    <%= link_to @course.title, admin_course_path(@course), class: 'text-link hover:text-link-hover' %> /
    <%= link_to '章节管理', admin_course_chapters_path(@course), class: 'text-link hover:text-link-hover' %> /
    <%= @chapter.title %> / 小节管理
  </h1>
  <%= link_to '新增小节', new_admin_course_chapter_lesson_path(@course, @chapter), class: 'hl-btn hl-btn-primary' %>
</div>

<div class="hl-card overflow-hidden">
  <table class="w-full">
    <thead>
      <tr class="border-b border-line bg-bg-mute">
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">排序</th>
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">标题</th>
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">有效访问级别</th>
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">状态</th>
        <th class="px-6 py-4 text-right text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">操作</th>
      </tr>
    </thead>
    <tbody>
      <% @lessons.each do |lesson| %>
        <tr class="border-b border-line hover:bg-bg-mute">
          <td class="px-6 py-4 text-hl-13 text-muted"><%= lesson.sort_num %></td>
          <td class="px-6 py-4 text-hl-13">
            <%= link_to lesson.title, admin_course_chapter_lesson_path(@course, @chapter, lesson), class: 'text-link hover:text-link-hover' %>
          </td>
          <td class="px-6 py-4 text-hl-13">
            <% level = lesson.effective_access_level %>
            <span class="inline-flex px-2 py-1 text-hl-12 font-medium <%= level == 1 ? 'bg-blue-50 text-link border border-blue-200' : 'bg-green-50 text-green-600 border border-green-200' %> rounded">
              <%= level == 1 ? '会员' : '公开' %>
              <% if lesson.access_level.nil? %>
                <span class="ml-1 text-muted-4">(继承)</span>
              <% end %>
            </span>
          </td>
          <td class="px-6 py-4 text-hl-13 text-muted">
            <%= lesson.published? ? '已发布' : '草稿' %>
          </td>
          <td class="px-6 py-4 text-hl-13 text-right">
            <div class="flex items-center justify-end space-x-3">
              <%= link_to '查看', admin_course_chapter_lesson_path(@course, @chapter, lesson), class: 'text-link hover:text-link-hover' %>
              <%= link_to '编辑', edit_admin_course_chapter_lesson_path(@course, @chapter, lesson), class: 'text-muted hover:text-ink' %>
              <%= button_to '删除', admin_course_chapter_lesson_path(@course, @chapter, lesson), method: :delete, class: 'text-profit hover:text-red-700', data: { turbo_confirm: '确认删除？' } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>