<%= form_with(model: [:admin, course], class: 'space-y-6') do |f| %>
  <div>
    <%= f.label :title, '课程标题', class: 'block text-sm font-medium text-gray-700 mb-1' %>
    <%= f.text_field :title, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500' %>
    <% if course.errors[:title].any? %>
      <p class="mt-1 text-sm text-red-600"><%= course.errors[:title].join(', ') %></p>
    <% end %>
  </div>

  <div>
    <%= f.label :description, '课程描述', class: 'block text-sm font-medium text-gray-700 mb-1' %>
    <%= f.text_area :description, rows: 4, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500' %>
  </div>

  <div>
    <%= f.label :cover, '封面图片URL', class: 'block text-sm font-medium text-gray-700 mb-1' %>
    <%= f.url_field :cover, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500', placeholder: 'https://example.com/covers/image.jpg' %>
  </div>

  <div class="flex flex-wrap items-center gap-6">
    <div class="flex items-center space-x-2">
      <%= f.check_box :is_published, class: 'rounded border-gray-300 text-blue-600 focus:ring-blue-500' %>
      <%= f.label :is_published, '发布', class: 'text-sm text-gray-700' %>
    </div>

    <div>
      <%= f.label :access_level, '访问级别', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.select :access_level, options_for_select([['公开', 0], ['会员', 1]], course.access_level), {}, class: 'px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500' %>
    </div>

    <div>
      <%= f.label :sort, '排序权重', class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.number_field :sort, class: 'w-20 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500' %>
    </div>
  </div>

  <div class="flex items-center space-x-3">
    <%= f.submit '保存', class: 'bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700' %>
    <%= link_to '取消', admin_courses_path, class: 'text-sm text-gray-600 hover:text-gray-800' %>
  </div>
<% end %>