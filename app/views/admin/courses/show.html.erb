<div class="flex items-center justify-between mb-6">
  <h1 class="text-lg font-semibold text-gray-800">
    <%= link_to '课程管理', admin_courses_path, class: 'text-blue-600 hover:text-blue-800' %> / <%= @course.title %>
  </h1>
  <%= link_to '编辑课程', edit_admin_course_path(@course), class: 'bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 text-sm' %>
</div>

<div class="bg-white rounded-md border border-gray-200 overflow-hidden mb-8">
  <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
    <h2 class="text-sm font-semibold text-gray-700">基本信息</h2>
  </div>
  <div class="p-6 space-y-4">
    <% if @course.cover_url %>
      <div>
        <span class="text-xs text-gray-400 block mb-1">封面图片</span>
        <img src="<%= @course.cover_url %>" alt="<%= @course.title %>" class="w-48 h-28 object-cover rounded border border-gray-100">
      </div>
    <% end %>
    <div>
      <span class="text-xs text-gray-400 block mb-1">标题</span>
      <span class="text-sm text-gray-900"><%= @course.title %></span>
    </div>
    <% if @course.description.present? %>
      <div>
        <span class="text-xs text-gray-400 block mb-1">描述</span>
        <span class="text-sm text-gray-600"><%= @course.description %></span>
      </div>
    <% end %>
    <div class="flex items-center space-x-6">
      <div>
        <span class="text-xs text-gray-400 block mb-1">访问级别</span>
        <% if @course.member_only? %>
          <span class="inline-flex px-2 py-1 text-xs font-medium bg-blue-50 text-blue-600 border border-blue-200 rounded">会员</span>
        <% else %>
          <span class="inline-flex px-2 py-1 text-xs font-medium bg-gray-50 text-gray-500 border border-gray-200 rounded">公开</span>
        <% end %>
      </div>
      <div>
        <span class="text-xs text-gray-400 block mb-1">状态</span>
        <span class="text-sm text-gray-700"><%= @course.published? ? '已发布' : '草稿' %></span>
      </div>
      <div>
        <span class="text-xs text-gray-400 block mb-1">排序</span>
        <span class="text-sm text-gray-700"><%= @course.sort %></span>
      </div>
    </div>
  </div>
</div>

<div class="bg-white rounded-md border border-gray-200 overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200 bg-gray-50 flex items-center justify-between">
    <h2 class="text-sm font-semibold text-gray-700">章节列表</h2>
    <%= link_to '新增章节', new_admin_course_chapter_path(@course), class: 'bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 text-sm' %>
  </div>
  <table class="w-full">
    <thead>
      <tr class="border-b border-gray-200 bg-gray-50">
        <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">排序</th>
        <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">标题</th>
        <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">访问级别</th>
        <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">状态</th>
        <th class="px-6 py-3 text-right text-sm font-medium text-gray-500">操作</th>
      </tr>
    </thead>
    <tbody>
      <% @chapters.each do |chapter| %>
        <tr class="border-b border-gray-100 hover:bg-gray-50">
          <td class="px-6 py-4 text-sm text-gray-600"><%= chapter.sort_num %></td>
          <td class="px-6 py-4 text-sm">
            <%= link_to chapter.title, admin_course_chapter_path(@course, chapter), class: 'text-blue-600 hover:text-blue-800' %>
          </td>
          <td class="px-6 py-4 text-sm">
            <% level = chapter.effective_access_level %>
            <span class="inline-flex px-2 py-1 text-xs font-medium <%= level == 1 ? 'bg-blue-50 text-blue-600 border border-blue-200' : 'bg-green-50 text-green-600 border border-green-200' %> rounded">
              <%= level == 1 ? '会员' : '公开' %>
              <% if chapter.access_level.nil? %>
                <span class="ml-1 text-gray-400">(继承)</span>
              <% end %>
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-600">
            <%= chapter.published? ? '已发布' : '草稿' %>
          </td>
          <td class="px-6 py-4 text-sm text-right">
            <div class="flex items-center justify-end space-x-3">
              <%= link_to '小节', admin_course_chapter_lessons_path(@course, chapter), class: 'text-blue-600 hover:text-blue-800' %>
              <%= link_to '编辑', edit_admin_course_chapter_path(@course, chapter), class: 'text-gray-600 hover:text-gray-800' %>
              <%= button_to '删除', admin_course_chapter_path(@course, chapter), method: :delete, class: 'text-red-600 hover:text-red-800', data: { turbo_confirm: '确认删除？' } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>