<div class="flex items-center justify-between mb-6">
  <h1 class="text-hl-22 font-bold text-ink">
    <%= link_to '课程管理', admin_courses_path, class: 'text-link hover:text-link-hover' %> / <%= @course.title %>
  </h1>
  <%= link_to '编辑课程', edit_admin_course_path(@course), class: 'hl-btn hl-btn-primary' %>
</div>

<div class="hl-card mb-8">
  <div class="px-6 py-4 border-b border-line bg-bg-mute">
    <h2 class="text-hl-13 font-semibold text-muted-3">基本信息</h2>
  </div>
  <div class="p-6 space-y-4">
    <% if @course.cover_url %>
      <div>
        <span class="text-hl-12 text-muted-4 block mb-1">封面图片</span>
        <img src="<%= @course.cover_url %>" alt="<%= @course.title %>" class="w-48 h-28 object-cover rounded border border-line">
      </div>
    <% end %>
    <div>
      <span class="text-hl-12 text-muted-4 block mb-1">标题</span>
      <span class="text-hl-13 text-ink"><%= @course.title %></span>
    </div>
    <% if @course.description.present? %>
      <div>
        <span class="text-hl-12 text-muted-4 block mb-1">描述</span>
        <span class="text-hl-13 text-muted"><%= @course.description %></span>
      </div>
    <% end %>
    <div class="flex items-center space-x-6">
      <div>
        <span class="text-hl-12 text-muted-4 block mb-1">访问级别</span>
        <% if @course.member_only? %>
          <span class="hl-tag bg-blue-50 text-link border border-blue-200">会员</span>
        <% else %>
          <span class="hl-tag bg-bg-mute text-muted-3 border border-line">公开</span>
        <% end %>
      </div>
      <div>
        <span class="text-hl-12 text-muted-4 block mb-1">状态</span>
        <span class="text-hl-13 text-muted"><%= @course.published? ? '已发布' : '草稿' %></span>
      </div>
      <div>
        <span class="text-hl-12 text-muted-4 block mb-1">排序</span>
        <span class="text-hl-13 text-muted"><%= @course.sort %></span>
      </div>
    </div>
  </div>
</div>

<div class="hl-card overflow-hidden">
  <div class="px-6 py-4 border-b border-line bg-bg-mute flex items-center justify-between">
    <h2 class="text-hl-13 font-semibold text-muted-3">章节列表</h2>
    <%= link_to '新增章节', new_admin_course_chapter_path(@course), class: 'hl-btn hl-btn-primary' %>
  </div>
  <table class="w-full">
    <thead>
      <tr class="border-b border-line bg-bg-mute">
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">排序</th>
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">标题</th>
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">访问级别</th>
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">状态</th>
        <th class="px-6 py-4 text-right text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">操作</th>
      </tr>
    </thead>
    <tbody>
      <% @chapters.each do |chapter| %>
        <tr class="border-b border-line hover:bg-bg-mute">
          <td class="px-6 py-4 text-hl-13 text-muted"><%= chapter.sort_num %></td>
          <td class="px-6 py-4 text-hl-13">
            <%= link_to chapter.title, admin_course_chapter_path(@course, chapter), class: 'text-link hover:text-link-hover' %>
          </td>
          <td class="px-6 py-4 text-hl-13">
            <% level = chapter.effective_access_level %>
            <span class="inline-flex px-2 py-1 text-hl-12 font-medium <%= level == 1 ? 'bg-blue-50 text-link border border-blue-200' : 'bg-green-50 text-green-600 border border-green-200' %> rounded">
              <%= level == 1 ? '会员' : '公开' %>
              <% if chapter.access_level.nil? %>
                <span class="ml-1 text-muted-4">(继承)</span>
              <% end %>
            </span>
          </td>
          <td class="px-6 py-4 text-hl-13 text-muted">
            <%= chapter.published? ? '已发布' : '草稿' %>
          </td>
          <td class="px-6 py-4 text-hl-13 text-right">
            <div class="flex items-center justify-end space-x-3">
              <%= link_to '小节', admin_course_chapter_lessons_path(@course, chapter), class: 'text-link hover:text-link-hover' %>
              <%= link_to '编辑', edit_admin_course_chapter_path(@course, chapter), class: 'text-muted hover:text-ink' %>
              <%= button_to '删除', admin_course_chapter_path(@course, chapter), method: :delete, class: 'text-profit hover:text-red-700', data: { turbo_confirm: '确认删除？' } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>