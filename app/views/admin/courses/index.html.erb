<div class="flex items-center justify-between mb-6">
  <h1 class="text-hl-22 font-bold text-ink">课程管理</h1>
  <%= link_to '新增课程', new_admin_course_path, class: 'hl-btn hl-btn-primary' %>
</div>

<div class="hl-card overflow-hidden">
  <table class="w-full">
    <thead>
      <tr class="border-b border-line bg-bg-mute">
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">封面</th>
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">标题</th>
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">访问级别</th>
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">状态</th>
        <th class="px-6 py-4 text-left text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">排序</th>
        <th class="px-6 py-4 text-right text-hl-12 font-semibold text-muted-3 uppercase tracking-wider">操作</th>
      </tr>
    </thead>
    <tbody>
      <% @courses.each do |course| %>
        <tr class="border-b border-line hover:bg-bg-mute">
          <td class="px-6 py-4 text-hl-13">
            <% if course.cover_url %>
              <img src="<%= course.cover_url %>" alt="<%= course.title %>" class="w-16 h-10 object-cover rounded border border-line">
            <% else %>
              <span class="text-muted-5 text-hl-12">无</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-hl-13">
            <%= link_to course.title, admin_course_path(course), class: 'text-link hover:text-link-hover' %>
          </td>
          <td class="px-6 py-4 text-hl-13">
            <% if course.member_only? %>
              <span class="hl-tag bg-blue-50 text-blue-600 border border-blue-200">会员</span>
            <% else %>
              <span class="hl-tag bg-bg-mute text-muted-3 border border-line">公开</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-hl-13 text-muted">
            <%= course.published? ? '已发布' : '草稿' %>
          </td>
          <td class="px-6 py-4 text-hl-13 text-muted"><%= course.sort %></td>
          <td class="px-6 py-4 text-hl-13 text-right">
            <div class="flex items-center justify-end space-x-3">
              <%= link_to '章节', admin_course_chapters_path(course), class: 'text-link hover:text-link-hover' %>
              <%= link_to '编辑', edit_admin_course_path(course), class: 'text-muted hover:text-ink' %>
              <%= button_to '删除', admin_course_path(course), method: :delete, class: 'text-profit hover:text-red-700', data: { turbo_confirm: '确认删除？' } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>