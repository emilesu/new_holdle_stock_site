<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900">用户详情</h1>
  <p class="mt-2 text-gray-600">查看用户 <%= @user.nickname %> 的详细信息</p>
</div>

<div class="hl-card">
  <div class="px-6 py-4 border-b border-line">
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-4">
        <%= user_avatar_tag(@user, size: "w-14 h-14", css_class: "text-2xl") %>
        <div>
          <h2 class="text-hl-18 font-bold text-ink"><%= @user.nickname %></h2>
          <p class="text-muted">#<%= @user.id %></p>
        </div>
      </div>
      <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-semibold
        <%= case @user.role
             when 'super_admin' then 'bg-red-100 text-red-800'
             when 'admin' then 'bg-purple-100 text-purple-800'
             when 'member' then 'bg-blue-100 text-blue-800'
             else 'bg-gray-100 text-gray-800'
           end %>">
        <%= human_role(@user.role) %>
      </span>
    </div>
  </div>

  <div class="px-6 py-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-gray-50 rounded-md p-5">
        <h3 class="text-sm font-medium text-gray-500 mb-4">基本信息</h3>
        <div class="space-y-3">
          <div class="flex justify-between">
            <span class="text-gray-500">邮箱</span>
            <span class="font-medium text-gray-900 text-right"><%= @user.email %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">昵称</span>
            <span class="font-medium text-gray-900 text-right"><%= @user.nickname %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">角色</span>
            <span class="font-medium text-gray-900 text-right"><%= human_role(@user.role) %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">会员到期</span>
            <span class="font-medium text-gray-900 text-right">
              <%= @user.member_expire_at.present? ? l(@user.member_expire_at, format: :long) : '未开通会员' %>
            </span>
          </div>
        </div>
      </div>

      <div class="bg-gray-50 rounded-md p-5">
        <h3 class="text-sm font-medium text-gray-500 mb-4">时间信息</h3>
        <div class="space-y-3">
          <div class="flex justify-between">
            <span class="text-gray-500">注册时间</span>
            <span class="font-medium text-gray-900 text-right"><%= l(@user.created_at, format: :long) %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">最后登录</span>
            <span class="font-medium text-gray-900 text-right">
              <%= @user.last_login_at.present? ? l(@user.last_login_at, format: :long) : '暂无记录' %>
            </span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">信息更新</span>
            <span class="font-medium text-gray-900 text-right"><%= l(@user.updated_at, format: :long) %></span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6 bg-gray-50 rounded-md p-5">
      <h3 class="text-sm font-medium text-gray-500 mb-3">个人简介</h3>
      <p class="text-gray-900 leading-relaxed min-h-[60px]">
        <%= @user.bio.presence || '<span class="text-gray-400">暂无简介</span>'.html_safe %>
      </p>
    </div>
  </div>
</div>

<div class="flex space-x-4">
  <%= link_to "编辑", edit_admin_user_path(@user),
    class: "hl-btn hl-btn-primary" %>
  <%= link_to "返回列表", admin_users_path,
    class: "hl-btn hl-btn-line" %>
</div>
