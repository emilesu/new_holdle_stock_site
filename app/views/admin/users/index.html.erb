<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">用户管理</h1>
      <p class="mt-2 text-gray-600">管理平台所有注册用户</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-6">
      <div class="px-6 py-4 border-b border-gray-100">
        <div class="flex flex-col sm:flex-row gap-4">
          <div class="flex-1 relative">
            <input type="text" name="search" placeholder="搜索邮箱或昵称..." value="<%= params[:search] %>"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              onkeydown="if(event.key === 'Enter') { this.form.submit(); }">
          </div>
          <div class="flex gap-2">
            <select name="role" class="px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              <option value="all" <%= 'selected' if params[:role] == 'all' || params[:role].blank? %>>全部角色</option>
              <option value="user" <%= 'selected' if params[:role] == 'user' %>>普通用户</option>
              <option value="member" <%= 'selected' if params[:role] == 'member' %>>会员</option>
              <option value="admin" <%= 'selected' if params[:role] == 'admin' %>>管理员</option>
              <option value="super_admin" <%= 'selected' if params[:role] == 'super_admin' %>>超级管理员</option>
            </select>
            <button type="submit" class="px-4 py-2.5 bg-gray-800 text-white rounded-lg hover:bg-gray-900 transition-colors">
              筛选
            </button>
            <a href="<%= new_admin_user_path %>" class="px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors whitespace-nowrap">
              <svg class="w-5 h-5 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
              添加用户
            </a>
          </div>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">用户</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">邮箱</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">角色</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">会员到期</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">注册时间</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">最后登录</th>
              <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">操作</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% if @users.empty? %>
              <tr>
                <td colspan="7" class="px-6 py-12 text-center text-gray-500">
                  暂无用户数据
                </td>
              </tr>
            <% else %>
              <% @users.each do |user| %>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center space-x-3">
                      <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-semibold">
                        <%= user.avatar_char %>
                      </div>
                      <div>
                        <p class="font-medium text-gray-900"><%= user.nickname %></p>
                        <p class="text-sm text-gray-500">#<%= user.id %></p>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="text-gray-600 truncate max-w-[200px]" title="<%= user.email %>"><%= user.email %></span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold
                      <%= case user.role
                           when 'super_admin' then 'bg-red-100 text-red-800'
                           when 'admin' then 'bg-purple-100 text-purple-800'
                           when 'member' then 'bg-blue-100 text-blue-800'
                           else 'bg-gray-100 text-gray-800'
                         end %>">
                      <%= user.role.humanize %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="text-gray-600">
                      <%= user.member_expire_at.present? ? l(user.member_expire_at.to_date) : '-' %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="text-gray-600"><%= l(user.created_at.to_date) %></span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="text-gray-600">
                      <%= user.last_login_at.present? ? l(user.last_login_at.to_date) : '-' %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right">
                    <div class="flex items-center justify-end space-x-2">
                      <a href="<%= admin_user_path(user) %>" class="text-blue-600 hover:text-blue-700 text-sm font-medium">查看</a>
                      <a href="<%= edit_admin_user_path(user) %>" class="text-indigo-600 hover:text-indigo-700 text-sm font-medium">编辑</a>
                      <%= button_to '删除', admin_user_path(user), method: :delete, 
                        class: "text-red-600 hover:text-red-700 text-sm font-medium",
                        data: { confirm: "确定删除用户 #{user.nickname} 吗？" },
                        disabled: current_user == user %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @total_pages > 1 %>
        <div class="px-6 py-4 border-t border-gray-100">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-sm text-gray-600">
              显示第 <%= (@page - 1) * @per_page + 1 %> 到 <%= [@page * @per_page, @total_count].min %> 条，共 <%= @total_count %> 条记录
            </p>
            <nav class="flex items-center space-x-1">
              <a href="<%= admin_users_path(page: @page - 1, search: params[:search], role: params[:role]) %>"
                class="px-3 py-1.5 text-sm font-medium rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                <%= 'disabled' if @page <= 1 %>>
                上一页
              </a>
              <% (([1, @page - 2].max)..([@total_pages, @page + 2].min)).each do |page_num| %>
                <% if page_num == @page %>
                  <a href="<%= admin_users_path(page: page_num, search: params[:search], role: params[:role]) %>"
                    class="min-w-[36px] px-3 py-1.5 text-sm font-medium rounded-lg border bg-blue-600 border-blue-600 text-white shadow-sm">
                    <%= page_num %>
                  </a>
                <% else %>
                  <a href="<%= admin_users_path(page: page_num, search: params[:search], role: params[:role]) %>"
                    class="min-w-[36px] px-3 py-1.5 text-sm font-medium rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors">
                    <%= page_num %>
                  </a>
                <% end %>
              <% end %>
              <a href="<%= admin_users_path(page: @page + 1, search: params[:search], role: params[:role]) %>"
                class="px-3 py-1.5 text-sm font-medium rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                <%= 'disabled' if @page >= @total_pages %>>
                下一页
              </a>
            </nav>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
