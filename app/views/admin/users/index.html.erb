<div class="mb-6">
  <h1 class="text-hl-22 font-bold text-ink">用户管理</h1>
  <p class="mt-1 text-hl-13 text-muted">管理平台所有注册用户</p>
</div>

<div class="hl-card mb-6">
  <div class="px-5 py-4 border-b border-line">
    <div class="flex flex-col sm:flex-row gap-4">
      <div class="flex-1 relative">
        <input type="text" name="search" placeholder="搜索邮箱或昵称..." value="<%= params[:search] %>"
          class="w-full px-4 py-2.5 border border-line rounded text-hl-13 focus:outline-none focus:border-ink"
          onkeydown="if(event.key === 'Enter') { this.form.submit(); }">
      </div>
      <div class="flex gap-2">
        <select name="role" class="px-4 py-2.5 border border-line rounded text-hl-13 focus:outline-none focus:border-ink bg-white">
          <option value="all" <%= 'selected' if params[:role] == 'all' || params[:role].blank? %>>全部角色</option>
          <option value="user" <%= 'selected' if params[:role] == 'user' %>>访客</option>
          <option value="member" <%= 'selected' if params[:role] == 'member' %>>会员</option>
          <option value="admin" <%= 'selected' if params[:role] == 'admin' %>>管理员</option>
          <option value="super_admin" <%= 'selected' if params[:role] == 'super_admin' %>>超级管理员</option>
        </select>
        <button type="submit" class="hl-btn hl-btn-primary flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          筛选
        </button>
        <a href="<%= new_admin_user_path %>" class="hl-btn hl-btn-primary flex items-center">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          添加用户
        </a>
      </div>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full hl-table">
      <thead>
        <tr>
          <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">用户</th>
          <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">邮箱</th>
          <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">角色</th>
          <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">会员到期</th>
          <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">注册时间</th>
          <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">最后登录</th>
          <th class="px-6 py-3 text-right text-hl-12 font-semibold text-muted uppercase">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-line">
        <% if @users.empty? %>
          <tr>
            <td colspan="7" class="px-6 py-12 text-center text-hl-13 text-muted-4">
              暂无用户数据
            </td>
          </tr>
        <% else %>
          <% @users.each do |user| %>
            <tr class="hover:bg-bg-mute transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center space-x-3">
                  <%= user_avatar_tag(user, size: "w-10 h-10") %>
                  <div>
                    <p class="text-hl-13 font-medium text-ink"><%= user.nickname %></p>
                    <p class="text-hl-12 text-muted-4">#<%= user.id %></p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-hl-13 text-muted-3 truncate max-w-[200px]" title="<%= user.email %>"><%= user.email %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2.5 py-1 rounded text-hl-12 font-medium
                  <%= case user.role
                       when 'super_admin' then 'bg-red-50 text-profit'
                       when 'admin' then 'bg-purple-50 text-purple-700'
                       when 'member' then 'bg-blue-50 text-link'
                       else 'bg-bg-mute text-muted-3'
                     end %>">
                  <%= human_role(user.role) %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-hl-13 text-muted-3">
                  <%= user.member_expire_at.present? ? l(user.member_expire_at.to_date) : '-' %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-hl-13 text-muted-3"><%= l(user.created_at.to_date) %></span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="text-hl-13 text-muted-3">
                  <%= user.last_login_at.present? ? l(user.last_login_at.to_date) : '-' %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <div class="flex items-center justify-end space-x-2">
                  <a href="<%= admin_user_path(user) %>" class="text-hl-13 text-link hover:text-link-hover">查看</a>
                  <a href="<%= edit_admin_user_path(user) %>" class="text-hl-13 text-link hover:text-link-hover">编辑</a>
                  <%= button_to '删除', admin_user_path(user), method: :delete, 
                    class: "text-hl-13 text-profit hover:text-red-700",
                    data: { confirm: "确定删除用户 #{user.nickname} 吗？" },
                    disabled: current_user == user %>
                </div>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @total_pages > 1 %>
    <div class="px-5 py-4 border-t border-line">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-hl-13 text-muted">显示第 <%= (@page - 1) * @per_page + 1 %> 到 <%= [@page * @per_page, @total_count].min %> 条，共 <%= @total_count %> 条记录</p>
        <nav class="flex items-center space-x-1">
          <a href="<%= admin_users_path(page: @page - 1, search: params[:search], role: params[:role]) %>"
            class="hl-btn hl-btn-line text-hl-13 <%= 'opacity-50 cursor-not-allowed' if @page <= 1 %>"
            <%= 'disabled' if @page <= 1 %>>
            上一页
          </a>
          <% (([1, @page - 2].max)..([@total_pages, @page + 2].min)).each do |page_num| %>
            <% if page_num == @page %>
              <a href="<%= admin_users_path(page: page_num, search: params[:search], role: params[:role]) %>"
                class="min-w-[36px] px-3 py-1.5 text-hl-13 font-medium rounded bg-ink text-white">
                <%= page_num %>
              </a>
            <% else %>
              <a href="<%= admin_users_path(page: page_num, search: params[:search], role: params[:role]) %>"
                class="min-w-[36px] px-3 py-1.5 text-hl-13 font-medium rounded border border-line bg-white text-muted hover:bg-bg-mute transition-colors">
                <%= page_num %>
              </a>
            <% end %>
          <% end %>
          <a href="<%= admin_users_path(page: @page + 1, search: params[:search], role: params[:role]) %>"
            class="hl-btn hl-btn-line text-hl-13 <%= 'opacity-50 cursor-not-allowed' if @page >= @total_pages %>"
            <%= 'disabled' if @page >= @total_pages %>>
            下一页
          </a>
        </nav>
      </div>
    </div>
  <% end %>
</div>