<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900">编辑用户</h1>
  <p class="mt-2 text-gray-600">修改用户 <%= @user.nickname %> 的信息</p>
</div>

<div class="bg-white rounded-md border border-gray-200 max-w-2xl mx-auto">
  <div class="px-6 py-4 border-b border-gray-100">
    <h2 class="text-lg font-semibold text-gray-900">用户信息</h2>
  </div>
  <div class="px-6 py-6">
    <%= form_with model: @user, url: admin_user_path(@user), method: :patch, class: "space-y-6" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.email_field :email, required: true,
            class: "w-full px-4 py-2.5 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500" %>
        </div>
        <div>
          <%= f.label :nickname, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.text_field :nickname, required: true,
            class: "w-full px-4 py-2.5 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500" %>
        </div>
        <div>
          <%= f.label :role, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.select :role, [['访客', 'user'], ['会员', 'member'], ['管理员', 'admin'], ['超级管理员', 'super_admin']], required: true,
            class: "w-full px-4 py-2.5 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500" %>
        </div>
        <div>
          <%= f.label :member_expire_at, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.date_field :member_expire_at,
            class: "w-full px-4 py-2.5 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500" %>
        </div>
      </div>

      <div>
        <%= f.label :bio, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= f.text_area :bio, rows: 3, placeholder: '个人简介（可选）',
          class: "w-full px-4 py-2.5 border border-gray-300 rounded-md focus:outline-none focus:border-blue-500 resize-none" %>
      </div>

      <div class="flex space-x-4 pt-4">
        <%= f.submit "保存修改",
          class: "px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 font-medium" %>
        <%= link_to "取消", admin_users_path,
          class: "px-6 py-2 bg-white border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 font-medium" %>
      </div>
    <% end %>
  </div>
</div>