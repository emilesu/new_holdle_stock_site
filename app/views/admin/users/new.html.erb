<div class="min-h-screen bg-gray-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">添加用户</h1>
      <p class="mt-2 text-gray-600">创建新的用户账号</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900">用户信息</h2>
      </div>
      <div class="px-6 py-6">
        <%= form_with model: @user, url: admin_users_path, class: "space-y-6" do |f| %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.email_field :email, required: true,
                class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
            </div>
            <div>
              <%= f.label :nickname, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.text_field :nickname, required: true,
                class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
            </div>
            <div>
              <%= f.label :role, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.select :role, [['普通用户', 'user'], ['会员', 'member'], ['管理员', 'admin'], ['超级管理员', 'super_admin']], required: true,
                class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
            </div>
            <div>
              <%= f.label :member_expire_at, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.date_field :member_expire_at,
                class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
            </div>
          </div>

          <div>
            <%= f.label :bio, class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= f.text_area :bio, rows: 3, placeholder: '个人简介（可选）',
              class: "w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none" %>
          </div>

          <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
            <p class="text-sm text-amber-700">
              <svg class="w-4 h-4 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              系统将自动生成8位随机密码，并发送至用户邮箱
            </p>
          </div>

          <div class="flex space-x-4 pt-4">
            <%= f.submit "创建用户",
              class: "px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium" %>
            <%= link_to "取消", admin_users_path,
              class: "px-6 py-2.5 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors font-medium" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
