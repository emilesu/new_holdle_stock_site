<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">股票管理</h1>
      <p class="mt-2 text-gray-600">管理平台所有股票数据</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-6">
      <div class="px-6 py-4 border-b border-gray-100">
        <div class="flex flex-col sm:flex-row gap-4">
          <div class="flex-1 relative">
            <input type="text" name="search" placeholder="搜索股票代码或名称..." value="<%= params[:search] %>"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              onkeydown="if(event.key === 'Enter') { this.form.submit(); }">
          </div>
          <div class="flex gap-2">
            <select name="market" class="px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
              <option value="all" <%= 'selected' if params[:market].blank? || params[:market] == 'all' %>>全部市场</option>
              <option value="CN" <%= 'selected' if params[:market] == 'CN' %>>A股</option>
              <option value="US" <%= 'selected' if params[:market] == 'US' %>>美股</option>
            </select>
            <button type="submit" class="px-4 py-2.5 bg-gray-800 text-white rounded-lg hover:bg-gray-900 transition-colors">
              筛选
            </button>
            <a href="<%= new_admin_stock_path %>" class="px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors whitespace-nowrap">
              <svg class="w-5 h-5 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
              添加股票
            </a>
          </div>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">股票代码</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">名称</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">市场</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">行业</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">交易所</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">状态</th>
              <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">操作</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% if @stocks.empty? %>
              <tr>
                <td colspan="7" class="px-6 py-12 text-center text-gray-500">
                  暂无股票数据
                </td>
              </tr>
            <% else %>
              <% @stocks.each do |stock| %>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="font-medium text-gray-900"><%= stock.symbol %></span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="text-gray-600"><%= stock.name %></span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold
                      <%= stock.market == 'CN' ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800' %>">
                      <%= stock.market == 'CN' ? 'A股' : '美股' %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="text-gray-600 truncate max-w-[150px]" title="<%= stock.sector.presence || stock.industry %>">
                      <%= stock.sector.presence || stock.industry || '-' %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="text-gray-600"><%= stock.exchange.presence || '-' %></span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold
                      <%= stock.status == 'active' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                      <%= stock.status == 'active' ? '活跃' : '暂停' %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right">
                    <div class="flex items-center justify-end space-x-2">
                      <a href="<%= admin_stock_path(stock) %>" class="text-blue-600 hover:text-blue-700 text-sm font-medium">查看</a>
                      <a href="<%= edit_admin_stock_path(stock) %>" class="text-indigo-600 hover:text-indigo-700 text-sm font-medium">编辑</a>
                      <%= button_to '删除', admin_stock_path(stock), method: :delete, 
                        class: "text-red-600 hover:text-red-700 text-sm font-medium",
                        data: { confirm: "确定删除股票 #{stock.symbol} 吗？" } %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @total_pages > 1 %>
        <div class="px-6 py-4 border-t border-gray-100">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-sm text-gray-600">
              显示第 <%= (@page - 1) * @per_page + 1 %> 到 <%= [@page * @per_page, @total_count].min %> 条，共 <%= @total_count %> 条记录
            </p>
            <nav class="flex items-center space-x-1">
              <a href="<%= admin_stocks_path(page: @page - 1, search: params[:search], market: params[:market]) %>"
                class="px-3 py-1.5 text-sm font-medium rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                <%= 'disabled' if @page <= 1 %>>
                上一页
              </a>
              <% (([1, @page - 2].max)..([@total_pages, @page + 2].min)).each do |page_num| %>
                <% if page_num == @page %>
                  <a href="<%= admin_stocks_path(page: page_num, search: params[:search], market: params[:market]) %>"
                    class="min-w-[36px] px-3 py-1.5 text-sm font-medium rounded-lg border bg-blue-600 border-blue-600 text-white shadow-sm">
                    <%= page_num %>
                  </a>
                <% else %>
                  <a href="<%= admin_stocks_path(page: page_num, search: params[:search], market: params[:market]) %>"
                    class="min-w-[36px] px-3 py-1.5 text-sm font-medium rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors">
                    <%= page_num %>
                  </a>
                <% end %>
              <% end %>
              <a href="<%= admin_stocks_path(page: @page + 1, search: params[:search], market: params[:market]) %>"
                class="px-3 py-1.5 text-sm font-medium rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                <%= 'disabled' if @page >= @total_pages %>>
                下一页
              </a>
            </nav>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
