<div id="admin-stocks-page">
  <div class="mb-6">
    <h1 class="text-hl-22 font-bold text-ink">股票管理</h1>
    <p class="mt-1 text-hl-13 text-muted-3">共 <%= @total_count %> 只股票</p>
  </div>

  <%= form_with url: admin_stocks_path, method: :get, class: 'hl-card p-4 mb-6', data: { controller: 'market-sector' } do |f| %>
    <div class="flex flex-wrap gap-4 items-center">
      <div class="flex items-center gap-2">
        <label class="text-hl-13 font-medium text-muted w-12 shrink-0">市场</label>
        <select name="market" id="market-filter" class="px-3 py-2 text-hl-13 border border-line rounded bg-white"
                data-market-sector-target="market" data-action="change->market-sector#changeMarket">
          <option value="CN" <%= 'selected' if @market == 'CN' %>>A股</option>
          <option value="HK" <%= 'selected' if @market == 'HK' %>>港股</option>
          <option value="US" <%= 'selected' if @market == 'US' %>>美股</option>
        </select>
      </div>

      <div class="flex items-center gap-2">
        <label class="text-hl-13 font-medium text-muted w-12 shrink-0">行业</label>
        <select name="sector" id="sector-filter" class="px-3 py-2 text-hl-13 border border-line rounded bg-white"
                data-market-sector-target="sector" data-current-sector="<%= @sector %>">
          <option value="">全部</option>
          <% @sectors.each do |sector| %>
            <option value="<%= sector %>" <%= 'selected' if @sector == sector %>><%= sector %></option>
          <% end %>
        </select>
      </div>

      <div class="flex items-center gap-2">
        <label class="text-hl-13 font-medium text-muted w-20 shrink-0">分数区间</label>
        <input type="number" name="pyramid_min" id="pyramid-min" value="<%= @pyramid_min %>" placeholder="最低分" 
               class="px-3 py-2 text-hl-13 border border-line rounded w-20">
        <span class="text-muted-4">-</span>
        <input type="number" name="pyramid_max" id="pyramid-max" value="<%= @pyramid_max %>" placeholder="最高分" 
               class="px-3 py-2 text-hl-13 border border-line rounded w-20">
      </div>

      <%= f.hidden_field :page, value: 1 %>

      <button type="submit" class="hl-btn hl-btn-primary flex items-center">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        筛选
      </button>
    </div>
  <% end %>

  <div class="hl-card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full hl-table">
        <thead>
          <tr>
            <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">股票代码</th>
            <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">名称</th>
            <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">市场</th>
            <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">行业</th>
            <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">金字塔总分</th>
            <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">上次计算</th>
            <th class="px-6 py-3 text-left text-hl-12 font-semibold text-muted uppercase">操作</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-line">
          <% @stocks.each do |stock| %>
            <%= render partial: 'admin/stocks/stock_row', locals: { stock: stock } %>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="bg-bg-mute px-6 py-3 flex items-center justify-between border-t border-line">
      <span class="text-hl-13 text-muted">
        显示 <span class="font-semibold text-ink"><%= [(@page - 1) * 20 + 1, @total_count].min %></span> 
        - <span class="font-semibold text-ink"><%= [@page * 20, @total_count].min %></span> 条
      </span>
      
      <nav class="flex items-center space-x-1" aria-label="分页导航">
        <a href="<%= admin_stocks_path(page: [@page - 1, 1].max, market: @market, sector: @sector, pyramid_min: @pyramid_min, pyramid_max: @pyramid_max) %>" 
           class="px-3 py-2 text-hl-13 bg-white border border-line rounded hover:bg-bg-mute text-muted transition-colors"
           <%= 'aria-disabled="true"' if @page <= 1 %>>
          <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          上一页
        </a>
        
        <% (1..@total_pages).to_a.each do |page_num| %>
          <% if page_num == @page %>
            <span class="px-3 py-2 text-hl-13 bg-ink text-white rounded font-medium"><%= page_num %></span>
          <% elsif page_num >= @page - 2 && page_num <= @page + 2 %>
            <a href="<%= admin_stocks_path(page: page_num, market: @market, sector: @sector, pyramid_min: @pyramid_min, pyramid_max: @pyramid_max) %>" 
               class="px-3 py-2 text-hl-13 bg-white border border-line rounded hover:bg-bg-mute text-muted transition-colors">
              <%= page_num %>
            </a>
          <% end %>
        <% end %>
        
        <a href="<%= admin_stocks_path(page: [@page + 1, @total_pages].min, market: @market, sector: @sector, pyramid_min: @pyramid_min, pyramid_max: @pyramid_max) %>" 
           class="px-3 py-2 text-hl-13 bg-white border border-line rounded hover:bg-bg-mute text-muted transition-colors"
           <%= 'aria-disabled="true"' if @page >= @total_pages %>>
          下一页
          <svg class="w-4 h-4 inline-block ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </nav>
    </div>
  </div>
</div>