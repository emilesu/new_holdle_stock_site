<div class="mb-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">添加股票</h1>
      <p class="mt-1 text-sm text-gray-500">创建新的股票数据</p>
    </div>
    <%= link_to "返回列表", admin_stocks_path, class: "text-sm text-gray-600 hover:text-gray-800" %>
  </div>
</div>

<div class="bg-white rounded-md border border-gray-200 max-w-2xl mx-auto">
  <div class="px-6 py-4 border-b border-gray-100">
    <h2 class="text-base font-semibold text-gray-900">股票信息</h2>
  </div>
  <div class="px-6 py-6">
    <%= form_with model: @stock, url: admin_stocks_path, class: "space-y-6" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= f.label :symbol, '股票代码', class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :symbol, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
        </div>
        <div>
          <%= f.label :name, '股票名称', class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
        </div>
        <div>
          <%= f.label :market, '市场', class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :market, [['A股', 'A股'], ['美股', '美股']], {}, class: "w-full px-3 py-2 border border-gray-300 rounded-md bg-white" %>
        </div>
        <div>
          <%= f.label :exchange, '交易所', class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :exchange, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
        </div>
        <div>
          <%= f.label :sector, '板块', class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :sector, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
        </div>
        <div>
          <%= f.label :industry, '行业', class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :industry, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
        </div>
      </div>

      <div>
        <%= f.label :website, '网站', class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.url_field :website, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
      </div>

      <div>
        <%= f.label :description, '描述', class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :description, rows: 4, class: "w-full px-3 py-2 border border-gray-300 rounded-md resize-none" %>
      </div>

      <div>
        <%= f.label :status, '状态', class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :status, [['活跃', 'active'], ['暂停', 'inactive']], {}, class: "w-full px-3 py-2 border border-gray-300 rounded-md bg-white" %>
      </div>

      <div class="flex space-x-3 pt-2">
        <%= f.submit "保存", class: "px-5 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors font-medium" %>
        <%= link_to "取消", admin_stocks_path, class: "px-5 py-2 bg-white border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition-colors font-medium" %>
      </div>
    <% end %>
  </div>
</div>