<div class="min-h-screen bg-gray-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">股票详情</h1>
      <p class="mt-2 text-gray-600">查看股票 <%= @stock.symbol %> 的详细信息</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 mb-6">
      <div class="px-6 py-4 border-b border-gray-100">
        <div class="flex items-center justify-between">
          <div>
            <span class="text-2xl font-bold text-gray-900"><%= @stock.symbol %></span>
            <span class="ml-3 text-lg text-gray-600"><%= @stock.name %></span>
          </div>
          <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-semibold
            <%= @stock.market == 'A股' ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800' %>">
            <%= @stock.market %>
          </span>
        </div>
      </div>

      <div class="px-6 py-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-gray-50 rounded-xl p-5">
            <h3 class="text-sm font-medium text-gray-500 mb-4">基本信息</h3>
            <div class="space-y-3">
              <div class="flex justify-between">
                <span class="text-gray-500">交易所</span>
                <span class="font-medium text-gray-900"><%= @stock.exchange.presence || '-' %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">行业</span>
                <span class="font-medium text-gray-900"><%= @stock.sector.presence || @stock.industry || '-' %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">状态</span>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold
                  <%= @stock.status == 'active' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= @stock.status == 'active' ? '活跃' : '暂停' %>
                </span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">创建时间</span>
                <span class="font-medium text-gray-900"><%= l(@stock.created_at, format: :long) %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">更新时间</span>
                <span class="font-medium text-gray-900"><%= l(@stock.updated_at, format: :long) %></span>
              </div>
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-5">
            <h3 class="text-sm font-medium text-gray-500 mb-4">扩展信息</h3>
            <div class="space-y-3">
              <div>
                <span class="text-gray-500 block mb-1">官网</span>
                <% if @stock.website.present? %>
                  <a href="<%= @stock.website %>" target="_blank" class="font-medium text-blue-600 hover:text-blue-700 truncate" title="<%= @stock.website %>">
                    <%= @stock.website %>
                  </a>
                <% else %>
                  <span class="text-gray-400">-</span>
                <% end %>
              </div>
              <div>
                <span class="text-gray-500 block mb-1">描述</span>
                <p class="text-gray-900 leading-relaxed min-h-[60px]">
                  <%= @stock.description.presence || '<span class="text-gray-400">暂无描述</span>'.html_safe %>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="flex space-x-4">
      <%= link_to "编辑", edit_admin_stock_path(@stock),
        class: "px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium" %>
      <%= link_to "返回列表", admin_stocks_path,
        class: "px-6 py-2.5 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition-colors font-medium" %>
    </div>
  </div>
</div>
