<div class="mb-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">股票详情</h1>
      <p class="mt-1 text-sm text-gray-500"><%= @stock.symbol %> 基本信息</p>
    </div>
    <div class="flex items-center space-x-2">
      <%= link_to "编辑", edit_admin_stock_path(@stock), class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors text-sm font-medium" %>
      <%= link_to "返回列表", admin_stocks_path, class: "px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition-colors text-sm font-medium" %>
    </div>
  </div>
</div>

<div class="bg-white rounded-md border border-gray-200 mb-6">
  <div class="px-6 py-4 border-b border-gray-100">
    <div class="flex items-center justify-between">
      <div>
        <span class="text-2xl font-bold text-gray-900"><%= @stock.symbol %></span>
        <span class="ml-3 text-lg text-gray-600"><%= @stock.name %></span>
      </div>
      <span class="inline-flex items-center px-3 py-1 rounded-md text-sm font-medium
        <%= @stock.market == 'A股' ? 'bg-green-50 text-green-700' : 'bg-blue-50 text-blue-700' %>">
        <%= @stock.market %>
      </span>
    </div>
  </div>

  <div class="px-6 py-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-gray-50 rounded-md p-5">
        <h3 class="text-sm font-medium text-gray-500 mb-4">基本信息</h3>
        <div class="space-y-3">
          <div class="flex justify-between">
            <span class="text-gray-500">交易所</span>
            <span class="font-medium text-gray-900"><%= @stock.exchange.presence || '-' %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">行业</span>
            <span class="font-medium text-gray-900"><%= @stock.sector.presence || @stock.industry || '-' %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">状态</span>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
              <%= @stock.status == 'active' ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-600' %>">
              <%= @stock.status == 'active' ? '活跃' : '暂停' %>
            </span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">创建时间</span>
            <span class="font-medium text-gray-900"><%= l(@stock.created_at, format: :long) %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">更新时间</span>
            <span class="font-medium text-gray-900"><%= l(@stock.updated_at, format: :long) %></span>
          </div>
        </div>
      </div>

      <div class="bg-gray-50 rounded-md p-5">
        <h3 class="text-sm font-medium text-gray-500 mb-4">扩展信息</h3>
        <div class="space-y-3">
          <div>
            <span class="text-gray-500 block mb-1">官网</span>
            <% if @stock.website.present? %>
              <a href="<%= @stock.website %>" target="_blank" class="font-medium text-blue-600 hover:text-blue-700 truncate" title="<%= @stock.website %>">
                <%= @stock.website %>
              </a>
            <% else %>
              <span class="text-gray-400">-</span>
            <% end %>
          </div>
          <div>
            <span class="text-gray-500 block mb-1">描述</span>
            <p class="text-gray-900 leading-relaxed min-h-[60px]">
              <%= @stock.description.presence || '<span class="text-gray-400">暂无描述</span>'.html_safe %>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="flex space-x-3">
  <%= link_to "编辑", edit_admin_stock_path(@stock), class: "px-5 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors font-medium" %>
  <%= link_to "返回列表", admin_stocks_path, class: "px-5 py-2 bg-white border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition-colors font-medium" %>
</div>