<tr id="stock-<%= stock.id %>" class="hover:bg-blue-50 cursor-pointer transition-colors">
  <td class="px-6 py-3 whitespace-nowrap">
    <div class="text-sm font-medium text-blue-600">
      <%= link_to stock.symbol, stock_path(stock) %>
    </div>
  </td>
  <td class="px-6 py-3 whitespace-nowrap">
    <div class="text-sm text-gray-900">
      <%= stock.market == 'US' && stock.name&.include?('|') ? stock.name.split('|').first.strip : stock.name %>
    </div>
  </td>
  <td class="px-6 py-3 whitespace-nowrap">
    <span class="px-2 py-1 text-xs font-semibold rounded <%= stock.market == 'CN' ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800' %>">
      <%= stock.market == 'CN' ? 'A股' : '美股' %>
    </span>
  </td>
  <td class="px-6 py-3 whitespace-nowrap">
    <span class="px-2 py-1 text-xs font-semibold rounded <%= stock.market == 'CN' ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800' %>">
      <%= stock.sector.presence || '-' %>
    </span>
  </td>
  <td class="px-6 py-3 whitespace-nowrap">
    <div class="text-sm font-medium text-indigo-600"><%= stock.pyramid_total_score %></div>
  </td>
  <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">
    <%= stock.last_pyramid_calc_at ? stock.last_pyramid_calc_at.strftime('%Y-%m-%d %H:%M') : '未计算' %>
  </td>
  <td class="px-6 py-3 whitespace-nowrap text-sm font-medium">
    <% if current_user.is_admin? %>
      <button type="button" 
              class="recalc-btn text-green-600 hover:text-green-900 px-3 py-1.5 border border-green-300 rounded-lg hover:bg-green-50 transition-colors"
              data-stock-id="<%= stock.id %>"
              onclick="recalculatePyramid(this, <%= stock.id %>)">
        重新计算
      </button>
    <% end %>
  </td>
</tr>