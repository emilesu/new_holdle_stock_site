<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">数据统计看板</h1>
  <p class="mt-1 text-sm text-gray-500">实时监控平台核心数据指标</p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4 mb-6">
  <div class="bg-white rounded-md border border-gray-200 p-4">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs font-medium text-gray-500">A股股票</p>
        <p class="mt-1 text-xl font-bold text-gray-900"><%= @a_stock_count %></p>
      </div>
      <div class="w-10 h-10 bg-green-50 rounded-md flex items-center justify-center">
        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
        </svg>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-md border border-gray-200 p-4">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs font-medium text-gray-500">美股股票</p>
        <p class="mt-1 text-xl font-bold text-gray-900"><%= @us_stock_count %></p>
      </div>
      <div class="w-10 h-10 bg-blue-50 rounded-md flex items-center justify-center">
        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
        </svg>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-md border border-gray-200 p-4">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs font-medium text-gray-500">总股票数</p>
        <p class="mt-1 text-xl font-bold text-gray-900"><%= @total_stocks %></p>
      </div>
      <div class="w-10 h-10 bg-purple-50 rounded-md flex items-center justify-center">
        <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-md border border-gray-200 p-4">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs font-medium text-gray-500">注册用户</p>
        <p class="mt-1 text-xl font-bold text-gray-900"><%= @total_users %></p>
      </div>
      <div class="w-10 h-10 bg-orange-50 rounded-md flex items-center justify-center">
        <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-md border border-gray-200 p-4">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs font-medium text-gray-500">日活用户</p>
        <p class="mt-1 text-xl font-bold text-gray-900"><%= @today_active_users %></p>
      </div>
      <div class="w-10 h-10 bg-cyan-50 rounded-md flex items-center justify-center">
        <svg class="w-5 h-5 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-md border border-gray-200 p-4">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs font-medium text-gray-500">周活用户</p>
        <p class="mt-1 text-xl font-bold text-gray-900"><%= @week_active_users %></p>
      </div>
      <div class="w-10 h-10 bg-indigo-50 rounded-md flex items-center justify-center">
        <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  <div class="bg-white rounded-md border border-gray-200">
    <div class="px-5 py-4 border-b border-gray-100">
      <h3 class="text-base font-semibold text-gray-900">今日新增</h3>
    </div>
    <div class="p-5 grid grid-cols-2 gap-4">
      <div class="bg-blue-50 rounded-md p-4">
        <p class="text-xs text-blue-600">新用户</p>
        <p class="mt-1 text-2xl font-bold text-blue-800"><%= @today_registered_users %></p>
      </div>
      <div class="bg-green-50 rounded-md p-4">
        <p class="text-xs text-green-600">会员用户</p>
        <p class="mt-1 text-2xl font-bold text-green-800"><%= @member_count %></p>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-md border border-gray-200">
    <div class="px-5 py-4 border-b border-gray-100">
      <h3 class="text-base font-semibold text-gray-900">管理员统计</h3>
    </div>
    <div class="p-5 flex items-center justify-center">
      <div class="text-center">
        <div class="w-20 h-20 bg-red-500 rounded-full flex items-center justify-center mx-auto mb-3">
          <span class="text-2xl font-bold text-white"><%= @admin_count %></span>
        </div>
        <p class="text-sm text-gray-500">系统管理员</p>
      </div>
    </div>
  </div>
</div>

<div class="mb-6">
  <h2 class="text-lg font-bold text-gray-900 mb-1">快捷功能入口</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <a href="<%= admin_stocks_path %>" class="block bg-green-600 rounded-md p-5 text-white hover:bg-green-700 transition-colors">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-base font-bold">股票管理</h3>
          <p class="mt-1 text-xs text-green-100">管理A股和美股股票数据</p>
        </div>
        <div class="w-10 h-10 bg-white/20 rounded-md flex items-center justify-center">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
      </div>
    </a>

    <a href="<%= admin_users_path %>" class="block bg-blue-600 rounded-md p-5 text-white hover:bg-blue-700 transition-colors">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-base font-bold">用户管理</h3>
          <p class="mt-1 text-xs text-blue-100">管理平台注册用户</p>
        </div>
        <div class="w-10 h-10 bg-white/20 rounded-md flex items-center justify-center">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
      </div>
    </a>

    <a href="<%= admin_stock_crawlers_path %>" class="block bg-purple-600 rounded-md p-5 text-white hover:bg-purple-700 transition-colors">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-base font-bold">爬虫管理</h3>
          <p class="mt-1 text-xs text-purple-100">管理股票数据爬虫任务</p>
        </div>
        <div class="w-10 h-10 bg-white/20 rounded-md flex items-center justify-center">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
        </div>
      </div>
    </a>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-white rounded-md border border-gray-200">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <h3 class="text-base font-semibold text-gray-900">最近注册用户</h3>
      <a href="<%= admin_users_path %>" class="text-sm text-blue-600 hover:text-blue-700">查看全部</a>
    </div>
    <div class="divide-y divide-gray-50">
      <% @recent_users.each do |user| %>
        <div class="px-5 py-3 flex items-center justify-between hover:bg-gray-50 transition-colors">
          <div class="flex items-center space-x-3">
            <div class="w-9 h-9 rounded-full bg-blue-500 flex items-center justify-center text-white font-semibold text-sm">
              <%= user.avatar_char %>
            </div>
            <div>
              <p class="text-sm font-medium text-gray-900"><%= user.nickname %></p>
              <p class="text-xs text-gray-500"><%= user.email %></p>
            </div>
          </div>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
            <%= case user.role
                 when 'super_admin' then 'bg-red-50 text-red-700'
                 when 'admin' then 'bg-purple-50 text-purple-700'
                 when 'member' then 'bg-blue-50 text-blue-700'
                 else 'bg-gray-100 text-gray-600'
               end %>">
            <%= user.role.humanize %>
          </span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-md border border-gray-200">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <h3 class="text-base font-semibold text-gray-900">最近添加股票</h3>
      <a href="<%= admin_stocks_path %>" class="text-sm text-blue-600 hover:text-blue-700">查看全部</a>
    </div>
    <div class="divide-y divide-gray-50">
      <% @recent_stocks.each do |stock| %>
        <div class="px-5 py-3 flex items-center justify-between hover:bg-gray-50 transition-colors">
          <div>
            <p class="text-sm font-medium text-gray-900"><%= stock.symbol %></p>
            <p class="text-xs text-gray-500"><%= stock.name %></p>
          </div>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
            <%= stock.market == 'A股' ? 'bg-green-50 text-green-700' : 'bg-blue-50 text-blue-700' %>">
            <%= stock.market %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
</div>