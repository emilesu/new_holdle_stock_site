<div class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <div class="bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 px-6 py-10">
        <div class="flex items-center space-x-6">
          <div class="relative">
            <div class="w-28 h-28 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-white text-5xl font-bold shadow-2xl">
              <%= @user.avatar_char %>
            </div>
          </div>
          <div class="text-white">
            <h1 class="text-3xl font-bold tracking-tight">编辑个人资料</h1>
            <p class="text-blue-100 mt-2 text-lg"><%= @user.nickname %></p>
          </div>
        </div>
      </div>

      <div class="px-6 py-6">
        <div class="flex border-b border-gray-200 mb-6">
          <nav class="flex space-x-8">
            <a href="<%= users_profile_path %>" class="pb-3 text-gray-500 hover:text-gray-700 transition-colors">基本信息</a>
            <a href="<%= users_profile_favorites_path %>" class="pb-3 text-gray-500 hover:text-gray-700 transition-colors">我的收藏</a>
          </nav>
        </div>

        <%= form_with model: @user, url: users_profile_path, method: :patch, class: "space-y-6" do |f| %>
          <div class="bg-gray-50 rounded-xl p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">基本信息</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <%= f.label :nickname, class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.text_field :nickname, 
                  class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-white" %>
                <% if @user.errors[:nickname].any? %>
                  <p class="mt-1.5 text-sm text-red-500"><%= @user.errors[:nickname].first %></p>
                <% end %>
              </div>
              <div>
                <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.email_field :email, disabled: true, 
                  class: "w-full px-4 py-3 border border-gray-300 rounded-xl bg-gray-200 text-gray-500 cursor-not-allowed" %>
              </div>
            </div>

            <div class="mt-6">
              <%= f.label :bio, class: "block text-sm font-medium text-gray-700 mb-2" %>
              <%= f.text_area :bio, rows: 4, 
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-white resize-none" %>
              <% if @user.errors[:bio].any? %>
                <p class="mt-1.5 text-sm text-red-500"><%= @user.errors[:bio].first %></p>
              <% end %>
            </div>
          </div>

          <div class="flex space-x-4">
            <%= f.submit "保存修改", 
              class: "inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition-all duration-200 shadow-md hover:shadow-lg font-medium" %>
            <%= link_to "取消", users_profile_path, 
              class: "inline-flex items-center px-6 py-3 bg-gray-200 text-gray-700 rounded-xl hover:bg-gray-300 transition-all duration-200 font-medium" %>
          </div>
        <% end %>

        <div class="mt-8 pt-8 border-t border-gray-200">
          <div class="bg-gray-50 rounded-xl p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">修改密码</h3>
            
            <%= form_with model: @user, url: users_update_profile_password_path, method: :patch, class: "space-y-4" do |f| %>
              <div>
                <%= f.label :current_password, class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.password_field :current_password, autocomplete: "current-password",
                  class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 bg-white" %>
                <% if @user.errors[:current_password].any? %>
                  <p class="mt-1.5 text-sm text-red-500"><%= @user.errors[:current_password].first %></p>
                <% end %>
              </div>
              <div>
                <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.password_field :password, autocomplete: "new-password",
                  class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 bg-white" %>
                <% if @user.errors[:password].any? %>
                  <p class="mt-1.5 text-sm text-red-500"><%= @user.errors[:password].first %></p>
                <% end %>
              </div>
              <div>
                <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-2" %>
                <%= f.password_field :password_confirmation, autocomplete: "new-password",
                  class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 bg-white" %>
                <% if @user.errors[:password_confirmation].any? %>
                  <p class="mt-1.5 text-sm text-red-500"><%= @user.errors[:password_confirmation].first %></p>
                <% end %>
              </div>

              <div class="mt-6">
                <%= f.submit "修改密码", 
                  class: "inline-flex items-center px-6 py-3 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition-all duration-200 shadow-md hover:shadow-lg font-medium" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
