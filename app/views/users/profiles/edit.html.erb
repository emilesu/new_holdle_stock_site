<% set_page_title "编辑个人资料 - Holdle" %>
<div class="py-16 bg-bg-soft min-h-screen">
  <div class="container-narrow">

    <div class="hl-card overflow-hidden">

      <%# 用户头部 %>
      <div class="bg-ink px-6 sm:px-8 py-8">
        <div class="flex items-center gap-5">
          <%= user_avatar_tag(@user, size: "w-20 h-20", css_class: "text-hl-22") %>
          <div class="min-w-0">
            <h1 class="text-hl-18 font-semibold text-white">编辑个人资料</h1>
            <p class="text-hl-13 text-white/60 mt-0.5"><%= @user.nickname %></p>
          </div>
        </div>
      </div>

      <%# 导航标签 %>
      <div class="flex border-b border-line px-6 sm:px-8">
        <nav class="flex gap-6">
          <a href="<%= users_profile_path %>" class="pb-3 text-muted-3 hover:text-ink transition-colors text-hl-13">基本信息</a>
          <a href="<%= users_profile_favorites_path %>" class="pb-3 text-muted-3 hover:text-ink transition-colors text-hl-13">我的收藏</a>
        </nav>
      </div>

      <%# 基本信息编辑 %>
      <div class="p-6 sm:p-8">
        <%= form_with model: @user, url: users_profile_path, method: :patch, class: "space-y-5" do |f| %>
          <div class="bg-bg-soft rounded p-5">
            <h2 class="text-hl-16 font-semibold text-ink mb-4">基本信息</h2>

            <div>
              <%= f.label :nickname, class: "block text-hl-13 font-medium text-muted mb-1.5" %>
              <%= f.text_field :nickname,
                class: "w-full px-4 py-2.5 border border-line rounded text-hl-14 text-ink placeholder:text-muted-4 bg-white focus:outline-none focus:border-muted-3 transition-colors" %>
              <% if @user.errors[:nickname].any? %>
                <p class="mt-1 text-hl-12 text-profit"><%= @user.errors[:nickname].first %></p>
              <% end %>
            </div>

            <div class="mt-4">
              <%= f.label :bio, class: "block text-hl-13 font-medium text-muted mb-1.5" %>
              <%= f.text_area :bio, rows: 4,
                class: "w-full px-4 py-2.5 border border-line rounded text-hl-14 text-ink placeholder:text-muted-4 bg-white focus:outline-none focus:border-muted-3 transition-colors resize-none" %>
              <% if @user.errors[:bio].any? %>
                <p class="mt-1 text-hl-12 text-profit"><%= @user.errors[:bio].first %></p>
              <% end %>
            </div>
          </div>

          <div class="flex flex-wrap gap-3">
            <%= f.submit "保存修改", class: "hl-btn hl-btn-primary" %>
            <%= link_to "取消", users_profile_path, class: "hl-btn hl-btn-line" %>
          </div>
        <% end %>

        <%# 修改密码功能已移除（当前主要用微信登陆，暂不需要邮箱和密码功能） %>
      </div>

    </div>
  </div>
</div>