<div class="py-16 bg-bg-soft min-h-screen">
  <div class="container-narrow">

    <div class="hl-card overflow-hidden">

      <%# 用户头部 %>
      <div class="bg-ink px-6 sm:px-8 py-8">
        <div class="flex items-center gap-5">
          <%= user_avatar_tag(@user, size: "w-20 h-20", css_class: "text-hl-22") %>
          <div class="min-w-0">
            <h1 class="text-hl-18 font-semibold text-white">我的收藏</h1>
            <p class="text-hl-13 text-white/60 mt-0.5"><%= @user.nickname %> 的收藏股票</p>
          </div>
        </div>
      </div>

      <%# 导航标签 %>
      <div class="flex border-b border-line px-6 sm:px-8">
        <nav class="flex gap-6">
          <a href="<%= users_profile_path %>" class="pb-3 text-muted-3 hover:text-ink transition-colors text-hl-13">基本信息</a>
          <a href="<%= users_profile_favorites_path %>" class="pb-3 border-b-2 border-ink text-ink font-medium text-hl-13">我的收藏</a>
        </nav>
      </div>

      <%# 收藏列表 %>
      <div class="p-6 sm:p-8">
        <% if @favorites.empty? %>
          <div class="py-12 text-center">
            <p class="text-hl-14 text-muted-4 font-medium">暂无收藏的股票</p>
            <p class="text-hl-13 text-muted-5 mt-1">去股票详情页添加收藏吧</p>
          </div>
        <% else %>
          <div class="grid gap-4 sm:grid-cols-1 md:grid-cols-2">
            <% @favorites.each do |favorite| %>
              <% stock = favorite.stock %>
              <div id="favorite_card_<%= stock.id %>" class="hl-card overflow-hidden hover:shadow-md transition-shadow">
                <a href="<%= stock_path(stock) %>" class="block p-5">
                  <div class="flex items-start justify-between">
                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2">
                        <h3 class="text-hl-15 font-semibold text-ink truncate"><%= stock.display_name_for_comparison %></h3>
                        <span class="hl-tag shrink-0"><%= stock.symbol %></span>
                      </div>
                      <div class="flex items-center gap-3 mt-2">
                        <span class="hl-tag"><%= stock.market == 'CN' ? 'A股' : stock.market == 'US' ? '美股' : stock.market %></span>
                        <span class="text-hl-12 text-muted-4"><%= stock.sector.presence || stock.industry.presence || '-' %></span>
                      </div>
                      <% if current_user.is_member? && stock.pyramid_total_score > 0 %>
                        <div class="mt-3 flex items-center gap-2">
                          <span class="text-hl-12 text-muted-4">金字塔评分</span>
                          <span class="text-hl-14 font-semibold <%= stock.pyramid_total_score >= 70 ? 'text-green-600' : stock.pyramid_total_score >= 40 ? 'text-yellow-600' : 'text-red-500' %>">
                            <%= stock.pyramid_total_score %>
                          </span>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </a>
                <div class="px-5 pb-4 border-t border-line-soft pt-3 flex items-center justify-between">
                  <span class="text-hl-12 text-muted-5">收藏于 <%= l(favorite.created_at, format: :short) %></span>
                  <%= button_to "取消收藏", user_favorite_path(favorite, stock_id: stock.id), method: :delete,
                    class: "text-hl-13 text-link hover:text-link-hover transition-colors",
                    form: { data: { turbo_confirm: "确定取消收藏 #{stock.symbol} 吗？" } } %>
                </div>
              </div>
            <% end %>
          </div>

          <% if @favorites.total_pages > 1 %>
            <div class="mt-8 flex justify-center">
              <%= paginate @favorites %>
            </div>
          <% end %>
        <% end %>
      </div>

    </div>
  </div>
</div>