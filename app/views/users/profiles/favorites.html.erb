<div class="py-16 bg-bg-soft min-h-screen">
  <div class="container-narrow">

    <div class="hl-card overflow-hidden">

      <%# 用户头部 %>
      <div class="bg-ink px-6 sm:px-8 py-8">
        <div class="flex items-center gap-5">
          <div class="w-20 h-20 rounded-full bg-white/10 flex items-center justify-center text-white text-hl-22 font-bold shrink-0">
            <%= @user.avatar_char || "U" %>
          </div>
          <div class="min-w-0">
            <h1 class="text-hl-18 font-semibold text-white">我的收藏</h1>
            <p class="text-hl-13 text-white/60 mt-0.5"><%= @user.nickname %> 的收藏股票</p>
          </div>
        </div>
      </div>

      <%# 导航标签 %>
      <div class="flex border-b border-line px-6 sm:px-8">
        <nav class="flex gap-6">
          <a href="<%= users_profile_path %>" class="pb-3 text-muted-3 hover:text-ink transition-colors text-hl-13">基本信息</a>
          <a href="<%= users_profile_favorites_path %>" class="pb-3 border-b-2 border-ink text-ink font-medium text-hl-13">我的收藏</a>
        </nav>
      </div>

      <%# 收藏列表 %>
      <div class="p-6 sm:p-8">
        <% if @favorite_stocks.empty? %>
          <div class="py-12 text-center">
            <p class="text-hl-14 text-muted-4 font-medium">暂无收藏的股票</p>
            <p class="text-hl-13 text-muted-5 mt-1">去股票列表页面添加收藏吧</p>
          </div>
        <% else %>
          <div class="overflow-x-auto">
            <table class="w-full hl-table">
              <thead>
                <tr>
                  <th class="text-hl-12 font-semibold text-muted-4 uppercase tracking-wide-2 px-4 py-3 text-left">股票代码</th>
                  <th class="text-hl-12 font-semibold text-muted-4 uppercase tracking-wide-2 px-4 py-3 text-left">名称</th>
                  <th class="text-hl-12 font-semibold text-muted-4 uppercase tracking-wide-2 px-4 py-3 text-left">市场</th>
                  <th class="text-hl-12 font-semibold text-muted-4 uppercase tracking-wide-2 px-4 py-3 text-left">行业</th>
                  <th class="text-hl-12 font-semibold text-muted-4 uppercase tracking-wide-2 px-4 py-3 text-left">收藏时间</th>
                  <th class="text-hl-12 font-semibold text-muted-4 uppercase tracking-wide-2 px-4 py-3 text-left">操作</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-line-soft">
                <% @favorite_stocks.each do |favorite| %>
                  <tr class="hover:bg-bg-soft transition-colors">
                    <td class="px-4 py-3 whitespace-nowrap">
                      <span class="hl-tag font-mono"><%= favorite.stock.symbol %></span>
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap">
                      <span class="text-hl-14 text-ink font-medium"><%= favorite.stock.name %></span>
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap">
                      <span class="hl-tag"><%= favorite.stock.market %></span>
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap">
                      <span class="text-hl-13 text-muted-3"><%= favorite.stock.sector.presence || favorite.stock.industry.presence || '-' %></span>
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap">
                      <span class="text-hl-12 text-muted-4"><%= l(favorite.created_at, format: :short) %></span>
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap">
                      <%= button_to "取消收藏", favorite_stock_path(favorite), method: :delete,
                        class: "text-hl-13 text-link hover:text-link-hover transition-colors",
                        data: { turbo_confirm: "确定取消收藏 #{favorite.stock.symbol} 吗？" } %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>