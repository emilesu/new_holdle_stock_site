<div class="py-16 bg-bg-soft min-h-screen">
  <div class="container-narrow">

    <div class="hl-card overflow-hidden">

      <%# 用户头部 %>
      <div class="bg-ink px-6 sm:px-8 py-8">
        <div class="flex items-center gap-5">
          <%= user_avatar_tag(@user, size: "w-20 h-20", css_class: "text-hl-22") %>
          <div class="min-w-0">
            <h1 class="text-hl-18 font-semibold text-white"><%= @user.nickname %></h1>
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="inline-flex px-2.5 py-0.5 text-hl-11 font-medium bg-white/10 text-white/80 border border-white/20 rounded"><%= @user.member_status %></span>
            </div>
          </div>
        </div>
      </div>

      <%# 导航标签 %>
      <div class="flex border-b border-line px-6 sm:px-8">
        <nav class="flex gap-6">
          <a href="<%= users_profile_path %>" class="pb-3 border-b-2 border-ink text-ink font-medium text-hl-13">基本信息</a>
          <a href="<%= users_profile_favorites_path %>" class="pb-3 text-muted-3 hover:text-ink transition-colors text-hl-13">我的收藏</a>
        </nav>
      </div>

      <%# 信息区域 %>
      <div class="p-6 sm:p-8 space-y-5">

        <div class="bg-bg-soft rounded p-4 sm:p-5">
          <span class="text-hl-12 text-muted-4 block mb-1">昵称</span>
          <span class="text-hl-15 text-ink font-medium"><%= @user.nickname %></span>
        </div>

        <div class="bg-bg-soft rounded p-4 sm:p-5">
          <span class="text-hl-12 text-muted-4 block mb-1">个人简介</span>
          <span class="text-hl-14 text-muted leading-relaxed block min-h-[40px]">
            <%= @user.bio.presence || "<span class='text-muted-4'>暂无简介</span>".html_safe %>
          </span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-bg-soft rounded p-4 sm:p-5">
            <span class="text-hl-12 text-muted-4 block mb-1">会员到期时间</span>
            <span class="text-hl-14 text-ink font-medium">
              <%= @user.member_expire_at.present? ? l(@user.member_expire_at, format: :long) : "<span class='text-muted-4'>未开通会员</span>".html_safe %>
            </span>
          </div>
          <div class="bg-bg-soft rounded p-4 sm:p-5">
            <span class="text-hl-12 text-muted-4 block mb-1">角色权限</span>
            <span class="text-hl-14 text-ink font-medium"><%= human_role(@user.role) %></span>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-bg-soft rounded p-4 sm:p-5">
            <span class="text-hl-12 text-muted-4 block mb-1">注册时间</span>
            <span class="text-hl-14 text-ink font-medium"><%= l(@user.created_at, format: :long) %></span>
          </div>
          <div class="bg-bg-soft rounded p-4 sm:p-5">
            <span class="text-hl-12 text-muted-4 block mb-1">最后登录</span>
            <span class="text-hl-14 text-ink font-medium">
              <%= @user.last_login_at.present? ? l(@user.last_login_at, format: :long) : "<span class='text-muted-4'>暂无记录</span>".html_safe %>
            </span>
          </div>
        </div>

      </div>

      <%# 操作按钮 %>
      <div class="px-6 sm:px-8 pb-6 sm:pb-8 flex flex-wrap gap-3">
        <%= link_to "编辑资料", users_edit_profile_path, class: "hl-btn hl-btn-primary" %>
        <% if current_user.admin? %>
          <%= link_to "后台管理", admin_root_path, class: "hl-btn hl-btn-line" %>
        <% end %>
      </div>

    </div>
  </div>
</div>