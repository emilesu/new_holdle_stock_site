<div class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <div class="bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 px-6 py-10">
        <div class="flex items-center space-x-6">
          <div class="relative">
            <div class="w-28 h-28 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-white text-5xl font-bold shadow-2xl">
              <%= @user.avatar_char %>
            </div>
            <div class="absolute -bottom-2 -right-2 w-10 h-10 bg-green-500 rounded-full border-4 border-white flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
          </div>
          <div class="text-white">
            <h1 class="text-3xl font-bold tracking-tight"><%= @user.nickname %></h1>
            <p class="text-blue-100 mt-2 text-lg"><%= @user.email %></p>
            <div class="flex flex-wrap gap-2 mt-3">
              <span class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-medium bg-white/20 backdrop-blur-sm">
                <%= @user.member_status %>
              </span>
              <span class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-medium bg-white/20 backdrop-blur-sm">
                <%= @user.role.humanize %>
              </span>
            </div>
          </div>
        </div>
      </div>

      <div class="px-6 py-6">
        <div class="flex border-b border-gray-200 mb-6">
          <nav class="flex space-x-8">
            <a href="<%= users_profile_path %>" class="pb-3 border-b-2 border-blue-600 text-blue-600 font-semibold">基本信息</a>
            <a href="<%= users_profile_favorites_path %>" class="pb-3 text-gray-500 hover:text-gray-700 transition-colors">我的收藏</a>
          </nav>
        </div>

        <div class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-gray-50 rounded-xl p-5">
              <label class="block text-sm font-medium text-gray-600 mb-2">昵称</label>
              <p class="text-gray-800 text-lg font-medium"><%= @user.nickname %></p>
            </div>
            <div class="bg-gray-50 rounded-xl p-5">
              <label class="block text-sm font-medium text-gray-600 mb-2">邮箱</label>
              <p class="text-gray-800 text-lg font-medium"><%= @user.email %></p>
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-5">
            <label class="block text-sm font-medium text-gray-600 mb-2">个人简介</label>
            <p class="text-gray-800 text-lg leading-relaxed min-h-[80px]">
              <%= @user.bio.presence || "<span class='text-gray-400'>暂无简介</span>".html_safe %>
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-gray-50 rounded-xl p-5">
              <label class="block text-sm font-medium text-gray-600 mb-2">会员到期时间</label>
              <p class="text-gray-800 text-lg font-medium">
                <%= @user.member_expire_at.present? ? l(@user.member_expire_at, format: :long) : "<span class='text-gray-400'>未开通会员</span>".html_safe %>
              </p>
            </div>
            <div class="bg-gray-50 rounded-xl p-5">
              <label class="block text-sm font-medium text-gray-600 mb-2">角色权限</label>
              <p class="text-gray-800 text-lg font-medium"><%= @user.role.humanize %></p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-gray-50 rounded-xl p-5">
              <label class="block text-sm font-medium text-gray-600 mb-2">注册时间</label>
              <p class="text-gray-800 text-lg font-medium"><%= l(@user.created_at, format: :long) %></p>
            </div>
            <div class="bg-gray-50 rounded-xl p-5">
              <label class="block text-sm font-medium text-gray-600 mb-2">最后登录</label>
              <p class="text-gray-800 text-lg font-medium">
                <%= @user.last_login_at.present? ? l(@user.last_login_at, format: :long) : "<span class='text-gray-400'>暂无记录</span>".html_safe %>
              </p>
            </div>
          </div>
        </div>

        <div class="mt-8 flex space-x-4">
          <%= link_to "编辑资料", users_edit_profile_path, 
            class: "inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-xl hover:bg-blue-700 transition-all duration-200 shadow-md hover:shadow-lg font-medium" %>
          <% if current_user.is_admin? %>
            <%= link_to "后台管理", admin_root_path, 
              class: "inline-flex items-center px-6 py-3 bg-gray-800 text-white rounded-xl hover:bg-gray-900 transition-all duration-200 shadow-md hover:shadow-lg font-medium" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
