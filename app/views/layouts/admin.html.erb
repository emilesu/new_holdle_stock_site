<!DOCTYPE html>
<html>
  <head>
    <title>管理后台 - StockWebsite</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-gray-100 min-h-screen">
    <nav class="bg-gray-800 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex items-center space-x-8">
            <a href="<%= admin_root_path %>" class="text-xl font-bold">管理后台</a>
            <div class="hidden md:flex space-x-4">
              <a href="<%= admin_root_path %>" class="text-gray-300 hover:text-white px-3 py-2">仪表盘</a>
              <a href="<%= admin_users_path %>" class="text-gray-300 hover:text-white px-3 py-2">用户管理</a>
              <a href="<%= admin_stocks_path %>" class="text-gray-300 hover:text-white px-3 py-2">股票管理</a>
              <!-- 课程管理 - 待开发 -->
              <a href="<%= admin_stock_crawlers_path %>" class="text-gray-300 hover:text-white px-3 py-2">爬虫管理</a>
            </div>
          </div>
          
          <div class="flex items-center space-x-4">
            <div class="flex items-center space-x-3">
              <div class="w-8 h-8 rounded-full bg-gray-600 flex items-center justify-center text-white font-medium">
                <%= current_user.avatar_char %>
              </div>
              <div class="text-right hidden sm:block">
                <p class="text-sm font-medium"><%= current_user.nickname %></p>
                <p class="text-xs text-gray-400"><%= current_user.role.humanize %></p>
              </div>
            </div>
            <%= link_to "退出", destroy_user_session_path, method: :delete, class: "text-gray-300 hover:text-white px-3 py-2" %>
          </div>
        </div>
      </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <% if notice %>
        <div class="mb-4 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="mb-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg">
          <%= alert %>
        </div>
      <% end %>
      
      <%= yield %>
    </div>
  </body>
</html>
