<!DOCTYPE html>
<html>
  <head>
    <title>Holdle - 股票分析平台</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js"></script>
    <%= javascript_include_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body data-controller="message">
    <%= render "shared/navbar" %>

    <!-- 主内容区 -->
    <main class="min-h-screen" id="main-content">
      <%= yield %>
    </main>

    <%= render "shared/footer" %>

    <script>
      // 股票搜索自动补齐功能 - 防竞态设计
      (function() {
        var searchState = null;

        function initStockSearch() {
          if (searchState) return;
          var searchInput = document.getElementById('stock-search-input');
          var suggestionsBox = document.getElementById('search-suggestions');
          var suggestionsList = document.getElementById('suggestions-list');
          var noResults = document.getElementById('no-results');

          if (!searchInput) return;

          var state = {
            selectedIndex: -1,
            currentResults: [],
            debounceTimer: null,
            requestCounter: 0,
            abortController: null
          };
          searchState = state;

          function hideSuggestions() {
            suggestionsBox.classList.add('hidden');
            state.selectedIndex = -1;
          }

          function abortPreviousRequest() {
            if (state.abortController) {
              state.abortController.abort();
            }
            state.abortController = new AbortController();
            return state.abortController;
          }

          function searchStocks(query) {
            if (query.length < 1) {
              hideSuggestions();
              return;
            }

            var controller = abortPreviousRequest();
            var requestId = ++state.requestCounter;
            var signal = controller.signal;

            fetch('/stocks/autocomplete?q=' + encodeURIComponent(query), { signal: signal })
              .then(function(response) { return response.json(); })
              .then(function(data) {
                if (requestId !== state.requestCounter) return;
                state.currentResults = data;
                renderSuggestions(data);
              })
              .catch(function(error) {
                if (error.name === 'AbortError') return;
                console.error('搜索失败:', error);
              });
          }

          function renderSuggestions(results) {
            state.selectedIndex = -1;

            if (results.length === 0) {
              suggestionsList.innerHTML = '';
              suggestionsBox.classList.remove('hidden');
              noResults.classList.remove('hidden');
              return;
            }

            noResults.classList.add('hidden');
            suggestionsBox.classList.remove('hidden');

            suggestionsList.innerHTML = results.map(function(stock, index) {
              var marketClass = stock.market === 'CN'
                ? 'bg-green-100 text-green-700'
                : stock.market === 'HK'
                ? 'bg-amber-100 text-amber-700'
                : 'bg-blue-100 text-blue-700';

              return '<div class="suggestion-item px-4 py-3 hover:bg-gray-50 cursor-pointer transition-colors" data-index="' + index + '" data-url="' + stock.url + '" data-symbol="' + stock.symbol + '">' +
                '<div class="flex items-center justify-between">' +
                  '<div class="flex items-center space-x-3">' +
                    '<span class="px-2 py-0.5 text-xs font-medium rounded whitespace-nowrap ' + marketClass + '">' + stock.market_label + '</span>' +
                    '<span class="font-mono text-sm font-medium text-gray-800">' + stock.symbol + '</span>' +
                  '</div>' +
                  '<span class="text-sm text-gray-600 truncate max-w-[200px]" title="' + stock.name + '">' + stock.name + '</span>' +
                '</div>' +
              '</div>';
            }).join('');
          }

          function updateSelection() {
            var items = document.querySelectorAll('.suggestion-item');
            items.forEach(function(item, index) {
              if (index === state.selectedIndex) {
                item.classList.add('bg-blue-50', 'border-l-2', 'border-blue-500');
              } else {
                item.classList.remove('bg-blue-50', 'border-l-2', 'border-blue-500');
              }
            });
          }

          searchInput.addEventListener('input', function() {
            clearTimeout(state.debounceTimer);
            state.debounceTimer = setTimeout(function() {
              searchStocks(searchInput.value.trim());
            }, 300);
          });

          searchInput.addEventListener('keydown', function(e) {
            var items = document.querySelectorAll('.suggestion-item');

            if (e.key === 'ArrowDown') {
              e.preventDefault();
              state.selectedIndex = Math.min(state.selectedIndex + 1, items.length - 1);
              updateSelection();
            } else if (e.key === 'ArrowUp') {
              e.preventDefault();
              state.selectedIndex = Math.max(state.selectedIndex - 1, -1);
              updateSelection();
            } else if (e.key === 'Enter') {
              e.preventDefault();
              if (state.selectedIndex >= 0 && items[state.selectedIndex]) {
                window.location.href = items[state.selectedIndex].dataset.url;
              }
            } else if (e.key === 'Escape') {
              hideSuggestions();
            }
          });

          searchInput.addEventListener('focus', function() {
            if (state.currentResults.length > 0) {
              suggestionsBox.classList.remove('hidden');
            }
          });

          // 事件委托：下拉项点击跳转
          suggestionsBox.addEventListener('click', function(e) {
            var item = e.target.closest('.suggestion-item');
            if (item) {
              window.location.href = item.dataset.url;
            }
          });

          document.addEventListener('click', function(e) {
            var container = document.getElementById('search-container');
            if (container && !container.contains(e.target)) {
              hideSuggestions();
            }
          });
        }

        // 移动端菜单
        document.addEventListener('turbo:load', function() {
          var mobileMenuBtn = document.getElementById('mobile-menu-btn');
          var mobileMenu = document.getElementById('mobile-menu');

          if (mobileMenuBtn && mobileMenu) {
            mobileMenuBtn.addEventListener('click', function() {
              mobileMenu.classList.toggle('hidden');
            });
          }

          initStockSearch();
        });
      })();
    </script>

    <!-- 留言功能：浮窗按钮 + 弹窗 -->
      <!-- PC右下角悬浮留言按钮 -->
      <div class="message-float" data-action="click->message#open:prevent">留言</div>

      <!-- 留言弹窗 -->
      <div data-message-target="modal"
           class="hidden fixed inset-0 z-[9999]">
        <div data-message-target="mask"
             data-action="click->message#closeByMask"
             class="absolute inset-0 bg-black/40"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
                    bg-white border border-line rounded
                    w-[650px] max-w-[92%] max-h-[85vh] overflow-y-auto">
          <div class="flex items-center justify-between px-6 py-4 border-b border-line">
            <span class="text-hl-15 font-semibold text-ink">给「大苏」留言</span>
            <button data-action="message#close"
                    class="text-muted-4 hover:text-ink transition-colors text-hl-18 leading-none">&times;</button>
          </div>
          <div class="flex border-b border-line">
            <button data-action="message#switchTabPublish"
                    class="flex-1 px-4 py-3 text-hl-13 text-muted hover:text-ink hover:bg-bg-mute transition-colors border-r border-line last:border-r-0">我要留言</button>
            <button data-action="message#switchTabList"
                    class="flex-1 px-4 py-3 text-hl-13 text-muted hover:text-ink hover:bg-bg-mute transition-colors">留言回复</button>
          </div>
          <div data-message-target="tabPublish" class="p-6">
            <div id="modal_flash_result" class="mb-4 hidden"></div>
            <div id="message_form_content">
              <div id="message_form_area">
                <%= render partial: "message_boards/form" %>
              </div>
            </div>
          </div>
          <div data-message-target="tabList" class="p-6 hidden" id="message_modal_content">
            <p class="text-hl-13 text-muted-4 text-center py-8">点击tab加载留言记录</p>
          </div>
        </div>
      </div>
  </body>
</html>